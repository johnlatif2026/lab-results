<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>معمل تحاليل - الاستعلام عن النتائج</title>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  <style>
    :root {
      --primary-color: #6a11cb;
      --secondary-color: #2575fc;
      --accent-color: #ff512f;
      --light-color: #1a1a2e;
      --dark-color: #ffffff;
      --success-color: #00b09b;
      --border-radius: 16px;
      --box-shadow: 0 10px 30px rgba(0, 0, 0, 0.4);
      --transition: all 0.5s cubic-bezier(0.4, 0, 0.2, 1);
      --gradient: linear-gradient(135deg, var(--primary-color), var(--secondary-color));
    }
    
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }
    
    body {
      font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
      background: linear-gradient(135deg, #0f0c29 0%, #302b63 50%, #24243e 100%);
      color: var(--dark-color);
      min-height: 100vh;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      padding: 20px;
      line-height: 1.6;
      overflow-x: hidden;
    }

    /* خلفية متحركة */
    .background-animation {
      position: fixed;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      z-index: -2;
      overflow: hidden;
    }

    .circle {
      position: absolute;
      border-radius: 50%;
      background: var(--gradient);
      animation: float 20s infinite ease-in-out;
      opacity: 0.1;
    }

    .circle:nth-child(1) {
      width: 300px;
      height: 300px;
      top: -100px;
      right: -100px;
      animation-delay: 0s;
    }

    .circle:nth-child(2) {
      width: 200px;
      height: 200px;
      bottom: -50px;
      left: -50px;
      animation-delay: 5s;
      background: linear-gradient(135deg, #ff512f, #dd2476);
    }

    .circle:nth-child(3) {
      width: 150px;
      height: 150px;
      top: 50%;
      left: 10%;
      animation-delay: 10s;
      background: linear-gradient(135deg, #00b09b, #96c93d);
    }

    @keyframes float {
      0%, 100% {
        transform: translate(0, 0) rotate(0deg);
      }
      25% {
        transform: translate(20px, -20px) rotate(90deg);
      }
      50% {
        transform: translate(-20px, 20px) rotate(180deg);
      }
      75% {
        transform: translate(10px, -10px) rotate(270deg);
      }
    }
    
    /* تموجات */
    .ripple {
      position: fixed;
      border-radius: 50%;
      background: rgba(255, 255, 255, 0.03);
      animation: ripple 8s infinite ease-in-out;
      z-index: -1;
    }

    .ripple:nth-child(4) {
      width: 500px;
      height: 500px;
      top: -250px;
      right: -250px;
      animation-delay: 0s;
    }

    .ripple:nth-child(5) {
      width: 400px;
      height: 400px;
      bottom: -200px;
      left: -200px;
      animation-delay: 2s;
    }

    @keyframes ripple {
      0%, 100% {
        transform: scale(1);
        opacity: 0.05;
      }
      50% {
        transform: scale(1.1);
        opacity: 0.02;
      }
    }
    
    .container {
      width: 100%;
      max-width: 500px;
      background: rgba(22, 33, 62, 0.9);
      border-radius: var(--border-radius);
      box-shadow: var(--box-shadow);
      overflow: hidden;
      margin: 0 auto;
      border: 1px solid rgba(255, 255, 255, 0.1);
      backdrop-filter: blur(10px);
      animation: slideUp 1s ease-out;
      position: relative;
      z-index: 1;
    }

    @keyframes slideUp {
      from {
        opacity: 0;
        transform: translateY(50px) scale(0.9);
      }
      to {
        opacity: 1;
        transform: translateY(0) scale(1);
      }
    }
    
    header {
      background: linear-gradient(135deg, rgba(106, 17, 203, 0.9), rgba(37, 117, 252, 0.9));
      color: white;
      padding: 40px 20px;
      text-align: center;
      border-bottom: 1px solid rgba(255, 255, 255, 0.1);
      position: relative;
      overflow: hidden;
    }

    header::before {
      content: '';
      position: absolute;
      top: 0;
      right: 0;
      width: 100%;
      height: 100%;
      background: url('data:image/svg+xml;utf8,<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 100 100" preserveAspectRatio="none"><path d="M0,0 L100,0 L100,100 Z" fill="rgba(255,255,255,0.1)"/></svg>');
      background-size: cover;
      pointer-events: none;
    }
    
    header h1 {
      font-size: 2.2rem;
      margin-bottom: 15px;
      font-weight: 700;
      text-shadow: 0 2px 10px rgba(0, 0, 0, 0.3);
      animation: fadeIn 1s ease-out 0.5s both;
    }
    
    @keyframes fadeIn {
      from { opacity: 0; transform: translateY(-20px); }
      to { opacity: 1; transform: translateY(0); }
    }
    
    header p {
      font-size: 1.1rem;
      opacity: 0.9;
      animation: fadeIn 1s ease-out 0.7s both;
    }
    
    .content {
      padding: 40px 30px;
      background-color: rgba(26, 26, 46, 0.8);
    }
    
    .welcome-text {
      text-align: center;
      margin-bottom: 30px;
      animation: fadeIn 1s ease-out 0.9s both;
    }
    
    .welcome-text h2 {
      font-size: 1.8rem;
      color: #ffffff;
      margin-bottom: 10px;
      background: var(--gradient);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }
    
    .welcome-text p {
      color: rgba(255, 255, 255, 0.8);
      font-size: 1rem;
    }
    
    .form-section {
      background: rgba(15, 52, 96, 0.7);
      padding: 35px 30px;
      border-radius: var(--border-radius);
      animation: fadeIn 1s ease-out 1.1s both;
      border: 1px solid rgba(255, 255, 255, 0.1);
      position: relative;
      overflow: hidden;
    }

    .form-section::before {
      content: '';
      position: absolute;
      top: 0;
      right: 0;
      width: 100%;
      height: 4px;
      background: var(--gradient);
      animation: slideRight 2s infinite alternate;
    }

    @keyframes slideRight {
      0% {
        transform: translateX(-100%);
      }
      100% {
        transform: translateX(100%);
      }
    }
    
    .form-section h3 {
      margin-bottom: 25px;
      color: #ffffff;
      text-align: center;
      font-size: 1.4rem;
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 10px;
    }
    
    .form-section h3 i {
      color: var(--success-color);
      animation: pulse 2s infinite;
    }

    @keyframes pulse {
      0%, 100% {
        transform: scale(1);
      }
      50% {
        transform: scale(1.2);
      }
    }
    
    .input-group {
      margin-bottom: 25px;
      position: relative;
    }
    
    .input-group input {
      width: 100%;
      padding: 18px 20px;
      background: rgba(22, 33, 62, 0.9);
      border: 2px solid rgba(255, 255, 255, 0.2);
      border-radius: var(--border-radius);
      font-size: 1.1rem;
      transition: var(--transition);
      color: #ffffff;
      letter-spacing: 2px;
    }
    
    .input-group input::placeholder {
      color: rgba(255, 255, 255, 0.5);
      letter-spacing: normal;
    }
    
    .input-group input:focus {
      border-color: var(--primary-color);
      outline: none;
      box-shadow: 0 0 0 4px rgba(106, 17, 203, 0.3);
      background: rgba(26, 26, 46, 0.9);
      transform: translateY(-2px);
    }

    .input-group::after {
      content: '📱';
      position: absolute;
      left: 20px;
      top: 50%;
      transform: translateY(-50%);
      font-size: 1.2rem;
      opacity: 0.7;
      transition: var(--transition);
    }

    .input-group:focus-within::after {
      opacity: 1;
      transform: translateY(-50%) scale(1.2);
    }
    
    .submit-btn {
      background: var(--gradient);
      color: white;
      border: none;
      padding: 18px 30px;
      border-radius: var(--border-radius);
      font-size: 1.2rem;
      font-weight: bold;
      cursor: pointer;
      transition: var(--transition);
      width: 100%;
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 12px;
      position: relative;
      overflow: hidden;
    }

    .submit-btn::before {
      content: '';
      position: absolute;
      top: 0;
      left: -100%;
      width: 100%;
      height: 100%;
      background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.2), transparent);
      transition: 0.5s;
    }

    .submit-btn:hover::before {
      left: 100%;
    }
    
    .submit-btn:hover {
      transform: translateY(-3px);
      box-shadow: 0 10px 20px rgba(106, 17, 203, 0.4);
      background: linear-gradient(135deg, #2575fc, #6a11cb);
    }

    .submit-btn:active {
      transform: translateY(-1px);
    }

    .submit-btn i {
      transition: var(--transition);
    }

    .submit-btn:hover i {
      transform: translateX(5px);
    }
    
    footer {
      text-align: center;
      margin-top: 30px;
      color: rgba(255, 255, 255, 0.6);
      font-size: 0.9rem;
      padding: 20px;
      background-color: rgba(0, 0, 0, 0.3);
      border-radius: var(--border-radius);
      width: 100%;
      max-width: 500px;
      backdrop-filter: blur(5px);
      border: 1px solid rgba(255, 255, 255, 0.1);
      animation: fadeIn 1s ease-out 1.3s both;
    }

    /* تأثيرات للنجوم */
    .stars {
      position: fixed;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      pointer-events: none;
      z-index: -1;
    }

    .star {
      position: absolute;
      background: white;
      border-radius: 50%;
      animation: twinkle 3s infinite ease-in-out;
    }

    .star:nth-child(1) { top: 20%; left: 10%; width: 2px; height: 2px; animation-delay: 0s; }
    .star:nth-child(2) { top: 40%; left: 80%; width: 3px; height: 3px; animation-delay: 1s; }
    .star:nth-child(3) { top: 60%; left: 20%; width: 2px; height: 2px; animation-delay: 2s; }
    .star:nth-child(4) { top: 80%; left: 60%; width: 2px; height: 2px; animation-delay: 0.5s; }
    .star:nth-child(5) { top: 30%; left: 40%; width: 3px; height: 3px; animation-delay: 1.5s; }
    .star:nth-child(6) { top: 70%; left: 90%; width: 2px; height: 2px; animation-delay: 2.5s; }

    @keyframes twinkle {
      0%, 100% { opacity: 0.3; transform: scale(1); }
      50% { opacity: 1; transform: scale(1.2); }
    }

    /* تأثير الكتابة */
    .typing-effect {
      overflow: hidden;
      border-right: 3px solid var(--primary-color);
      white-space: nowrap;
      animation: typing 3.5s steps(40, end), blink-caret 0.75s step-end infinite;
    }

    @keyframes typing {
      from { width: 0 }
      to { width: 100% }
    }

    @keyframes blink-caret {
      from, to { border-color: transparent }
      50% { border-color: var(--primary-color) }
    }
    
    @media (max-width: 576px) {
      .container {
        max-width: 100%;
      }
      
      header {
        padding: 30px 20px;
      }
      
      header h1 {
        font-size: 1.8rem;
      }
      
      .content {
        padding: 30px 20px;
      }
      
      .form-section {
        padding: 25px 20px;
      }
      
      .input-group input {
        padding: 16px 45px 16px 16px;
      }
    }

    /* تأثير النجمة المتحركة عند النقر */
    .confetti {
      position: fixed;
      width: 10px;
      height: 10px;
      background: var(--gradient);
      border-radius: 50%;
      pointer-events: none;
      z-index: 1000;
      opacity: 0;
    }

    @keyframes confetti-fall {
      0% {
        opacity: 1;
        transform: translateY(-100px) rotate(0deg);
      }
      100% {
        opacity: 0;
        transform: translateY(100vh) rotate(720deg);
      }
    }
  </style>
</head>
<body>
  <!-- خلفية متحركة -->
  <div class="background-animation">
    <div class="circle"></div>
    <div class="circle"></div>
    <div class="circle"></div>
    <div class="ripple"></div>
    <div class="ripple"></div>
  </div>

  <!-- النجوم -->
  <div class="stars">
    <div class="star"></div>
    <div class="star"></div>
    <div class="star"></div>
    <div class="star"></div>
    <div class="star"></div>
    <div class="star"></div>
  </div>

  <div class="container">
    <header>
      <h1>معمل التحاليل (جون)</h1>
      <p>استعلم عن نتائج تحاليلك بسهولة وسرية تامة</p>
    </header>
    
    <div class="content">
      <div class="welcome-text">
        <h2>مرحباً بك</h2>
        <p>أدخل رقم هاتفك للاستعلام عن نتائج التحاليل</p>
      </div>
      
      <div id="form" class="form-section">
        <h3><i class="fas fa-search"></i> استعلام عن النتيجة</h3>
        <form method="POST" action="/result" onsubmit="return validatePhone()" id="phoneForm">
          <div class="input-group">
            <input type="text" name="phone" id="phoneInput" placeholder="أدخل رقم هاتفك هنا..." required autofocus>
          </div>
          <button type="submit" class="submit-btn" id="submitBtn">
            <i class="fas fa-search"></i> عرض النتائج
          </button>
        </form>
      </div>
    </div>
  </div>
  
    <footer>
      <p>© 2025 معمل التحاليل (جون). جميع الحقوق محفوظة.</p>
    </footer>

  <script>
    // تركيز على حقل الإدخال تلقائياً
    document.addEventListener('DOMContentLoaded', function() {
      const phoneInput = document.getElementById('phoneInput');
      phoneInput.focus();
      
      // إضافة تأثير الكتابة عند التركيز
      phoneInput.addEventListener('focus', function() {
        this.parentElement.classList.add('focused');
      });
      
      phoneInput.addEventListener('blur', function() {
        this.parentElement.classList.remove('focused');
      });
      
      // تأثير الكتابة للمحتوى
      const welcomeText = document.querySelector('.welcome-text h2');
      welcomeText.classList.add('typing-effect');
    });

    // التحقق من صحة رقم الهاتف
    function validatePhone() {
      const input = document.getElementById('phoneInput').value;
      const cleanedInput = input.replace(/\D/g, '');
      const isValid = /^[0-9]{10,11}$/.test(cleanedInput);
      
      if (!isValid) {
        // تأثير اهتزاز للحقل
        const phoneInput = document.getElementById('phoneInput');
        phoneInput.style.animation = 'shake 0.5s';
        phoneInput.style.borderColor = '#ff512f';
        
        setTimeout(() => {
          phoneInput.style.animation = '';
          phoneInput.style.borderColor = 'rgba(255, 255, 255, 0.2)';
        }, 500);
        
        // رسالة خطأ جذابة
        showError("من فضلك أدخل رقم هاتف صحيح (10 أو 11 رقم)");
        return false;
      }
      
      // تحديث قيمة الحقل بالأرقام فقط
      document.getElementById('phoneInput').value = cleanedInput;
      
      // إضافة تأثير النجمة المتحركة
      createConfetti();
      
      // تعطيل الزر مؤقتاً لمنع النقر المتكرر
      const submitBtn = document.getElementById('submitBtn');
      submitBtn.disabled = true;
      submitBtn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> جاري البحث...';
      
      return true;
    }

    // إنشاء تأثير الاهتزاز
    const style = document.createElement('style');
    style.textContent = `
      @keyframes shake {
        0%, 100% { transform: translateX(0); }
        10%, 30%, 50%, 70%, 90% { transform: translateX(-10px); }
        20%, 40%, 60%, 80% { transform: translateX(10px); }
      }
    `;
    document.head.appendChild(style);

    // عرض رسالة خطأ جذابة
    function showError(message) {
      // إزالة أي رسائل خطأ سابقة
      const existingError = document.querySelector('.error-message');
      if (existingError) existingError.remove();
      
      const errorDiv = document.createElement('div');
      errorDiv.className = 'error-message';
      errorDiv.innerHTML = `
        <i class="fas fa-exclamation-circle"></i> ${message}
      `;
      
      // إضافة الأنماط
      errorDiv.style.cssText = `
        position: fixed;
        top: 20px;
        left: 50%;
        transform: translateX(-50%);
        background: linear-gradient(135deg, #ff512f, #dd2476);
        color: white;
        padding: 15px 25px;
        border-radius: 10px;
        box-shadow: 0 5px 15px rgba(0,0,0,0.3);
        z-index: 1000;
        display: flex;
        align-items: center;
        gap: 10px;
        animation: slideDown 0.5s ease-out;
      `;
      
      const slideDownStyle = document.createElement('style');
      slideDownStyle.textContent = `
        @keyframes slideDown {
          from { top: -100px; opacity: 0; }
          to { top: 20px; opacity: 1; }
        }
      `;
      document.head.appendChild(slideDownStyle);
      
      document.body.appendChild(errorDiv);
      
      // إزالة الرسالة بعد 3 ثواني
      setTimeout(() => {
        errorDiv.style.animation = 'slideUp 0.5s ease-out forwards';
        
        const slideUpStyle = document.createElement('style');
        slideUpStyle.textContent = `
          @keyframes slideUp {
            from { top: 20px; opacity: 1; }
            to { top: -100px; opacity: 0; }
          }
        `;
        document.head.appendChild(slideUpStyle);
        
        setTimeout(() => errorDiv.remove(), 500);
      }, 3000);
    }

    // إنشاء تأثير النجمة المتحركة
    function createConfetti() {
      const colors = ['#6a11cb', '#2575fc', '#ff512f', '#00b09b'];
      
      for (let i = 0; i < 20; i++) {
        const confetti = document.createElement('div');
        confetti.className = 'confetti';
        
        // حجم عشوائي
        const size = Math.random() * 10 + 5;
        confetti.style.width = `${size}px`;
        confetti.style.height = `${size}px`;
        
        // لون عشوائي
        const color = colors[Math.floor(Math.random() * colors.length)];
        confetti.style.backgroundColor = color;
        
        // موقع عشوائي
        const startX = Math.random() * window.innerWidth;
        confetti.style.left = `${startX}px`;
        confetti.style.top = `0px`;
        
        // مدة وسرعة عشوائية
        const duration = Math.random() * 3 + 2;
        const delay = Math.random() * 0.5;
        
        confetti.style.animation = `confetti-fall ${duration}s ease-in ${delay}s forwards`;
        
        document.body.appendChild(confetti);
        
        // إزالة العنصر بعد انتهاء الأنيميشن
        setTimeout(() => confetti.remove(), (duration + delay) * 1000);
      }
    }
  </script>
</body>
</html>
