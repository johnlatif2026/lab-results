<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
  <title>معمل التحاليل - استعلام النتائج</title>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    body {
      font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', 'Tajawal', sans-serif;
      background: linear-gradient(145deg, #e8eff9 0%, #d4e0f0 100%);
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 20px;
    }

    .container {
      max-width: 500px;
      width: 100%;
      margin: 0 auto;
    }

    /* كارت رئيسي ناعم */
    .main-card {
      background: rgba(255, 255, 255, 0.98);
      backdrop-filter: blur(0px);
      border-radius: 40px;
      box-shadow: 0 20px 35px -12px rgba(0, 0, 0, 0.12), 0 0 0 1px rgba(0, 0, 0, 0.02);
      overflow: hidden;
      transition: all 0.3s ease;
    }

    /* الهيدر */
    .header {
      background: linear-gradient(135deg, #1e3c72 0%, #2a5298 100%);
      padding: 35px 25px;
      text-align: center;
      color: white;
    }

    .header h1 {
      font-size: 1.8rem;
      font-weight: 700;
      margin-bottom: 8px;
      letter-spacing: -0.5px;
    }

    .header p {
      font-size: 0.9rem;
      opacity: 0.85;
    }

    .lab-icon {
      background: rgba(255, 255, 255, 0.2);
      width: 70px;
      height: 70px;
      border-radius: 35px;
      display: flex;
      align-items: center;
      justify-content: center;
      margin: 0 auto 15px;
      font-size: 32px;
    }

    /* المحتوى */
    .content {
      padding: 30px 25px;
    }

    .welcome-title {
      text-align: center;
      margin-bottom: 28px;
    }

    .welcome-title h2 {
      font-size: 1.5rem;
      color: #1e293b;
      font-weight: 700;
      margin-bottom: 6px;
    }

    .welcome-title p {
      color: #64748b;
      font-size: 0.9rem;
    }

    /* الفورم */
    .form-card {
      background: #f8fafc;
      border-radius: 28px;
      padding: 20px;
    }

    .input-phone {
      margin-bottom: 20px;
    }

    .input-phone label {
      display: block;
      margin-bottom: 10px;
      color: #334155;
      font-weight: 600;
      font-size: 0.9rem;
    }

    .phone-wrapper {
      position: relative;
    }

    .phone-wrapper i {
      position: absolute;
      right: 18px;
      top: 50%;
      transform: translateY(-50%);
      color: #94a3b8;
      font-size: 1.1rem;
    }

    .phone-wrapper input {
      width: 100%;
      padding: 16px 48px 16px 18px;
      background: white;
      border: 1.5px solid #e2e8f0;
      border-radius: 60px;
      font-size: 1rem;
      color: #0f172a;
      transition: all 0.2s;
      font-family: monospace;
      font-size: 1.1rem;
      letter-spacing: 1px;
    }

    .phone-wrapper input:focus {
      outline: none;
      border-color: #2a5298;
      box-shadow: 0 0 0 3px rgba(42, 82, 152, 0.1);
    }

    .phone-wrapper input::placeholder {
      color: #cbd5e1;
      font-family: inherit;
    }

    /* زر البحث */
    .search-btn {
      width: 100%;
      background: linear-gradient(135deg, #1e3c72 0%, #2a5298 100%);
      border: none;
      padding: 16px;
      border-radius: 60px;
      color: white;
      font-size: 1rem;
      font-weight: 700;
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 10px;
      cursor: pointer;
      transition: all 0.2s;
      box-shadow: 0 4px 12px rgba(42, 82, 152, 0.3);
    }

    .search-btn:hover {
      transform: translateY(-2px);
      box-shadow: 0 8px 20px rgba(42, 82, 152, 0.35);
    }

    .search-btn:active {
      transform: translateY(0);
    }

    /* تذييل */
    .footer {
      text-align: center;
      padding: 20px;
      background: #f1f5f9;
      font-size: 0.75rem;
      color: #64748b;
      border-top: 1px solid #e2e8f0;
    }

    /* رسائل الخطأ */
    .error-toast {
      position: fixed;
      bottom: 30px;
      left: 20px;
      right: 20px;
      background: #dc2626;
      color: white;
      padding: 14px 20px;
      border-radius: 60px;
      display: flex;
      align-items: center;
      gap: 12px;
      font-weight: 500;
      box-shadow: 0 10px 25px -5px rgba(0, 0, 0, 0.2);
      z-index: 1000;
      animation: slideUp 0.3s ease;
      max-width: 400px;
      margin: 0 auto;
    }

    @keyframes slideUp {
      from {
        opacity: 0;
        transform: translateY(20px);
      }
      to {
        opacity: 1;
        transform: translateY(0);
      }
    }

    @media (max-width: 480px) {
      body {
        padding: 16px;
      }
      .header {
        padding: 25px 20px;
      }
      .header h1 {
        font-size: 1.5rem;
      }
      .content {
        padding: 25px 20px;
      }
      .form-card {
        padding: 18px;
      }
    }
  </style>
</head>
<body>
  <div class="container">
    <div class="main-card">
      <div class="header">
        <div class="lab-icon">
          <i class="fas fa-flask"></i>
        </div>
        <h1>معمل التحاليل (جون)</h1>
        <p>استعلم عن نتائج تحاليلك بسهولة</p>
      </div>

      <div class="content">
        <div class="welcome-title">
          <h2>مرحباً بك 👋</h2>
          <p>أدخل رقم هاتفك لعرض النتائج</p>
        </div>

        <div class="form-card">
          <form method="POST" action="/result" id="phoneForm">
            <div class="input-phone">
              <label>رقم الهاتف</label>
              <div class="phone-wrapper">
                <i class="fas fa-phone-alt"></i>
                <input type="tel" name="phone" id="phoneInput" placeholder="05XXXXXXXX" required autofocus>
              </div>
            </div>
            <button type="submit" class="search-btn">
              <i class="fas fa-search"></i> عرض النتائج
            </button>
          </form>
        </div>
      </div>

      <div class="footer">
        <p>© 2025 معمل التحاليل (جون) - جميع الحقوق محفوظة</p>
      </div>
    </div>
  </div>

  <script>
    document.addEventListener('DOMContentLoaded', () => {
      document.getElementById('phoneInput').focus();
    });

    function validatePhone() {
      const input = document.getElementById('phoneInput');
      let value = input.value.replace(/\D/g, '');
      
      if (!/^[0-9]{10,11}$/.test(value)) {
        showError("📱 يرجى إدخال رقم هاتف صحيح (10 أو 11 رقم)");
        return false;
      }
      
      input.value = value;
      return true;
    }

    function showError(msg) {
      const existing = document.querySelector('.error-toast');
      if (existing) existing.remove();
      
      const div = document.createElement('div');
      div.className = 'error-toast';
      div.innerHTML = `<i class="fas fa-exclamation-circle"></i> ${msg} <i class="fas fa-times-circle" style="margin-right: auto; cursor: pointer;" onclick="this.parentElement.remove()"></i>`;
      document.body.appendChild(div);
      
      setTimeout(() => {
        if (div && div.remove) div.remove();
      }, 3500);
    }

    const form = document.getElementById('phoneForm');
    form.addEventListener('submit', function(e) {
      if (!validatePhone()) {
        e.preventDefault();
      }
    });
  </script>
</body>
</html>
