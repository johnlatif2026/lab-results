<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>معمل جون - استعلام النتائج</title>

  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

  <style>
    :root{
      --bg:#0b0f1a;
      --card:#12182b;
      --glass:rgba(255,255,255,0.05);
      --primary:#00d4ff;
      --secondary:#4facfe;
      --text:#e6e9f0;
      --muted:#9aa3b2;
      --radius:14px;
    }

    *{
      margin:0;
      padding:0;
      box-sizing:border-box;
      font-family:'Cairo',sans-serif;
    }

    body{
      background: radial-gradient(circle at top,#11182c,#05070f);
      color:var(--text);
      min-height:100vh;
      display:flex;
      align-items:center;
      justify-content:center;
      padding:20px;
    }

    .container{
      width:100%;
      max-width:420px;
      background:var(--card);
      border-radius:var(--radius);
      box-shadow:0 20px 50px rgba(0,0,0,0.6);
      overflow:hidden;
      border:1px solid rgba(255,255,255,0.05);
    }

    /* HEADER */
    header{
      padding:30px 20px;
      text-align:center;
      background:linear-gradient(135deg,#0f2027,#203a43,#2c5364);
    }

    header h1{
      font-size:1.7rem;
      margin-bottom:8px;
    }

    header p{
      color:var(--muted);
      font-size:.95rem;
    }

    /* CONTENT */
    .content{
      padding:25px 20px;
    }

    .welcome{
      text-align:center;
      margin-bottom:20px;
    }

    .welcome h2{
      color:var(--primary);
      margin-bottom:5px;
    }

    .welcome p{
      color:var(--muted);
      font-size:.9rem;
    }

    /* FORM */
    .form{
      background:var(--glass);
      padding:20px;
      border-radius:var(--radius);
      backdrop-filter:blur(10px);
    }

    .input-group{
      position:relative;
      margin-bottom:15px;
    }

    .input-group input{
      width:100%;
      padding:14px 15px;
      border-radius:10px;
      border:1px solid rgba(255,255,255,0.1);
      background:#0e1424;
      color:white;
      font-size:1rem;
    }

    .input-group input:focus{
      outline:none;
      border-color:var(--primary);
      box-shadow:0 0 0 2px rgba(0,212,255,0.2);
    }

    /* BUTTON */
    .btn{
      width:100%;
      padding:13px;
      border:none;
      border-radius:10px;
      background:linear-gradient(135deg,var(--primary),var(--secondary));
      color:black;
      font-size:1rem;
      font-weight:bold;
      cursor:pointer;
      transition:.3s;
    }

    .btn:hover{
      transform:translateY(-2px) scale(1.02);
    }

    footer{
      text-align:center;
      padding:15px;
      font-size:.8rem;
      color:var(--muted);
    }

    /* ERROR */
    .error{
      position:fixed;
      top:20px;
      left:50%;
      transform:translateX(-50%);
      background:#ff4d4d;
      color:white;
      padding:10px 20px;
      border-radius:8px;
    }

    @media(max-width:480px){
      .container{
        margin-top:20px;
      }
    }

  </style>
</head>

<body>

<div class="container">

<header>
  <h1>🧪 معمل جون</h1>
  <p>استعلام عن نتائج التحاليل بسهولة</p>
</header>

<div class="content">

  <div class="welcome">
    <h2>مرحباً بك</h2>
    <p>أدخل رقم هاتفك لعرض النتائج</p>
  </div>

  <div class="form">
    <form method="POST" action="/result" onsubmit="return validatePhone()">

      <div class="input-group">
        <input type="text" id="phoneInput" placeholder="ادخل رقم هاتفك" required>
      </div>

      <button class="btn">
        عرض النتائج
      </button>

    </form>
  </div>

</div>

<footer>
  © 2025 معمل التحاليل (جون). جميع الحقوق محفوظة.
</footer>

</div>

<script>

function validatePhone(){
  const input=document.getElementById('phoneInput').value.replace(/\D/g,'');

  if(!/^[0-9]{10,11}$/.test(input)){
    showError("رقم غير صحيح");
    return false;
  }

  document.getElementById('phoneInput').value=input;
  return true;
}

function showError(msg){
  const div=document.createElement('div');
  div.className='error';
  div.innerText=msg;
  document.body.appendChild(div);

  setTimeout(()=>div.remove(),3000);
}

</script>

</body>
</html>
