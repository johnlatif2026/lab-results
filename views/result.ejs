<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>نتائج التحاليل الطبية</title>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  <style>
    :root {
      --primary-color: #6a11cb;
      --secondary-color: #2575fc;
      --accent-color: #ff512f;
      --success-color: #00b09b;
      --border-radius: 16px;
      --box-shadow: 0 5px 15px rgba(0, 0, 0, 0.2);
      --transition: all 0.3s ease;
      --gradient: linear-gradient(135deg, var(--primary-color), var(--secondary-color));
      --gradient-success: linear-gradient(135deg, #00b09b, #96c93d);
      --gradient-danger: linear-gradient(135deg, #ff512f, #dd2476);
      --gradient-info: linear-gradient(135deg, #3498db, #2980b9);
    }
    
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }
    
    body {
      font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
      background: linear-gradient(135deg, #0f0c29 0%, #302b63 100%);
      color: #ffffff;
      min-height: 100vh;
      line-height: 1.6;
      padding: 20px;
    }
    
    .container {
      max-width: 1200px;
      margin: 0 auto;
      background: rgba(22, 33, 62, 0.95);
      border-radius: var(--border-radius);
      box-shadow: var(--box-shadow);
      overflow: hidden;
      border: 1px solid rgba(255, 255, 255, 0.1);
    }
    
    header {
      background: linear-gradient(135deg, rgba(106, 17, 203, 0.9), rgba(37, 117, 252, 0.9));
      color: white;
      padding: 40px 20px;
      text-align: center;
      border-bottom: 1px solid rgba(255, 255, 255, 0.1);
      position: relative;
    }
    
    header h1 {
      font-size: 2.2rem;
      margin-bottom: 10px;
      font-weight: 700;
      background: linear-gradient(135deg, #ffffff, #e6e6e6);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }
    
    .back-btn {
      position: absolute;
      top: 20px;
      right: 20px;
      background: rgba(255, 255, 255, 0.15);
      color: white;
      border: 1px solid rgba(255, 255, 255, 0.3);
      padding: 12px 20px;
      border-radius: var(--border-radius);
      cursor: pointer;
      transition: var(--transition);
      text-decoration: none;
      display: flex;
      align-items: center;
      gap: 8px;
      font-weight: 600;
    }
    
    .back-btn:hover {
      background: rgba(255, 255, 255, 0.25);
      transform: translateY(-2px);
    }
    
    main {
      padding: 40px 30px;
      background: rgba(26, 26, 46, 0.9);
      min-height: 500px;
    }
    
    .results-header {
      text-align: center;
      margin-bottom: 40px;
      padding: 30px;
      background: rgba(15, 52, 96, 0.7);
      border-radius: var(--border-radius);
      border: 1px solid rgba(255, 255, 255, 0.1);
    }
    
    .results-header h2 {
      font-size: 1.8rem;
      margin-bottom: 15px;
      color: #ffffff;
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 15px;
    }

    .results-header h2 i {
      color: var(--success-color);
    }
    
    .patient-info {
      display: flex;
      flex-wrap: wrap;
      justify-content: center;
      gap: 20px;
      margin-top: 20px;
    }
    
    .info-card {
      background: rgba(106, 17, 203, 0.2);
      padding: 15px 25px;
      border-radius: var(--border-radius);
      border: 1px solid rgba(106, 17, 203, 0.3);
      display: flex;
      align-items: center;
      gap: 10px;
      min-width: 200px;
    }
    
    .info-label {
      color: rgba(255, 255, 255, 0.9);
      font-size: 1rem;
    }
    
    .info-value {
      font-weight: bold;
      color: #ffffff;
      font-family: 'Courier New', monospace;
      font-size: 1.1rem;
    }
    
    .phone-number {
      font-weight: bold;
      color: #ffffff;
      direction: ltr;
      font-family: 'Courier New', monospace;
      font-size: 1.2rem;
      letter-spacing: 1px;
      background: var(--gradient);
      padding: 8px 15px;
      border-radius: 8px;
    }

    .result-count {
      background: var(--gradient-success);
      color: white;
      padding: 8px 20px;
      border-radius: 30px;
      font-weight: 600;
      font-size: 1.1rem;
      margin-top: 20px;
      display: inline-block;
    }
    
    /* قسم الملاحظات */
    .notes-section {
      background: rgba(52, 152, 219, 0.1);
      padding: 25px;
      border-radius: var(--border-radius);
      border: 1px solid rgba(52, 152, 219, 0.3);
      margin-bottom: 30px;
    }
    
    .notes-header {
      display: flex;
      align-items: center;
      gap: 12px;
      margin-bottom: 15px;
      color: #ffffff;
    }
    
    .notes-header i {
      color: #3498db;
      font-size: 1.4rem;
    }
    
    .notes-header h3 {
      font-size: 1.4rem;
      margin: 0;
    }
    
    .notes-content {
      color: rgba(255, 255, 255, 0.9);
      font-size: 1.1rem;
      line-height: 1.7;
      padding: 15px;
      background: rgba(0, 0, 0, 0.1);
      border-radius: var(--border-radius);
      border-right: 4px solid #3498db;
    }
    
    .no-notes {
      color: rgba(255, 255, 255, 0.6);
      font-style: italic;
      text-align: center;
      padding: 20px;
      background: rgba(0, 0, 0, 0.05);
      border-radius: var(--border-radius);
    }
    
    .table-container {
      background: rgba(15, 52, 96, 0.7);
      border-radius: var(--border-radius);
      padding: 20px;
      border: 1px solid rgba(255, 255, 255, 0.1);
      margin-bottom: 40px;
    }
    
    .table-responsive {
      overflow-x: auto;
      border-radius: 12px;
    }
    
    table {
      width: 100%;
      border-collapse: collapse;
      border-radius: 12px;
      overflow: hidden;
    }
    
    thead {
      background: var(--gradient);
    }
    
    th {
      padding: 20px;
      text-align: right;
      color: white;
      font-weight: 700;
      font-size: 1.1rem;
      position: relative;
    }
    
    td {
      padding: 20px;
      text-align: right;
      border-bottom: 1px solid rgba(255, 255, 255, 0.1);
      color: #ffffff;
      font-size: 1.05rem;
    }
    
    tbody tr {
      background: rgba(255, 255, 255, 0.05);
      transition: var(--transition);
    }
    
    tr:hover {
      background: rgba(255, 255, 255, 0.1);
    }
    
    .action-buttons {
      display: flex;
      gap: 12px;
    }
    
    .btn {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      padding: 12px 25px;
      border-radius: var(--border-radius);
      font-weight: 700;
      text-decoration: none;
      transition: var(--transition);
      font-size: 1rem;
      border: none;
      cursor: pointer;
      gap: 10px;
      min-width: 130px;
    }
    
    .btn-download {
      background: var(--gradient);
      color: white;
    }
    
    .btn-download:hover {
      background: linear-gradient(135deg, #2575fc, #6a11cb);
      transform: translateY(-2px);
    }
    
    .btn-view {
      background: var(--gradient-success);
      color: white;
    }
    
    .btn-view:hover {
      background: linear-gradient(135deg, #96c93d, #00b09b);
      transform: translateY(-2px);
    }
    
    .no-results {
      text-align: center;
      padding: 80px 30px;
      background: rgba(15, 52, 96, 0.7);
      border-radius: var(--border-radius);
      margin: 30px 0;
      border: 1px solid rgba(255, 255, 255, 0.1);
    }
    
    .no-results-icon {
      font-size: 5rem;
      margin-bottom: 25px;
      display: inline-block;
    }
    
    .no-results h3 {
      color: #ffffff;
      margin-bottom: 20px;
      font-size: 2rem;
      background: var(--gradient-danger);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }
    
    .no-results p {
      color: rgba(255, 255, 255, 0.8);
      margin-bottom: 20px;
      font-size: 1.1rem;
      max-width: 600px;
      margin-left: auto;
      margin-right: auto;
    }
    
    .search-again {
      display: inline-flex;
      align-items: center;
      gap: 12px;
      padding: 16px 35px;
      background: var(--gradient);
      color: white;
      text-decoration: none;
      border-radius: var(--border-radius);
      font-weight: 700;
      transition: var(--transition);
      border: none;
      cursor: pointer;
      font-size: 1.1rem;
      margin-top: 20px;
    }
    
    .search-again:hover {
      background: linear-gradient(135deg, #2575fc, #6a11cb);
      transform: translateY(-2px);
    }
    
    footer {
      text-align: center;
      margin-top: 40px;
      color: rgba(255, 255, 255, 0.7);
      font-size: 0.9rem;
      padding: 25px;
      background: rgba(0, 0, 0, 0.3);
      border-top: 1px solid rgba(255, 255, 255, 0.1);
    }

    footer p {
      margin-bottom: 10px;
    }

    .footer-contact {
      color: rgba(255, 255, 255, 0.6);
      font-size: 0.85rem;
    }
    
    @media (max-width: 768px) {
      th, td {
        padding: 15px 12px;
      }
      
      .btn {
        padding: 10px 20px;
        font-size: 0.9rem;
        min-width: 110px;
      }
      
      header h1 {
        font-size: 1.8rem;
      }
      
      .back-btn {
        position: relative;
        top: auto;
        right: auto;
        margin: 0 auto 20px;
        display: inline-flex;
        justify-content: center;
        width: auto;
      }

      .results-header h2 {
        flex-direction: column;
        gap: 10px;
      }

      .patient-info {
        flex-direction: column;
        align-items: center;
      }

      .info-card {
        width: 100%;
        max-width: 300px;
      }

      .action-buttons {
        flex-direction: column;
      }
    }
    
    @media (max-width: 576px) {
      .action-buttons {
        flex-direction: column;
        gap: 8px;
      }
      
      .btn {
        width: 100%;
        justify-content: center;
      }

      .container {
        padding: 10px;
      }

      header, main {
        padding: 20px 15px;
      }
    }
  </style>
</head>
<body>
  <div class="container">
    <header>
      <a href="/" class="back-btn">
        <i class="fas fa-arrow-right"></i> العودة للبحث
      </a>
      <h1>نتائج التحاليل الطبية</h1>
    </header>

    <main>
      <div class="results-header">
        <h2><i class="fas fa-file-medical-alt"></i> نتائج التحاليل</h2>
        <p style="color: rgba(255, 255, 255, 0.9); margin-bottom: 20px; font-size: 1.1rem;">يمكنك الاطلاع على نتائج تحاليلك وتحميلها بسهولة</p>
        
        <% if (Array.isArray(result) && result.length > 0) { 
          const patient = result[0]; // نفترض أن جميع النتائج لنفس المريض
        %>
          <div class="patient-info">
            <div class="info-card">
              <span class="info-label">اسم المريض:</span>
              <span class="info-value"><%= patient.name %></span>
            </div>
            
            <div class="info-card">
              <span class="info-label">رقم الهاتف:</span>
              <span class="phone-number"><%= phoneNumber || "غير محدد" %></span>
            </div>
            
            <% if (patient.test) { %>
              <div class="info-card">
                <span class="info-label">نوع التحليل:</span>
                <span class="info-value"><%= patient.test %></span>
              </div>
            <% } %>
            
            <% if (patient.date) { %>
              <div class="info-card">
                <span class="info-label">تاريخ النتيجة:</span>
                <span class="info-value"><%= patient.date %></span>
              </div>
            <% } %>
          </div>
          
          <div class="result-count">
            <i class="fas fa-check-circle"></i> تم العثور على <%= result.length %> نتيجة
          </div>
        <% } %>
      </div>
      
      <% if (Array.isArray(result) && result.length > 0) { 
        const patient = result[0];
      %>
        <!-- قسم الملاحظات الإضافية -->
        <% if (patient.notes && patient.notes.trim() !== '') { %>
          <div class="notes-section">
            <div class="notes-header">
              <i class="fas fa-sticky-note"></i>
              <h3>ملاحظات إضافية</h3>
            </div>
            <div class="notes-content">
              <%= patient.notes %>
            </div>
          </div>
        <% } else { %>
          <div class="notes-section">
            <div class="notes-header">
              <i class="fas fa-sticky-note"></i>
              <h3>ملاحظات إضافية</h3>
            </div>
            <div class="no-notes">
              لا توجد ملاحظات إضافية مرفقة مع هذه النتيجة
            </div>
          </div>
        <% } %>
        
        <div class="table-container">
          <div class="table-responsive">
            <table>
              <thead>
                <tr>
                  <th>اسم المريض</th>
                  <th>رقم الهاتف</th>
                  <th>الإجراءات</th>
                </tr>
              </thead>
              <tbody>
                <% result.forEach((r, index) => { %>
                  <tr>
                    <td>
                      <strong><%= r.name %></strong>
                      <% if (r.test) { %>
                        <br><small style="color: rgba(255, 255, 255, 0.7);">نوع التحليل: <%= r.test %></small>
                      <% } %>
                    </td>
                    <td><%= r.phone %></td>
                    <td>
                      <div class="action-buttons">
                        <a href="/download/<%= r.file %>" class="btn btn-download">
                          <i class="fas fa-download"></i> تحميل
                        </a>
                        <a href="/view/<%= r.file %>" target="_blank" class="btn btn-view">
                          <i class="fas fa-eye"></i> عرض
                        </a>
                      </div>
                    </td>
                  </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
        </div>
      <% } else { %>
        <div class="no-results">
          <div class="no-results-icon">🔍</div>
          <h3>لا توجد نتائج متاحة</h3>
          <p>لم يتم العثور على نتائج للرقم المدخل</p>
          <p>يرجى التأكد من صحة الرقم أو التواصل مع المركز الطبي للحصول على المساعدة</p>
          <a href="/" class="search-again">
            <i class="fas fa-redo"></i> البحث مرة أخرى
          </a>
        </div>
      <% } %>
    </main>
    
    <footer>
      <p>© 2025 معمل التحاليل (جون). جميع الحقوق محفوظة.</p>
    </footer>
  </div>

  <script>
    document.addEventListener('DOMContentLoaded', function() {
      // تأثير للنص الديناميكي
      const phoneNumber = document.querySelector('.phone-number');
      if (phoneNumber && phoneNumber.textContent !== 'غير محدد') {
        phoneNumber.style.animation = 'pulse 2s infinite';
      }
    });
  </script>
</body>
</html>
