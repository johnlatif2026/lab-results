<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>نتائج التحاليل الطبية</title>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  <style>
    :root {
      --primary-color: #6a11cb;
      --secondary-color: #2575fc;
      --accent-color: #ff512f;
      --success-color: #00b09b;
      --border-radius: 16px;
      --box-shadow: 0 10px 30px rgba(0, 0, 0, 0.4);
      --transition: all 0.5s cubic-bezier(0.4, 0, 0.2, 1);
      --gradient: linear-gradient(135deg, var(--primary-color), var(--secondary-color));
      --gradient-success: linear-gradient(135deg, #00b09b, #96c93d);
      --gradient-danger: linear-gradient(135deg, #ff512f, #dd2476);
    }
    
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }
    
    body {
      font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
      background: linear-gradient(135deg, #0f0c29 0%, #302b63 50%, #24243e 100%);
      color: #ffffff;
      min-height: 100vh;
      line-height: 1.6;
      padding: 20px;
      overflow-x: hidden;
    }

    /* خلفية متحركة */
    .background-animation {
      position: fixed;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      z-index: -2;
      overflow: hidden;
    }

    .circle {
      position: absolute;
      border-radius: 50%;
      animation: float 25s infinite ease-in-out;
      opacity: 0.1;
      filter: blur(20px);
    }

    .circle:nth-child(1) {
      width: 400px;
      height: 400px;
      top: -200px;
      right: -200px;
      animation-delay: 0s;
      background: var(--gradient);
    }

    .circle:nth-child(2) {
      width: 300px;
      height: 300px;
      bottom: -150px;
      left: -150px;
      animation-delay: 8s;
      background: var(--gradient-success);
    }

    .circle:nth-child(3) {
      width: 250px;
      height: 250px;
      top: 50%;
      left: 10%;
      animation-delay: 15s;
      background: var(--gradient-danger);
    }

    @keyframes float {
      0%, 100% {
        transform: translate(0, 0) rotate(0deg) scale(1);
      }
      25% {
        transform: translate(30px, -30px) rotate(90deg) scale(1.1);
      }
      50% {
        transform: translate(-30px, 30px) rotate(180deg) scale(0.9);
      }
      75% {
        transform: translate(15px, -15px) rotate(270deg) scale(1.05);
      }
    }
    
    /* تموجات */
    .ripple {
      position: fixed;
      border-radius: 50%;
      background: rgba(255, 255, 255, 0.03);
      animation: ripple 10s infinite ease-in-out;
      z-index: -1;
    }

    .ripple:nth-child(4) {
      width: 600px;
      height: 600px;
      top: -300px;
      right: -300px;
      animation-delay: 0s;
    }

    .ripple:nth-child(5) {
      width: 500px;
      height: 500px;
      bottom: -250px;
      left: -250px;
      animation-delay: 4s;
    }

    @keyframes ripple {
      0%, 100% {
        transform: scale(1);
        opacity: 0.03;
      }
      50% {
        transform: scale(1.15);
        opacity: 0.01;
      }
    }

    /* النجوم */
    .stars {
      position: fixed;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      pointer-events: none;
      z-index: -1;
    }

    .star {
      position: absolute;
      background: white;
      border-radius: 50%;
      animation: twinkle 4s infinite ease-in-out;
    }

    .star:nth-child(1) { top: 15%; left: 5%; width: 2px; height: 2px; animation-delay: 0s; }
    .star:nth-child(2) { top: 30%; left: 85%; width: 3px; height: 3px; animation-delay: 1s; }
    .star:nth-child(3) { top: 45%; left: 15%; width: 2px; height: 2px; animation-delay: 2s; }
    .star:nth-child(4) { top: 65%; left: 70%; width: 2px; height: 2px; animation-delay: 0.5s; }
    .star:nth-child(5) { top: 25%; left: 35%; width: 3px; height: 3px; animation-delay: 1.5s; }
    .star:nth-child(6) { top: 75%; left: 95%; width: 2px; height: 2px; animation-delay: 2.5s; }
    .star:nth-child(7) { top: 85%; left: 25%; width: 3px; height: 3px; animation-delay: 3s; }

    @keyframes twinkle {
      0%, 100% { opacity: 0.3; transform: scale(1); }
      50% { opacity: 1; transform: scale(1.3); }
    }
    
    .container {
      max-width: 1200px;
      margin: 0 auto;
      background: rgba(22, 33, 62, 0.85);
      border-radius: var(--border-radius);
      box-shadow: var(--box-shadow);
      overflow: hidden;
      border: 1px solid rgba(255, 255, 255, 0.1);
      backdrop-filter: blur(10px);
      animation: slideUp 1s ease-out;
      position: relative;
      z-index: 1;
    }

    @keyframes slideUp {
      from {
        opacity: 0;
        transform: translateY(50px) scale(0.95);
      }
      to {
        opacity: 1;
        transform: translateY(0) scale(1);
      }
    }
    
    header {
      background: linear-gradient(135deg, rgba(106, 17, 203, 0.9), rgba(37, 117, 252, 0.9));
      color: white;
      padding: 40px 20px;
      text-align: center;
      border-bottom: 1px solid rgba(255, 255, 255, 0.1);
      position: relative;
      overflow: hidden;
    }

    header::before {
      content: '';
      position: absolute;
      top: 0;
      right: 0;
      width: 100%;
      height: 100%;
      background: url('data:image/svg+xml;utf8,<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 100 100" preserveAspectRatio="none"><path d="M0,0 L100,0 L100,100 Z" fill="rgba(255,255,255,0.1)"/></svg>');
      background-size: cover;
      pointer-events: none;
    }
    
    header h1 {
      font-size: 2.2rem;
      margin-bottom: 10px;
      font-weight: 700;
      text-shadow: 0 2px 10px rgba(0, 0, 0, 0.3);
      background: linear-gradient(135deg, #ffffff, #e6e6e6);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
      animation: fadeIn 1s ease-out 0.3s both;
    }
    
    @keyframes fadeIn {
      from { opacity: 0; transform: translateY(-20px); }
      to { opacity: 1; transform: translateY(0); }
    }
    
    .back-btn {
      position: absolute;
      top: 20px;
      right: 20px;
      background: rgba(255, 255, 255, 0.15);
      color: white;
      border: 1px solid rgba(255, 255, 255, 0.3);
      padding: 12px 20px;
      border-radius: var(--border-radius);
      cursor: pointer;
      transition: var(--transition);
      text-decoration: none;
      display: flex;
      align-items: center;
      gap: 8px;
      font-weight: 600;
      backdrop-filter: blur(5px);
      animation: fadeIn 1s ease-out 0.5s both;
    }
    
    .back-btn:hover {
      background: rgba(255, 255, 255, 0.25);
      transform: translateY(-3px) translateX(5px);
      box-shadow: 0 5px 15px rgba(0, 0, 0, 0.3);
    }

    .back-btn i {
      transition: var(--transition);
    }

    .back-btn:hover i {
      transform: translateX(5px);
    }
    
    main {
      padding: 40px 30px;
      background: rgba(26, 26, 46, 0.8);
      min-height: 500px;
      animation: fadeIn 1s ease-out 0.7s both;
    }
    
    .results-header {
      text-align: center;
      margin-bottom: 40px;
      padding: 30px;
      background: rgba(15, 52, 96, 0.6);
      border-radius: var(--border-radius);
      border: 1px solid rgba(255, 255, 255, 0.1);
      position: relative;
      overflow: hidden;
    }

    .results-header::before {
      content: '';
      position: absolute;
      top: 0;
      right: 0;
      width: 100%;
      height: 4px;
      background: var(--gradient);
      animation: slideRight 3s infinite linear;
    }

    @keyframes slideRight {
      0% {
        transform: translateX(-100%);
      }
      100% {
        transform: translateX(100%);
      }
    }
    
    .results-header h2 {
      font-size: 1.8rem;
      margin-bottom: 15px;
      color: #ffffff;
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 15px;
    }

    .results-header h2 i {
      color: var(--success-color);
      animation: pulse 2s infinite;
    }

    @keyframes pulse {
      0%, 100% {
        transform: scale(1);
      }
      50% {
        transform: scale(1.2);
      }
    }
    
    .phone-number-container {
      display: inline-flex;
      align-items: center;
      gap: 15px;
      background: rgba(106, 17, 203, 0.2);
      padding: 15px 25px;
      border-radius: var(--border-radius);
      border: 1px solid rgba(106, 17, 203, 0.3);
      margin-top: 15px;
    }
    
    .phone-number {
      font-weight: bold;
      color: #ffffff;
      direction: ltr;
      font-family: 'Courier New', monospace;
      font-size: 1.2rem;
      letter-spacing: 1px;
      background: var(--gradient);
      padding: 8px 15px;
      border-radius: 8px;
      box-shadow: 0 4px 8px rgba(0, 0, 0, 0.2);
    }
    
    .phone-label {
      color: rgba(255, 255, 255, 0.9);
      font-size: 1.1rem;
    }

    .result-count {
      background: var(--gradient-success);
      color: white;
      padding: 8px 20px;
      border-radius: 30px;
      font-weight: 600;
      font-size: 1.1rem;
      box-shadow: 0 4px 10px rgba(0, 176, 155, 0.3);
      animation: fadeIn 1s ease-out 0.9s both;
    }
    
    .table-container {
      background: rgba(15, 52, 96, 0.6);
      border-radius: var(--border-radius);
      padding: 20px;
      border: 1px solid rgba(255, 255, 255, 0.1);
      margin-bottom: 40px;
      animation: fadeIn 1s ease-out 1.1s both;
    }
    
    .table-responsive {
      overflow-x: auto;
      border-radius: 12px;
    }
    
    table {
      width: 100%;
      border-collapse: collapse;
      border-radius: 12px;
      overflow: hidden;
    }
    
    thead {
      background: var(--gradient);
    }
    
    th {
      padding: 20px;
      text-align: right;
      color: white;
      font-weight: 700;
      font-size: 1.1rem;
      position: relative;
      overflow: hidden;
    }

    th::after {
      content: '';
      position: absolute;
      bottom: 0;
      right: 0;
      width: 100%;
      height: 2px;
      background: rgba(255, 255, 255, 0.3);
    }
    
    tbody tr {
      background: rgba(255, 255, 255, 0.05);
      transition: var(--transition);
      animation: slideIn 0.5s ease-out forwards;
      opacity: 0;
    }

    @keyframes slideIn {
      from {
        opacity: 0;
        transform: translateX(50px);
      }
      to {
        opacity: 1;
        transform: translateX(0);
      }
    }

    tbody tr:nth-child(1) { animation-delay: 0.1s; }
    tbody tr:nth-child(2) { animation-delay: 0.2s; }
    tbody tr:nth-child(3) { animation-delay: 0.3s; }
    tbody tr:nth-child(4) { animation-delay: 0.4s; }
    tbody tr:nth-child(5) { animation-delay: 0.5s; }
    
    td {
      padding: 20px;
      text-align: right;
      border-bottom: 1px solid rgba(255, 255, 255, 0.1);
      color: #ffffff;
      font-size: 1.05rem;
    }
    
    tr:hover {
      background: rgba(255, 255, 255, 0.1);
      transform: translateY(-2px);
      box-shadow: 0 5px 15px rgba(0, 0, 0, 0.2);
    }
    
    .action-buttons {
      display: flex;
      gap: 12px;
    }
    
    .btn {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      padding: 12px 25px;
      border-radius: var(--border-radius);
      font-weight: 700;
      text-decoration: none;
      transition: var(--transition);
      font-size: 1rem;
      border: none;
      cursor: pointer;
      gap: 10px;
      position: relative;
      overflow: hidden;
      min-width: 130px;
    }

    .btn::before {
      content: '';
      position: absolute;
      top: 0;
      left: -100%;
      width: 100%;
      height: 100%;
      background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.2), transparent);
      transition: 0.5s;
    }

    .btn:hover::before {
      left: 100%;
    }
    
    .btn-download {
      background: var(--gradient);
      color: white;
      box-shadow: 0 4px 10px rgba(106, 17, 203, 0.3);
    }
    
    .btn-download:hover {
      transform: translateY(-3px);
      box-shadow: 0 8px 20px rgba(106, 17, 203, 0.4);
      background: linear-gradient(135deg, #2575fc, #6a11cb);
    }
    
    .btn-view {
      background: var(--gradient-success);
      color: white;
      box-shadow: 0 4px 10px rgba(0, 176, 155, 0.3);
    }
    
    .btn-view:hover {
      transform: translateY(-3px);
      box-shadow: 0 8px 20px rgba(0, 176, 155, 0.4);
      background: linear-gradient(135deg, #96c93d, #00b09b);
    }
    
    .btn i {
      font-size: 1.1rem;
      transition: var(--transition);
    }

    .btn:hover i {
      transform: translateY(-2px);
    }
    
    .no-results {
      text-align: center;
      padding: 80px 30px;
      background: rgba(15, 52, 96, 0.6);
      border-radius: var(--border-radius);
      margin: 30px 0;
      border: 1px solid rgba(255, 255, 255, 0.1);
      animation: fadeIn 1s ease-out 1.3s both;
      position: relative;
      overflow: hidden;
    }

    .no-results::before {
      content: '';
      position: absolute;
      top: 0;
      right: 0;
      width: 100%;
      height: 4px;
      background: var(--gradient-danger);
      animation: slideRight 3s infinite linear;
    }
    
    .no-results-icon {
      font-size: 5rem;
      margin-bottom: 25px;
      display: inline-block;
      animation: floatIcon 3s infinite ease-in-out;
    }

    @keyframes floatIcon {
      0%, 100% {
        transform: translateY(0) rotate(0deg);
      }
      50% {
        transform: translateY(-20px) rotate(10deg);
      }
    }
    
    .no-results h3 {
      color: #ffffff;
      margin-bottom: 20px;
      font-size: 2rem;
      background: var(--gradient-danger);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }
    
    .no-results p {
      color: rgba(255, 255, 255, 0.8);
      margin-bottom: 20px;
      font-size: 1.1rem;
      max-width: 600px;
      margin-left: auto;
      margin-right: auto;
    }
    
    .search-again {
      display: inline-flex;
      align-items: center;
      gap: 12px;
      padding: 16px 35px;
      background: var(--gradient);
      color: white;
      text-decoration: none;
      border-radius: var(--border-radius);
      font-weight: 700;
      transition: var(--transition);
      border: none;
      cursor: pointer;
      font-size: 1.1rem;
      box-shadow: 0 6px 15px rgba(106, 17, 203, 0.3);
      margin-top: 20px;
    }
    
    .search-again:hover {
      transform: translateY(-3px);
      box-shadow: 0 10px 25px rgba(106, 17, 203, 0.4);
      background: linear-gradient(135deg, #2575fc, #6a11cb);
    }

    .search-again i {
      transition: var(--transition);
    }

    .search-again:hover i {
      transform: translateX(5px);
    }
    
    footer {
      text-align: center;
      margin-top: 40px;
      color: rgba(255, 255, 255, 0.7);
      font-size: 0.9rem;
      padding: 25px;
      background: rgba(0, 0, 0, 0.3);
      border-top: 1px solid rgba(255, 255, 255, 0.1);
      animation: fadeIn 1s ease-out 1.5s both;
    }

    footer p {
      margin-bottom: 10px;
    }

    .footer-contact {
      color: rgba(255, 255, 255, 0.6);
      font-size: 0.85rem;
    }
    
    @media (max-width: 768px) {
      th, td {
        padding: 15px 12px;
      }
      
      .btn {
        padding: 10px 20px;
        font-size: 0.9rem;
        min-width: 110px;
      }
      
      header h1 {
        font-size: 1.8rem;
      }
      
      .back-btn {
        position: relative;
        top: auto;
        right: auto;
        margin: 0 auto 20px;
        display: inline-flex;
        justify-content: center;
        width: auto;
      }

      .results-header h2 {
        flex-direction: column;
        gap: 10px;
      }

      .phone-number-container {
        flex-direction: column;
        gap: 10px;
        text-align: center;
      }

      .action-buttons {
        flex-direction: column;
      }
    }
    
    @media (max-width: 576px) {
      .action-buttons {
        flex-direction: column;
        gap: 8px;
      }
      
      .btn {
        width: 100%;
        justify-content: center;
      }

      .container {
        padding: 10px;
      }

      header, main {
        padding: 20px 15px;
      }
    }

    /* تأثير البيكسل المتحرك */
    .pixel {
      position: fixed;
      width: 4px;
      height: 4px;
      background: var(--gradient);
      pointer-events: none;
      z-index: 1000;
      opacity: 0;
    }

    @keyframes pixel-fall {
      0% {
        opacity: 1;
        transform: translateY(-100px) rotate(0deg);
      }
      100% {
        opacity: 0;
        transform: translateY(100vh) rotate(720deg);
      }
    }
  </style>
</head>
<body>
  <!-- خلفية متحركة -->
  <div class="background-animation">
    <div class="circle"></div>
    <div class="circle"></div>
    <div class="circle"></div>
    <div class="ripple"></div>
    <div class="ripple"></div>
  </div>

  <!-- النجوم -->
  <div class="stars">
    <div class="star"></div>
    <div class="star"></div>
    <div class="star"></div>
    <div class="star"></div>
    <div class="star"></div>
    <div class="star"></div>
    <div class="star"></div>
  </div>

  <div class="container">
    <header>
      <a href="/" class="back-btn">
        <i class="fas fa-arrow-right"></i> العودة للبحث
      </a>
      <h1>نتائج التحاليل الطبية</h1>
    </header>

    <main>
      <div class="results-header">
        <h2><i class="fas fa-file-medical-alt"></i> نتائج التحاليل</h2>
        <p style="color: rgba(255, 255, 255, 0.9); margin-bottom: 20px; font-size: 1.1rem;">يمكنك الاطلاع على نتائج تحاليلك وتحميلها بسهولة</p>
        
        <div class="phone-number-container">
          <span class="phone-label">رقم الهاتف:</span>
          <span class="phone-number"><%= phoneNumber || "غير محدد" %></span>
        </div>
        
        <% if (Array.isArray(result) && result.length > 0) { %>
          <div class="result-count" style="margin-top: 20px;">
            <i class="fas fa-check-circle"></i> تم العثور على <%= result.length %> نتيجة
          </div>
        <% } %>
      </div>
      
      <% if (Array.isArray(result) && result.length > 0) { %>
        <div class="table-container">
          <div class="table-responsive">
            <table>
              <thead>
                <tr>
                  <th>اسم المريض</th>
                  <th>رقم الهاتف</th>
                  <th>الإجراءات</th>
                </tr>
              </thead>
              <tbody>
                <% result.forEach((r, index) => { %>
                  <tr>
                    <td><%= r.name %></td>
                    <td><%= r.phone %></td>
                    <td>
                      <div class="action-buttons">
                        <a href="/download/<%= r.file %>" class="btn btn-download" onclick="createPixels(event)">
                          <i class="fas fa-download"></i> تحميل
                        </a>
                        <a href="/view/<%= r.file %>" target="_blank" class="btn btn-view" onclick="createPixels(event)">
                          <i class="fas fa-eye"></i> عرض
                        </a>
                      </div>
                    </td>
                  </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
        </div>
      <% } else { %>
        <div class="no-results">
          <div class="no-results-icon">🔍</div>
          <h3>لا توجد نتائج متاحة</h3>
          <p>لم يتم العثور على نتائج للرقم المدخل</p>
          <p>يرجى التأكد من صحة الرقم أو التواصل مع المركز الطبي للحصول على المساعدة</p>
          <a href="/" class="search-again" onclick="createPixels(event)">
            <i class="fas fa-redo"></i> البحث مرة أخرى
          </a>
        </div>
      <% } %>
    </main>
    
    <footer>
      <p>© 2025 معمل التحاليل (جون). جميع الحقوق محفوظة.</p>
    </footer>
  </div>

  <script>
    // إنشاء تأثير البيكسل المتحرك عند النقر
    function createPixels(event) {
      const colors = ['#6a11cb', '#2575fc', '#ff512f', '#00b09b'];
      const buttonRect = event.currentTarget.getBoundingClientRect();
      
      for (let i = 0; i < 25; i++) {
        const pixel = document.createElement('div');
        pixel.className = 'pixel';
        
        // حجم عشوائي
        const size = Math.random() * 6 + 3;
        pixel.style.width = `${size}px`;
        pixel.style.height = `${size}px`;
        
        // لون عشوائي
        const color = colors[Math.floor(Math.random() * colors.length)];
        pixel.style.backgroundColor = color;
        
        // موقع بداية من الزر
        const startX = buttonRect.left + Math.random() * buttonRect.width;
        const startY = buttonRect.top + Math.random() * buttonRect.height;
        
        pixel.style.left = `${startX}px`;
        pixel.style.top = `${startY}px`;
        
        // مدة وسرعة عشوائية
        const duration = Math.random() * 2 + 1;
        const delay = Math.random() * 0.3;
        
        pixel.style.animation = `pixel-fall ${duration}s ease-in ${delay}s forwards`;
        
        document.body.appendChild(pixel);
        
        // إزالة العنصر بعد انتهاء الأنيميشن
        setTimeout(() => pixel.remove(), (duration + delay) * 1000);
      }
    }

    // تأثير عند تحميل الصفحة
    document.addEventListener('DOMContentLoaded', function() {
      // إضافة تأثير تدريجي للصفوف
      const rows = document.querySelectorAll('tbody tr');
      rows.forEach((row, index) => {
        row.style.animationDelay = `${index * 0.1}s`;
      });

      // تأثير للنص الديناميكي
      const phoneNumber = document.querySelector('.phone-number');
      if (phoneNumber && phoneNumber.textContent !== 'غير محدد') {
        phoneNumber.style.animation = 'pulse 2s infinite';
      }
    });

    // تأثير للزر العودة
    const backBtn = document.querySelector('.back-btn');
    backBtn.addEventListener('mouseenter', function() {
      createPixels({currentTarget: this});
    });
  </script>
</body>
</html>
