<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<title>نتائج التحاليل</title>

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

<style>
:root{
  --bg:#0b0f1a;
  --card:#12182b;
  --glass:rgba(255,255,255,0.05);
  --primary:#00d4ff;
  --secondary:#4facfe;
  --success:#00ffa3;
  --text:#e6e9f0;
  --muted:#9aa3b2;
  --radius:14px;
}

/* GLOBAL */
*{margin:0;padding:0;box-sizing:border-box;font-family:'Cairo',sans-serif;}

body{
  background: radial-gradient(circle at top,#11182c,#05070f);
  color:var(--text);
}

/* CONTAINER */
.container{
  max-width:1100px;
  margin:auto;
  padding:20px;
}

/* HEADER */
.header{
  display:flex;
  justify-content:space-between;
  align-items:center;
  padding:20px;
  border-radius:var(--radius);
  background:linear-gradient(135deg,#0f2027,#203a43,#2c5364);
  box-shadow:0 10px 40px rgba(0,0,0,0.5);
}

.header h1{
  font-size:1.6rem;
}

.back{
  background:var(--glass);
  padding:10px 15px;
  border-radius:10px;
  text-decoration:none;
  color:white;
  transition:.3s;
}
.back:hover{
  background:var(--primary);
  color:black;
}

/* CARD */
.card{
  background:var(--card);
  border-radius:var(--radius);
  padding:25px;
  margin-top:20px;
  box-shadow:0 10px 30px rgba(0,0,0,0.4);
  border:1px solid rgba(255,255,255,0.05);
}

/* TITLE */
.card h2{
  margin-bottom:15px;
  color:var(--primary);
}

/* INFO GRID */
.info{
  display:grid;
  grid-template-columns:repeat(auto-fit,minmax(200px,1fr));
  gap:15px;
}

.box{
  background:var(--glass);
  padding:15px;
  border-radius:10px;
  backdrop-filter:blur(10px);
}

.box span{
  font-size:.8rem;
  color:var(--muted);
}

.box strong{
  display:block;
  margin-top:5px;
  font-size:1.1rem;
}

/* NOTES */
.notes{
  margin-top:20px;
  background:rgba(0,255,163,0.08);
  border-left:4px solid var(--success);
  padding:15px;
  border-radius:10px;
}

/* TABLE */
table{
  width:100%;
  border-collapse:collapse;
  margin-top:20px;
}

th{
  background:linear-gradient(135deg,#00d4ff,#4facfe);
  color:black;
  padding:12px;
}

td{
  padding:12px;
  border-bottom:1px solid rgba(255,255,255,0.05);
}

tr:hover{
  background:rgba(255,255,255,0.05);
}

/* BUTTONS */
.actions{
  display:flex;
  gap:10px;
  flex-wrap:wrap;
}

.btn{
  padding:8px 14px;
  border-radius:8px;
  text-decoration:none;
  font-size:.9rem;
  font-weight:bold;
  transition:.3s;
}

.download{
  background:var(--primary);
  color:black;
}

.view{
  background:var(--success);
  color:black;
}

.btn:hover{
  transform:scale(1.05);
}

/* NO RESULT */
.no{
  text-align:center;
  padding:50px;
  background:var(--card);
  border-radius:var(--radius);
}

.retry{
  display:inline-block;
  margin-top:15px;
  background:var(--primary);
  color:black;
  padding:10px 20px;
  border-radius:8px;
  text-decoration:none;
}

/* MOBILE */
@media(max-width:600px){
  .header{
    flex-direction:column;
    gap:10px;
    text-align:center;
  }
}

</style>
</head>

<body>

<div class="container">

<div class="header">
  <h1>🧪 نتائج التحاليل</h1>
  <a href="/" class="back">رجوع</a>
</div>

<% if (Array.isArray(result) && result.length > 0) { 
  const patient = result[0];
%>

<div class="card">
  <h2>👤 بيانات المريض</h2>

  <div class="info">
    <div class="box">
      <span>الاسم</span>
      <strong><%= patient.name %></strong>
    </div>

    <div class="box">
      <span>رقم الهاتف</span>
      <strong><%= phoneNumber %></strong>
    </div>

    <% if (patient.test) { %>
    <div class="box">
      <span>نوع التحليل</span>
      <strong><%= patient.test %></strong>
    </div>
    <% } %>

    <% if (patient.date) { %>
    <div class="box">
      <span>التاريخ</span>
      <strong><%= patient.date %></strong>
    </div>
    <% } %>
  </div>

  <div class="notes">
    <strong>ملاحظات:</strong><br>
    <%= patient.notes || "لا توجد ملاحظات" %>
  </div>
</div>

<div class="card">
  <h2>📊 النتائج</h2>

  <table>
    <thead>
      <tr>
        <th>الاسم</th>
        <th>الهاتف</th>
        <th>الإجراءات</th>
      </tr>
    </thead>

    <tbody>
      <% result.forEach(r => { %>
      <tr>
        <td><%= r.name %></td>
        <td><%= r.phone %></td>
        <td>
          <div class="actions">
            <a href="/download/<%= r.file %>" class="btn download">تحميل</a>
            <a href="/view/<%= r.file %>" target="_blank" class="btn view">عرض</a>
          </div>
        </td>
      </tr>
      <% }) %>
    </tbody>
  </table>
</div>

<% } else { %>

<div class="no">
  <h2>❌ لا توجد نتائج</h2>
  <p>تأكد من الرقم</p>
  <a href="/" class="retry">إعادة البحث</a>
</div>

<% } %>

</div>

</body>
</html>
