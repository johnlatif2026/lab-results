<!-- Floating WhatsApp Button -->
<style>
  /* WhatsApp Button Styles - Light Mode */
  :root {
    --whatsapp-color: #25D366;
    --whatsapp-hover: #20b859;
    --whatsapp-shadow: rgba(0, 0, 0, 0.15);
  }
  
  [data-theme="dark"] {
    --whatsapp-shadow: rgba(0, 0, 0, 0.3);
  }
  
  .whatsapp-float {
    position: fixed;
    bottom: 30px;
    left: 30px;
    z-index: 1000;
    animation: fadeInUp 0.3s ease;
  }
  
  /* For RTL, button stays on left side */
  .whatsapp-button {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 60px;
    height: 60px;
    background-color: var(--whatsapp-color);
    border-radius: 50%;
    box-shadow: 0 4px 12px var(--whatsapp-shadow);
    transition: all 0.3s ease;
    cursor: pointer;
    text-decoration: none;
    color: white;
  }
  
  .whatsapp-button:hover {
    transform: translateY(-3px);
    background-color: var(--whatsapp-hover);
    box-shadow: 0 6px 16px var(--whatsapp-shadow);
  }
  
  .whatsapp-button:active {
    transform: translateY(0);
  }
  
  .whatsapp-button i {
    font-size: 32px;
  }
  
  /* Tooltip */
  .whatsapp-tooltip {
    position: absolute;
    bottom: 70px;
    left: 50%;
    transform: translateX(-50%);
    background: var(--bg-card);
    color: var(--text-primary);
    padding: 8px 12px;
    border-radius: 12px;
    font-size: 0.75rem;
    white-space: nowrap;
    box-shadow: var(--shadow-sm);
    border: 1px solid var(--border-color);
    pointer-events: none;
    opacity: 0;
    transition: opacity 0.2s;
    font-weight: 500;
  }
  
  .whatsapp-float:hover .whatsapp-tooltip {
    opacity: 1;
  }
  
  /* Mobile adjustments */
  @media (max-width: 768px) {
    .whatsapp-float {
      bottom: 20px;
      left: 20px;
    }
    
    .whatsapp-button {
      width: 50px;
      height: 50px;
    }
    
    .whatsapp-button i {
      font-size: 26px;
    }
    
    .whatsapp-tooltip {
      display: none;
    }
  }
  
  @keyframes fadeInUp {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>

<%
  // Single source of truth for WhatsApp number
  // Replace with your actual number (include country code without '+')
  const WHATSAPP_NUMBER = "201274445091";
  const whatsappUrl = `https://wa.me/${WHATSAPP_NUMBER}`;
%>

<div class="whatsapp-float">
  <a href="<%= whatsappUrl %>" 
     class="whatsapp-button" 
     target="_blank" 
     rel="noopener noreferrer"
     aria-label="تواصل عبر واتساب">
    <i class="fab fa-whatsapp"></i>
  </a>
  <div class="whatsapp-tooltip">
    <i class="fab fa-whatsapp"></i> تواصل معنا
  </div>
</div>
