<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>لوحة تحكم المسؤول | تسجيل الدخول</title>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  <style>
    :root {
      --primary-color: #6a11cb;
      --secondary-color: #2575fc;
      --accent-color: #ff512f;
      --success-color: #00b09b;
      --border-radius: 20px;
      --box-shadow: 0 15px 35px rgba(0, 0, 0, 0.5);
      --transition: all 0.5s cubic-bezier(0.4, 0, 0.2, 1);
      --gradient: linear-gradient(135deg, var(--primary-color), var(--secondary-color));
      --gradient-success: linear-gradient(135deg, #00b09b, #96c93d);
      --gradient-danger: linear-gradient(135deg, #ff512f, #dd2476);
    }
    
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
      font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
    }
    
    body {
      background: linear-gradient(135deg, #0f0c29 0%, #302b63 50%, #24243e 100%);
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 20px;
      color: #ffffff;
      position: relative;
      overflow: hidden;
    }

    /* خلفية متحركة */
    .background-animation {
      position: fixed;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      z-index: -2;
      overflow: hidden;
    }

    .floating-shape {
      position: absolute;
      border-radius: 50%;
      animation: float 25s infinite ease-in-out;
      filter: blur(40px);
      opacity: 0.1;
    }

    .floating-shape:nth-child(1) {
      width: 500px;
      height: 500px;
      top: -250px;
      right: -250px;
      animation-delay: 0s;
      background: var(--gradient);
    }

    .floating-shape:nth-child(2) {
      width: 400px;
      height: 400px;
      bottom: -200px;
      left: -200px;
      animation-delay: 8s;
      background: var(--gradient-success);
    }

    .floating-shape:nth-child(3) {
      width: 300px;
      height: 300px;
      top: 50%;
      left: 15%;
      animation-delay: 15s;
      background: var(--gradient-danger);
    }

    @keyframes float {
      0%, 100% {
        transform: translate(0, 0) rotate(0deg) scale(1);
      }
      25% {
        transform: translate(40px, -40px) rotate(90deg) scale(1.1);
      }
      50% {
        transform: translate(-40px, 40px) rotate(180deg) scale(0.9);
      }
      75% {
        transform: translate(20px, -20px) rotate(270deg) scale(1.05);
      }
    }
    
    /* موجات خلفية */
    .wave {
      position: fixed;
      border-radius: 50%;
      background: rgba(255, 255, 255, 0.02);
      animation: wave 12s infinite ease-in-out;
      z-index: -1;
    }

    .wave:nth-child(4) {
      width: 700px;
      height: 700px;
      top: -350px;
      right: -350px;
      animation-delay: 0s;
    }

    .wave:nth-child(5) {
      width: 600px;
      height: 600px;
      bottom: -300px;
      left: -300px;
      animation-delay: 4s;
    }

    @keyframes wave {
      0%, 100% {
        transform: scale(1);
        opacity: 0.02;
      }
      50% {
        transform: scale(1.2);
        opacity: 0.01;
      }
    }

    /* نجوم متلألئة */
    .stars {
      position: fixed;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      pointer-events: none;
      z-index: -1;
    }

    .star {
      position: absolute;
      background: white;
      border-radius: 50%;
      animation: twinkle 4s infinite ease-in-out;
    }

    .star:nth-child(1) { top: 20%; left: 10%; width: 3px; height: 3px; animation-delay: 0s; }
    .star:nth-child(2) { top: 40%; left: 85%; width: 2px; height: 2px; animation-delay: 1s; }
    .star:nth-child(3) { top: 60%; left: 20%; width: 3px; height: 3px; animation-delay: 2s; }
    .star:nth-child(4) { top: 80%; left: 70%; width: 2px; height: 2px; animation-delay: 0.5s; }

    @keyframes twinkle {
      0%, 100% { opacity: 0.2; transform: scale(1); }
      50% { opacity: 1; transform: scale(1.5); }
    }
    
    .login-container {
      width: 100%;
      max-width: 500px;
      background: rgba(22, 33, 62, 0.9);
      border-radius: var(--border-radius);
      box-shadow: var(--box-shadow);
      overflow: hidden;
      position: relative;
      z-index: 1;
      animation: slideUp 1s ease-out;
      border: 1px solid rgba(255, 255, 255, 0.15);
      backdrop-filter: blur(15px);
    }

    @keyframes slideUp {
      from {
        opacity: 0;
        transform: translateY(60px) scale(0.9);
      }
      to {
        opacity: 1;
        transform: translateY(0) scale(1);
      }
    }
    
    .login-header {
      background: linear-gradient(135deg, rgba(106, 17, 203, 0.9), rgba(37, 117, 252, 0.9));
      color: white;
      padding: 50px 30px;
      text-align: center;
      border-bottom: 1px solid rgba(255, 255, 255, 0.15);
      position: relative;
      overflow: hidden;
    }

    .login-header::before {
      content: '';
      position: absolute;
      top: 0;
      right: 0;
      width: 100%;
      height: 100%;
      background: url('data:image/svg+xml;utf8,<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 100 100" preserveAspectRatio="none"><path d="M0,0 L100,0 L100,100 Z" fill="rgba(255,255,255,0.1)"/></svg>');
      background-size: cover;
      pointer-events: none;
    }

    .login-header::after {
      content: '';
      position: absolute;
      top: 0;
      right: 0;
      width: 100%;
      height: 4px;
      background: var(--gradient-success);
      animation: slideRight 3s infinite linear;
    }

    @keyframes slideRight {
      0% {
        transform: translateX(-100%);
      }
      100% {
        transform: translateX(100%);
      }
    }
    
    .login-header h1 {
      font-size: 2.5rem;
      margin-bottom: 15px;
      font-weight: 800;
      text-shadow: 0 2px 10px rgba(0, 0, 0, 0.3);
      background: linear-gradient(135deg, #ffffff, #e6e6e6);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
      animation: fadeIn 1s ease-out 0.3s both;
    }
    
    @keyframes fadeIn {
      from { opacity: 0; transform: translateY(-20px); }
      to { opacity: 1; transform: translateY(0); }
    }
    
    .login-header p {
      font-size: 1.2rem;
      opacity: 0.9;
      animation: fadeIn 1s ease-out 0.5s both;
    }
    
    .login-form {
      padding: 50px 35px;
      background: rgba(26, 26, 46, 0.8);
      animation: fadeIn 1s ease-out 0.7s both;
    }
    
    .form-group {
      margin-bottom: 30px;
      animation: fadeIn 1s ease-out 0.9s both;
    }
    
    .form-group label {
      display: block;
      margin-bottom: 12px;
      font-weight: 600;
      color: #ffffff;
      font-size: 1.1rem;
      display: flex;
      align-items: center;
      gap: 10px;
    }

    .form-group label i {
      color: var(--secondary-color);
      font-size: 1.2rem;
    }
    
    .input-with-icon {
      position: relative;
    }
    
    .input-with-icon i {
      position: absolute;
      top: 50%;
      right: 20px;
      transform: translateY(-50%);
      color: rgba(255, 255, 255, 0.6);
      transition: var(--transition);
      font-size: 1.2rem;
    }
    
    .input-with-icon input {
      padding-right: 60px;
    }
    
    .form-group input {
      width: 100%;
      padding: 20px;
      border: 2px solid rgba(255, 255, 255, 0.2);
      border-radius: var(--border-radius);
      font-size: 1.1rem;
      transition: var(--transition);
      background: rgba(15, 52, 96, 0.6);
      color: #ffffff;
      letter-spacing: 1px;
    }
    
    .form-group input::placeholder {
      color: rgba(255, 255, 255, 0.5);
      letter-spacing: normal;
    }
    
    .form-group input:focus {
      border-color: var(--primary-color);
      outline: none;
      box-shadow: 0 0 0 5px rgba(106, 17, 203, 0.3);
      background: rgba(22, 33, 62, 0.8);
      transform: translateY(-3px);
    }

    .form-group input:focus + i {
      color: var(--primary-color);
      transform: translateY(-50%) scale(1.2);
      animation: bounce 0.5s ease;
    }

    @keyframes bounce {
      0%, 100% { transform: translateY(-50%) scale(1); }
      50% { transform: translateY(-50%) scale(1.3); }
    }
    
    .login-btn {
      background: var(--gradient);
      color: white;
      border: none;
      padding: 22px;
      border-radius: var(--border-radius);
      font-size: 1.3rem;
      font-weight: 700;
      cursor: pointer;
      transition: var(--transition);
      width: 100%;
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 15px;
      box-shadow: 0 8px 20px rgba(106, 17, 203, 0.4);
      margin-top: 20px;
      position: relative;
      overflow: hidden;
      animation: fadeIn 1s ease-out 1.1s both;
    }

    .login-btn::before {
      content: '';
      position: absolute;
      top: 0;
      left: -100%;
      width: 100%;
      height: 100%;
      background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.2), transparent);
      transition: 0.6s;
    }

    .login-btn:hover::before {
      left: 100%;
    }
    
    .login-btn:hover {
      transform: translateY(-5px);
      box-shadow: 0 15px 30px rgba(106, 17, 203, 0.5);
      background: linear-gradient(135deg, #2575fc, #6a11cb);
    }

    .login-btn:active {
      transform: translateY(-2px);
    }

    .login-btn i {
      transition: var(--transition);
      font-size: 1.4rem;
    }

    .login-btn:hover i {
      transform: translateX(8px);
    }

    .pulse {
      animation: pulse 2s infinite;
    }
    
    @keyframes pulse {
      0%, 100% {
        transform: scale(1);
        box-shadow: 0 8px 20px rgba(106, 17, 203, 0.4);
      }
      50% {
        transform: scale(1.03);
        box-shadow: 0 12px 25px rgba(106, 17, 203, 0.5);
      }
    }
    
    .login-footer {
      text-align: center;
      margin-top: 30px;
      color: rgba(255, 255, 255, 0.6);
      font-size: 0.95rem;
      padding: 25px;
      border-top: 1px solid rgba(255, 255, 255, 0.1);
      background: rgba(22, 33, 62, 0.8);
      animation: fadeIn 1s ease-out 1.3s both;
    }

    .login-footer p {
      margin-bottom: 10px;
    }

    .footer-note {
      color: rgba(255, 255, 255, 0.5);
      font-size: 0.85rem;
      margin-top: 10px;
    }
    
    /* تأثير الجسيمات */
    .particle {
      position: fixed;
      width: 4px;
      height: 4px;
      background: var(--gradient);
      pointer-events: none;
      z-index: 1000;
      opacity: 0;
      border-radius: 50%;
    }

    @keyframes particle-explode {
      0% {
        opacity: 1;
        transform: translate(0, 0) scale(1);
      }
      100% {
        opacity: 0;
        transform: translate(var(--tx), var(--ty)) scale(0);
      }
    }
    
    @media (max-width: 576px) {
      .login-header h1 {
        font-size: 2rem;
      }

      .login-header {
        padding: 40px 25px;
      }

      .login-form {
        padding: 40px 25px;
      }

      .form-group input {
        padding: 18px;
      }

      .login-btn {
        padding: 20px;
        font-size: 1.2rem;
      }
    }

    /* تأثير الخطوط المتحركة */
    .scan-line {
      position: absolute;
      top: 0;
      right: 0;
      width: 100%;
      height: 2px;
      background: linear-gradient(90deg, transparent, var(--success-color), transparent);
      animation: scan 3s infinite linear;
      z-index: 2;
    }

    @keyframes scan {
      0% {
        top: 0;
        opacity: 0;
      }
      10% {
        opacity: 1;
      }
      90% {
        opacity: 1;
      }
      100% {
        top: 100%;
        opacity: 0;
      }
    }
  </style>
</head>
<body>
  <!-- خلفية متحركة -->
  <div class="background-animation">
    <div class="floating-shape"></div>
    <div class="floating-shape"></div>
    <div class="floating-shape"></div>
    <div class="wave"></div>
    <div class="wave"></div>
  </div>

  <!-- النجوم -->
  <div class="stars">
    <div class="star"></div>
    <div class="star"></div>
    <div class="star"></div>
    <div class="star"></div>
  </div>

  <!-- خط المسح -->
  <div class="scan-line"></div>

  <div class="login-container">
    <div class="login-header">
      <h1><i class="fas fa-shield-alt"></i> لوحة تحكم المسؤول</h1>
      <p>إدارة نظام نتائج التحاليل الطبية</p>
    </div>
    
    <form class="login-form" method="POST" action="/admin/login" id="loginForm">
      <div class="form-group">
        <label for="username"><i class="fas fa-user-cog"></i> اسم المستخدم</label>
        <div class="input-with-icon">
          <input type="text" id="username" name="username" placeholder="أدخل اسم المستخدم المسؤول" required autofocus>
          <i class="fas fa-user-tie"></i>
        </div>
      </div>
      
      <div class="form-group">
        <label for="password"><i class="fas fa-key"></i> كلمة المرور</label>
        <div class="input-with-icon">
          <input type="password" id="password" name="password" placeholder="أدخل كلمة المرور الخاصة بك" required>
          <i class="fas fa-lock"></i>
        </div>
      </div>
      
      <button type="submit" class="login-btn pulse" id="loginBtn">
        <i class="fas fa-sign-in-alt"></i> تسجيل الدخول
      </button>
    </form>
    
    <div class="login-footer">
      <p>© 2025 نظام إدارة معمل التحاليل الطبية</p>
      <p class="footer-note">جميع الحقوق محفوظة | النسخة 2.0</p>
    </div>
  </div>

  <script>
    // تأثير الجسيمات عند النقر
    function createParticles(event) {
      const colors = ['#6a11cb', '#2575fc', '#ff512f', '#00b09b'];
      const buttonRect = event.currentTarget.getBoundingClientRect();
      const centerX = buttonRect.left + buttonRect.width / 2;
      const centerY = buttonRect.top + buttonRect.height / 2;
      
      for (let i = 0; i < 30; i++) {
        const particle = document.createElement('div');
        particle.className = 'particle';
        
        // حجم عشوائي
        const size = Math.random() * 6 + 2;
        particle.style.width = `${size}px`;
        particle.style.height = `${size}px`;
        
        // لون عشوائي
        const color = colors[Math.floor(Math.random() * colors.length)];
        particle.style.backgroundColor = color;
        
        // موقع البداية من مركز الزر
        particle.style.left = `${centerX}px`;
        particle.style.top = `${centerY}px`;
        
        // حركة عشوائية
        const angle = Math.random() * Math.PI * 2;
        const distance = Math.random() * 100 + 50;
        const tx = Math.cos(angle) * distance;
        const ty = Math.sin(angle) * distance;
        
        const duration = Math.random() * 1.5 + 0.5;
        particle.style.setProperty('--tx', `${tx}px`);
        particle.style.setProperty('--ty', `${ty}px`);
        particle.style.animation = `particle-explode ${duration}s ease-out forwards`;
        
        document.body.appendChild(particle);
        
        // إزالة الجسيم بعد انتهاء الأنيميشن
        setTimeout(() => particle.remove(), duration * 1000);
      }
    }

    // تأثيرات عند تحميل الصفحة
    document.addEventListener('DOMContentLoaded', function() {
      const usernameInput = document.getElementById('username');
      const passwordInput = document.getElementById('password');
      const loginBtn = document.getElementById('loginBtn');
      const loginForm = document.getElementById('loginForm');
      
      // تأثير التركيز التلقائي
      setTimeout(() => {
        usernameInput.focus();
      }, 500);
      
      // تأثير عند إرسال النموذج
      loginForm.addEventListener('submit', function(e) {
        const username = usernameInput.value.trim();
        const password = passwordInput.value.trim();
        
        if (!username || !password) {
          e.preventDefault();
          
          // تأثير اهتزاز للحقول الفارغة
          if (!username) {
            usernameInput.style.animation = 'shake 0.5s';
            usernameInput.style.borderColor = '#ff512f';
          }
          if (!password) {
            passwordInput.style.animation = 'shake 0.5s';
            passwordInput.style.borderColor = '#ff512f';
          }
          
          setTimeout(() => {
            usernameInput.style.animation = '';
            passwordInput.style.animation = '';
            usernameInput.style.borderColor = '';
            passwordInput.style.borderColor = '';
          }, 500);
          
          // إنشاء تأثير اهتزاز
          if (!document.querySelector('#shakeStyle')) {
            const shakeStyle = document.createElement('style');
            shakeStyle.id = 'shakeStyle';
            shakeStyle.textContent = `
              @keyframes shake {
                0%, 100% { transform: translateX(0); }
                10%, 30%, 50%, 70%, 90% { transform: translateX(-10px); }
                20%, 40%, 60%, 80% { transform: translateX(10px); }
              }
            `;
            document.head.appendChild(shakeStyle);
          }
          
          return false;
        }
        
        // تغيير حالة الزر أثناء التحميل
        loginBtn.disabled = true;
        loginBtn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> جاري التحقق...';
        loginBtn.classList.remove('pulse');
        
        // إضافة تأثير الجسيمات
        createParticles({currentTarget: loginBtn});
      });
      
      // تأثير عند المرور على الزر
      loginBtn.addEventListener('mouseenter', function() {
        createParticles({currentTarget: this});
      });
    });
  </script>
</body>
</html>
