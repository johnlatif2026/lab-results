<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
  <title>لوحة التحكم - معمل التحاليل</title>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  <style>
    /* ========================================
       CSS VARIABLES FOR THEMING (IMPROVED)
    ======================================== */
    :root {
      --bg-primary: #f8fafc;
      --bg-card: #ffffff;
      --bg-sidebar: #ffffff;
      --bg-header: #ffffff;
      --bg-hover: #f1f5f9;
      --text-primary: #0f172a;
      --text-secondary: #475569;
      --text-muted: #94a3b8;
      --border-color: #e2e8f0;
      --border-light: #f1f5f9;
      --shadow-sm: 0 1px 3px rgba(0, 0, 0, 0.05), 0 1px 2px rgba(0, 0, 0, 0.03);
      --shadow-md: 0 4px 6px -1px rgba(0, 0, 0, 0.05), 0 2px 4px -1px rgba(0, 0, 0, 0.03);
      --gradient-start: #1e3c72;
      --gradient-end: #2a5298;
      --stat-icon-bg: #eef2ff;
      --table-header-bg: #f8fafc;
      --success-bg: #10b981;
      --danger-bg: #ef4444;
      --telegram-bg: #0088cc;
      --email-bg: #ea4335;
      --warning-bg: #f59e0b;
      --border-radius-card: 24px;
      --border-radius-button: 40px;
      --transition: all 0.2s ease;
    }

    [data-theme="dark"] {
      --bg-primary: #0f172a;
      --bg-card: #1e293b;
      --bg-sidebar: #1e293b;
      --bg-header: #1e293b;
      --bg-hover: #334155;
      --text-primary: #f1f5f9;
      --text-secondary: #cbd5e1;
      --text-muted: #94a3b8;
      --border-color: #334155;
      --border-light: #1e293b;
      --shadow-sm: 0 1px 3px rgba(0, 0, 0, 0.3);
      --shadow-md: 0 4px 6px -1px rgba(0, 0, 0, 0.4);
      --stat-icon-bg: #1e3a5f;
      --table-header-bg: #0f172a;
    }

    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    body {
      font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', 'Tajawal', sans-serif;
      background: var(--bg-primary);
      transition: background-color 0.3s ease;
      color: var(--text-primary);
    }

    /* ========================================
       DASHBOARD LAYOUT
    ======================================== */
    .dashboard-wrapper {
      display: flex;
      min-height: 100vh;
    }

    /* ========================================
       SIDEBAR (DESKTOP)
    ======================================== */
    .sidebar {
      width: 280px;
      background: var(--bg-sidebar);
      border-left: 1px solid var(--border-color);
      position: fixed;
      right: 0;
      top: 0;
      bottom: 0;
      z-index: 100;
      transition: all 0.3s ease;
      overflow-y: auto;
      box-shadow: var(--shadow-sm);
    }

    .sidebar-header {
      padding: 28px 24px;
      border-bottom: 1px solid var(--border-color);
    }

    .sidebar-header h2 {
      font-size: 1.25rem;
      color: var(--text-primary);
      display: flex;
      align-items: center;
      gap: 12px;
    }

    .sidebar-header h2 i {
      color: var(--gradient-end);
      font-size: 1.4rem;
    }

    .sidebar-nav {
      padding: 20px 0;
    }

    .sidebar-item {
      display: flex;
      align-items: center;
      gap: 14px;
      padding: 14px 24px;
      color: var(--text-secondary);
      text-decoration: none;
      transition: var(--transition);
      cursor: pointer;
      border-right: 3px solid transparent;
      margin: 4px 0;
      font-weight: 500;
    }

    .sidebar-item:hover {
      background: var(--bg-hover);
      color: var(--text-primary);
    }

    .sidebar-item.active {
      background: linear-gradient(90deg, transparent, rgba(42, 82, 152, 0.08));
      border-right-color: var(--gradient-end);
      color: var(--gradient-end);
    }

    .sidebar-item i {
      width: 24px;
      font-size: 1.2rem;
    }

    .sidebar-footer {
      padding: 24px;
      border-top: 1px solid var(--border-color);
      margin-top: 40px;
    }

    .logout-sidebar {
      display: flex;
      align-items: center;
      gap: 12px;
      color: var(--danger-bg);
      text-decoration: none;
      padding: 10px;
      border-radius: 12px;
      transition: var(--transition);
      cursor: pointer;
    }

    .logout-sidebar:hover {
      background: rgba(239, 68, 68, 0.1);
    }

    /* ========================================
       MAIN CONTENT
    ======================================== */
    .main-content {
      flex: 1;
      margin-right: 280px;
      padding: 24px 32px;
      transition: all 0.3s ease;
    }

    /* Header Bar */
    .header-bar {
      background: var(--bg-header);
      border-radius: var(--border-radius-card);
      padding: 16px 28px;
      margin-bottom: 28px;
      display: flex;
      flex-wrap: wrap;
      justify-content: space-between;
      align-items: center;
      gap: 15px;
      box-shadow: var(--shadow-sm);
      backdrop-filter: blur(2px);
    }

    .logo h1 {
      font-size: 1.35rem;
      color: var(--text-primary);
      display: flex;
      align-items: center;
      gap: 12px;
    }

    .logo i {
      color: var(--gradient-end);
    }

    .header-actions {
      display: flex;
      align-items: center;
      gap: 20px;
    }

    .theme-toggle {
      background: var(--bg-card);
      border: 1px solid var(--border-color);
      border-radius: var(--border-radius-button);
      padding: 8px 20px;
      cursor: pointer;
      display: flex;
      align-items: center;
      gap: 10px;
      color: var(--text-primary);
      font-size: 0.85rem;
      font-weight: 500;
      transition: var(--transition);
    }

    .theme-toggle:hover {
      transform: translateY(-2px);
      box-shadow: var(--shadow-md);
    }

    .user-info {
      display: flex;
      align-items: center;
      gap: 15px;
    }

    .user-badge {
      background: var(--bg-hover);
      padding: 8px 20px;
      border-radius: var(--border-radius-button);
      font-size: 0.85rem;
      color: var(--text-primary);
      font-weight: 500;
    }

    .logout-link {
      color: var(--danger-bg);
      text-decoration: none;
      display: flex;
      align-items: center;
      gap: 8px;
      cursor: pointer;
      font-weight: 500;
    }

    /* Mobile Menu Button */
    .mobile-menu-btn {
      display: none;
      background: var(--bg-card);
      border: 1px solid var(--border-color);
      border-radius: 12px;
      padding: 12px;
      cursor: pointer;
      color: var(--text-primary);
      font-size: 1.2rem;
      position: fixed;
      top: 16px;
      right: 16px;
      z-index: 150;
    }

    /* Mobile Drawer Overlay */
    .drawer-overlay {
      display: none;
      position: fixed;
      top: 0;
      left: 0;
      right: 0;
      bottom: 0;
      background: rgba(0, 0, 0, 0.5);
      z-index: 200;
    }

    /* Stats Grid */
    .stats-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
      gap: 20px;
      margin-bottom: 32px;
    }

    .stat-card {
      background: var(--bg-card);
      border-radius: var(--border-radius-card);
      padding: 22px 20px;
      display: flex;
      align-items: center;
      gap: 18px;
      box-shadow: var(--shadow-sm);
      transition: var(--transition);
      border: 1px solid var(--border-light);
    }

    .stat-card:hover {
      transform: translateY(-3px);
      box-shadow: var(--shadow-md);
    }

    .stat-icon {
      width: 54px;
      height: 54px;
      background: var(--stat-icon-bg);
      border-radius: 28px;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 26px;
      color: var(--gradient-end);
    }

    .stat-info h3 {
      font-size: 2rem;
      font-weight: 700;
      color: var(--text-primary);
    }

    .stat-info p {
      color: var(--text-secondary);
      font-size: 0.85rem;
      font-weight: 500;
    }

    /* Cards */
    .section-card {
      background: var(--bg-card);
      border-radius: var(--border-radius-card);
      padding: 28px;
      margin-bottom: 32px;
      box-shadow: var(--shadow-sm);
      border: 1px solid var(--border-light);
    }

    .section-title {
      font-size: 1.2rem;
      font-weight: 700;
      color: var(--text-primary);
      display: flex;
      align-items: center;
      gap: 12px;
      margin-bottom: 24px;
      padding-bottom: 14px;
      border-bottom: 2px solid var(--border-light);
    }

    .form-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
      gap: 20px;
    }

    .input-group {
      margin-bottom: 8px;
    }

    .input-group label {
      display: block;
      font-size: 0.8rem;
      font-weight: 600;
      color: var(--text-secondary);
      margin-bottom: 8px;
    }

    .input-group input,
    .input-group select,
    .input-group textarea {
      width: 100%;
      padding: 12px 16px;
      background: var(--bg-primary);
      border: 1.5px solid var(--border-color);
      border-radius: 20px;
      font-size: 0.9rem;
      color: var(--text-primary);
      transition: var(--transition);
    }

    .input-group input:focus,
    .input-group textarea:focus {
      outline: none;
      border-color: var(--gradient-end);
      background: var(--bg-card);
      box-shadow: 0 0 0 3px rgba(42, 82, 152, 0.1);
    }

    .upload-btn {
      background: linear-gradient(135deg, var(--gradient-start), var(--gradient-end));
      color: white;
      border: none;
      padding: 14px 28px;
      border-radius: var(--border-radius-button);
      font-weight: 600;
      font-size: 0.9rem;
      display: inline-flex;
      align-items: center;
      gap: 10px;
      cursor: pointer;
      margin-top: 20px;
      transition: var(--transition);
    }

    .upload-btn:hover {
      transform: translateY(-2px);
      box-shadow: var(--shadow-md);
    }

    /* Tables */
    .results-card {
      background: var(--bg-card);
      border-radius: var(--border-radius-card);
      padding: 24px;
      overflow-x: auto;
    }

    .desktop-table {
      width: 100%;
      border-collapse: collapse;
      min-width: 700px;
    }

    .desktop-table th {
      text-align: right;
      padding: 16px 12px;
      color: var(--text-secondary);
      font-weight: 600;
      font-size: 0.8rem;
      border-bottom: 2px solid var(--border-light);
      background: var(--table-header-bg);
    }

    .desktop-table td {
      padding: 16px 12px;
      color: var(--text-primary);
      font-size: 0.85rem;
      border-bottom: 1px solid var(--border-light);
    }

    .desktop-table tr:hover {
      background: var(--bg-hover);
    }

    .mobile-cards {
      display: none;
    }

    .result-mobile-card {
      background: var(--bg-primary);
      border-radius: 20px;
      padding: 16px;
      margin-bottom: 12px;
    }

    .action-group {
      display: flex;
      gap: 12px;
      margin-top: 12px;
      flex-wrap: wrap;
    }

    .btn-mini {
      padding: 8px 18px;
      border-radius: 40px;
      border: none;
      font-weight: 600;
      font-size: 0.75rem;
      cursor: pointer;
      display: inline-flex;
      align-items: center;
      gap: 8px;
      transition: var(--transition);
    }

    .btn-view {
      background: var(--gradient-end);
      color: white;
      text-decoration: none;
    }

    .btn-delete {
      background: var(--danger-bg);
      color: white;
    }

    .btn-notify {
      background: var(--success-bg);
      color: white;
    }

    .btn-telegram {
      background: var(--telegram-bg);
      color: white;
    }

    .btn-email {
      background: var(--email-bg);
      color: white;
    }

    .btn-mini:hover {
      transform: translateY(-1px);
      filter: brightness(1.05);
    }

    .empty-state {
      text-align: center;
      padding: 60px 20px;
      color: var(--text-muted);
    }

    .telegram-numbers-table,
    .email-logs-table {
      width: 100%;
      border-collapse: collapse;
      margin-top: 16px;
    }

    .telegram-numbers-table th,
    .telegram-numbers-table td,
    .email-logs-table th,
    .email-logs-table td {
      padding: 12px;
      text-align: right;
      border-bottom: 1px solid var(--border-light);
      color: var(--text-primary);
    }

    hr {
      margin: 24px 0;
      border-color: var(--border-light);
    }

    .toast-notify {
      position: fixed;
      bottom: 24px;
      left: 24px;
      right: 24px;
      background: var(--text-primary);
      color: white;
      padding: 14px 20px;
      border-radius: 60px;
      display: flex;
      align-items: center;
      gap: 12px;
      z-index: 1000;
      max-width: 400px;
      margin: 0 auto;
      animation: slideUp 0.3s ease;
      box-shadow: var(--shadow-md);
    }

    .toast-success {
      border-right: 4px solid var(--success-bg);
    }

    .toast-error {
      border-right: 4px solid var(--danger-bg);
    }

    @keyframes slideUp {
      from {
        opacity: 0;
        transform: translateY(20px);
      }
      to {
        opacity: 1;
        transform: translateY(0);
      }
    }

    /* Tab Content */
    .tab-content {
      display: none;
    }

    .tab-content.active {
      display: block;
    }

    /* Recipients List */
    .recipients-container {
      background: var(--bg-primary);
      border-radius: 20px;
      padding: 16px;
      max-height: 240px;
      overflow-y: auto;
      margin: 16px 0;
    }

    .recipient-item {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 12px;
      border-bottom: 1px solid var(--border-color);
    }

    /* ========================================
       RESPONSIVE
    ======================================== */
    @media (max-width: 768px) {
      .sidebar {
        transform: translateX(100%);
        width: 280px;
        z-index: 300;
      }

      .sidebar.open {
        transform: translateX(0);
      }

      .main-content {
        margin-right: 0;
        padding: 20px 16px;
      }

      .mobile-menu-btn {
        display: block;
      }

      .drawer-overlay.open {
        display: block;
      }

      .desktop-table {
        display: none;
      }

      .mobile-cards {
        display: block;
      }

      .stats-grid {
        grid-template-columns: repeat(auto-fit, minmax(160px, 1fr));
        gap: 12px;
      }

      .stat-card {
        padding: 15px;
      }

      .stat-icon {
        width: 44px;
        height: 44px;
        font-size: 20px;
      }

      .stat-info h3 {
        font-size: 1.4rem;
      }
      
      .section-card {
        padding: 20px;
      }
    }

    @media (max-width: 480px) {
      .main-content {
        padding: 16px;
      }

      .header-bar {
        padding: 12px 16px;
      }

      .logo h1 {
        font-size: 1rem;
      }

      .user-badge {
        display: none;
      }
    }
  </style>
</head>
<body>
<div class="dashboard-wrapper">
  <!-- Mobile Menu Button -->
  <button class="mobile-menu-btn" id="mobileMenuBtn">
    <i class="fas fa-bars"></i>
  </button>

  <!-- Drawer Overlay -->
  <div class="drawer-overlay" id="drawerOverlay"></div>

  <!-- Sidebar -->
  <aside class="sidebar" id="sidebar">
    <div class="sidebar-header">
      <h2><i class="fas fa-microscope"></i> معمل التحاليل</h2>
    </div>
    <nav class="sidebar-nav">
      <div class="sidebar-item active" data-tab="tab-lab">
        <i class="fas fa-flask"></i>
        <span>رفع التحاليل</span>
      </div>
      <div class="sidebar-item" data-tab="tab-telegram">
        <i class="fab fa-telegram"></i>
        <span>التيليجرام</span>
      </div>
      <div class="sidebar-item" data-tab="tab-smtp">
        <i class="fas fa-envelope"></i>
        <span>SMTP / الإيميلات</span>
      </div>
    </nav>
    <div class="sidebar-footer">
      <div class="logout-sidebar" id="logoutBtn">
        <i class="fas fa-sign-out-alt"></i>
        <span>خروج</span>
      </div>
      <div style="margin-top: 20px; padding-top: 16px; border-top: 1px solid var(--border-color);">
        <a href="#" style="color: var(--text-muted); text-decoration: none; font-size: 0.75rem;">
          <i class="fas fa-shield-alt"></i> سياسة الخصوصية
        </a>
      </div>
    </div>
  </aside>

  <!-- Main Content -->
  <main class="main-content">
    <div class="header-bar">
      <div class="logo">
        <h1><i class="fas fa-microscope"></i> لوحة التحكم</h1>
      </div>
      <div class="header-actions">
        <button class="theme-toggle" id="themeToggle">
          <i class="fas fa-moon"></i>
          <span>الوضع المظلم</span>
        </button>
        <div class="user-info">
          <span class="user-badge"><i class="fas fa-user-md"></i> الدكتور أحمد</span>
          <div class="logout-link" id="logoutLink"><i class="fas fa-sign-out-alt"></i> خروج</div>
        </div>
      </div>
    </div>

    <!-- Stats Cards -->
    <div class="stats-grid">
      <div class="stat-card">
        <div class="stat-icon"><i class="fas fa-file-alt"></i></div>
        <div class="stat-info">
          <h3 id="totalResultsCount">0</h3>
          <p>إجمالي النتائج</p>
        </div>
      </div>
      <div class="stat-card">
        <div class="stat-icon"><i class="fab fa-telegram"></i></div>
        <div class="stat-info">
          <h3 id="telegramCount">0</h3>
          <p>أرقام تليجرام</p>
        </div>
      </div>
      <div class="stat-card">
        <div class="stat-icon"><i class="fas fa-envelope"></i></div>
        <div class="stat-info">
          <h3 id="emailCount">0</h3>
          <p>إيميلات مرسلة</p>
        </div>
      </div>
    </div>

    <!-- Tab Content: رفع التحاليل -->
    <div id="tab-lab" class="tab-content active">
      <div class="section-card">
        <div class="section-title"><i class="fas fa-cloud-upload-alt"></i> رفع نتيجة تحليل جديدة</div>
        <form id="uploadForm">
          <div class="form-grid">
            <div class="input-group"><label><i class="fas fa-user"></i> اسم المريض</label><input type="text" id="patientName" placeholder="الاسم الكامل" required></div>
            <div class="input-group"><label><i class="fas fa-flask"></i> نوع التحليل</label><input type="text" id="testType" placeholder="مثال: صورة دم" required></div>
            <div class="input-group"><label><i class="fas fa-phone"></i> رقم الهاتف</label><input type="tel" id="patientPhone" placeholder="10 أو 11 رقم" pattern="[0-9]{10,11}" required></div>
            <div class="input-group"><label><i class="fas fa-envelope"></i> البريد الإلكتروني</label><input type="email" id="patientEmail" placeholder="patient@example.com" required></div>
            <div class="input-group"><label><i class="fas fa-file-pdf"></i> ملف النتيجة</label><input type="file" id="resultFile" accept=".pdf,.jpg,.jpeg,.png,.doc,.docx" required></div>
            <div class="input-group"><label><i class="fas fa-sticky-note"></i> ملاحظات</label><textarea id="notes" rows="2" placeholder="أي ملاحظات خاصة..."></textarea></div>
          </div>
          <button type="submit" class="upload-btn"><i class="fas fa-cloud-upload-alt"></i> رفع النتيجة</button>
        </form>
      </div>

      <div class="results-card">
        <div class="section-title"><i class="fas fa-database"></i> قاعدة البيانات</div>
        <div id="resultsListContainer">
          <table class="desktop-table" id="resultsTable">
            <thead>
              <tr><th>المريض</th><th>نوع التحليل</th><th>الهاتف</th><th>البريد</th><th>الملف</th><th>التاريخ</th><th>الإجراءات</th></tr>
            </thead>
            <tbody id="resultsTableBody">
              <!-- Data will be inserted here -->
            </tbody>
           </table>
          <div id="mobileResultsCards" class="mobile-cards"></div>
        </div>
      </div>
    </div>

    <!-- Tab Content: التيليجرام -->
    <div id="tab-telegram" class="tab-content">
      <div class="section-card">
        <div class="section-title"><i class="fab fa-telegram"></i> إرسال إشعارات عبر التيليجرام</div>
        <div style="margin-bottom: 24px;">
          <h4 style="margin-bottom: 16px;"><i class="fas fa-paper-plane"></i> إرسال رسالة لرقم معين</h4>
          <div class="form-grid">
            <div class="input-group"><label>رقم الهاتف</label><input type="tel" id="telegramPhone" placeholder="مثال: 01234567890"></div>
            <div class="input-group"><label>نص الرسالة</label><textarea id="telegramMessage" rows="3" placeholder="أدخل نص الرسالة..."></textarea></div>
          </div>
          <button id="sendTelegramBtn" class="upload-btn" style="background: #0088cc;"><i class="fab fa-telegram"></i> إرسال عبر تليجرام</button>
          <div id="telegramResult" style="margin-top: 16px;"></div>
        </div>
        <hr>
        <div>
          <h4 style="margin-bottom: 16px;"><i class="fas fa-list"></i> الأرقام المسجلة في البوت</h4>
          <div style="display: flex; gap: 12px; margin-bottom: 20px; flex-wrap: wrap;">
            <input type="tel" id="newTelegramNumber" placeholder="رقم جديد" style="padding: 12px 16px; border-radius: 40px; border: 1px solid var(--border-color); flex:1; background: var(--bg-primary); color: var(--text-primary);">
            <button id="addTelegramNumberBtn" class="btn-mini" style="background:var(--gradient-end);color:white;">إضافة</button>
            <button id="refreshTelegramNumbers" class="btn-mini" style="background:var(--text-muted);color:white;">تحديث</button>
          </div>
          <table class="telegram-numbers-table">
            <thead><tr><th>الرقم</th><th>التاريخ</th><th></th></thead>
            <tbody id="telegramNumbersBody">
              <tr><td colspan="3" style="text-align:center;">لا توجد أرقام</td></tr>
            </tbody>
          </table>
        </div>
      </div>
    </div>

    <!-- Tab Content: SMTP / الإيميلات -->
    <div id="tab-smtp" class="tab-content">
      <div class="section-card">
        <div class="section-title"><i class="fas fa-paper-plane"></i> إرسال إيميل يدوي</div>
        <div class="form-grid">
          <div class="input-group"><label><i class="fas fa-user"></i> اسم المستلم</label><input type="text" id="manualEmailName" placeholder="الاسم"></div>
          <div class="input-group"><label><i class="fas fa-envelope"></i> البريد الإلكتروني</label><input type="email" id="manualEmailAddress" placeholder="example@domain.com"></div>
          <div class="input-group"><label><i class="fas fa-tag"></i> الموضوع</label><input type="text" id="manualEmailSubject" placeholder="موضوع الرسالة"></div>
          <div class="input-group" style="grid-column: span 2;"><label><i class="fas fa-comment"></i> محتوى الرسالة</label><textarea id="manualEmailBody" rows="5" placeholder="اكتب محتوى الإيميل هنا..."></textarea></div>
        </div>
        <button id="sendManualEmailBtn" class="upload-btn" style="background: #ea4335;"><i class="fas fa-envelope"></i> إرسال الإيميل</button>
        <div id="manualEmailResult" style="margin-top: 16px;"></div>
      </div>

      <div class="section-card">
        <div class="section-title"><i class="fas fa-users"></i> إرسال إيميل جماعي لقائمة مخصصة</div>
        <div style="margin-bottom: 24px;">
          <h4 style="margin-bottom: 16px;"><i class="fas fa-plus-circle"></i> إضافة مستلمين</h4>
          <div class="form-grid">
            <div class="input-group"><label>اسم المستلم</label><input type="text" id="bulkRecipientName" placeholder="الاسم"></div>
            <div class="input-group"><label>البريد الإلكتروني</label><input type="email" id="bulkRecipientEmail" placeholder="email@example.com"></div>
          </div>
          <button id="addRecipientBtn" class="btn-mini" style="background:var(--gradient-end);color:white;margin-top:12px;"><i class="fas fa-plus"></i> إضافة للمستلمين</button>
        </div>
        <div style="margin-bottom: 24px;">
          <h4><i class="fas fa-list"></i> قائمة المستلمين (<span id="recipientCount">0</span>)</h4>
          <div id="recipientsList" class="recipients-container">
            <div style="text-align: center; color: var(--text-muted);">لا يوجد مستلمين، أضف مستلمين أولاً</div>
          </div>
          <button id="clearRecipientsBtn" class="btn-mini" style="background:var(--danger-bg);color:white;margin-top:12px;"><i class="fas fa-trash"></i> حذف الكل</button>
        </div>
        <hr>
        <div>
          <h4><i class="fas fa-envelope-open-text"></i> بيانات الإيميل</h4>
          <div class="input-group"><label><i class="fas fa-tag"></i> الموضوع</label><input type="text" id="bulkEmailSubject" placeholder="موضوع الرسالة"></div>
          <div class="input-group"><label><i class="fas fa-comment"></i> محتوى الرسالة</label><textarea id="bulkEmailBody" rows="5" placeholder="محتوى الإيميل لجميع المستلمين..."></textarea></div>
          <button id="sendBulkEmailBtn" class="upload-btn" style="background: #ea4335;"><i class="fas fa-paper-plane"></i> إرسال للجميع</button>
          <div id="bulkEmailResult" style="margin-top: 16px;"></div>
        </div>
      </div>

      <div class="section-card">
        <div class="section-title"><i class="fas fa-clipboard-list"></i> قوالب سريعة</div>
        <div style="display: flex; flex-wrap: wrap; gap: 12px;">
          <button class="btn-mini template-btn" style="background:var(--gradient-end);color:white;" data-template="welcome">ترحيب</button>
          <button class="btn-mini template-btn" style="background:var(--gradient-end);color:white;" data-template="reminder">تذكير</button>
          <button class="btn-mini template-btn" style="background:var(--gradient-end);color:white;" data-template="thanks">شكر</button>
          <button class="btn-mini template-btn" style="background:var(--gradient-end);color:white;" data-template="result_ready">نتيجة جاهزة</button>
        </div>
      </div>

      <div class="section-card">
        <div class="section-title"><i class="fas fa-history"></i> سجل الإيميلات المرسلة</div>
        <button id="refreshEmailLogs" class="btn-mini" style="background:var(--text-muted);color:white;margin-bottom:16px;">تحديث</button>
        <div style="overflow-x: auto;">
          <table class="email-logs-table">
            <thead>
              <tr><th>إلى</th><th>الموضوع</th><th>التاريخ</th><th>الحالة</th><th>الإجراءات</th></tr>
            </thead>
            <tbody id="emailLogsBody">
              <tr><td colspan="5" style="text-align:center;">لا توجد إيميلات مرسلة</td></tr>
            </tbody>
           </table>
        </div>
      </div>
    </div>
  </main>
</div>

<script>
  // ========================================
  // STORAGE KEYS
  // ========================================
  const STORAGE_KEYS = {
    RESULTS: 'lab_results',
    TELEGRAM_NUMBERS: 'telegram_numbers',
    EMAIL_LOGS: 'email_logs'
  };

  // ========================================
  // INITIAL DATA
  // ========================================
  let results = [];
  let telegramNumbers = [];
  let emailLogs = [];
  let recipientsList = [];

  // ========================================
  // LOAD DATA FROM LOCALSTORAGE
  // ========================================
  function loadData() {
    const storedResults = localStorage.getItem(STORAGE_KEYS.RESULTS);
    if (storedResults) results = JSON.parse(storedResults);
    else results = [];

    const storedTelegram = localStorage.getItem(STORAGE_KEYS.TELEGRAM_NUMBERS);
    if (storedTelegram) telegramNumbers = JSON.parse(storedTelegram);
    else telegramNumbers = [];

    const storedEmails = localStorage.getItem(STORAGE_KEYS.EMAIL_LOGS);
    if (storedEmails) emailLogs = JSON.parse(storedEmails);
    else emailLogs = [];

    updateStats();
    renderResults();
    renderTelegramNumbers();
    renderEmailLogs();
  }

  // ========================================
  // SAVE DATA TO LOCALSTORAGE
  // ========================================
  function saveResults() {
    localStorage.setItem(STORAGE_KEYS.RESULTS, JSON.stringify(results));
    updateStats();
    renderResults();
  }

  function saveTelegramNumbers() {
    localStorage.setItem(STORAGE_KEYS.TELEGRAM_NUMBERS, JSON.stringify(telegramNumbers));
    updateStats();
    renderTelegramNumbers();
  }

  function saveEmailLogs() {
    localStorage.setItem(STORAGE_KEYS.EMAIL_LOGS, JSON.stringify(emailLogs));
    updateStats();
    renderEmailLogs();
  }

  // ========================================
  // UPDATE STATS CARDS
  // ========================================
  function updateStats() {
    document.getElementById('totalResultsCount').innerText = results.length;
    document.getElementById('telegramCount').innerText = telegramNumbers.length;
    document.getElementById('emailCount').innerText = emailLogs.length;
  }

  // ========================================
  // RENDER RESULTS (TABLE + MOBILE)
  // ========================================
  function renderResults() {
    const tbody = document.getElementById('resultsTableBody');
    const mobileContainer = document.getElementById('mobileResultsCards');
    
    if (results.length === 0) {
      tbody.innerHTML = '<tr><td colspan="7" style="text-align:center;">لا توجد نتائج مسجلة</td></tr>';
      mobileContainer.innerHTML = '<div class="empty-state"><i class="fas fa-folder-open" style="font-size: 3rem;"></i><p>لا توجد نتائج مسجلة</p></div>';
      return;
    }

    // Desktop Table
    tbody.innerHTML = results.map(r => `
      <tr id="row-${r.id}">
        <td><strong>${escapeHtml(r.name)}</strong></td>
        <td>${escapeHtml(r.test)}</td>
        <td>${escapeHtml(r.phone)}</td>
        <td>${escapeHtml(r.email)}</td>
        <td><button class="btn-mini btn-view" onclick="viewFile('${r.id}')"><i class="fas fa-eye"></i> عرض</button></td>
        <td>${r.date}</td>
        <td><div class="action-group">
          <button class="btn-mini btn-delete" onclick="deleteResult('${r.id}')"><i class="fas fa-trash"></i> حذف</button>
          <button class="btn-mini btn-notify" onclick="sendEmailNotification('${r.id}')"><i class="fas fa-envelope"></i> إيميل</button>
          <button class="btn-mini btn-telegram" onclick="sendTelegramToPatient('${r.id}')"><i class="fab fa-telegram"></i> تليجرام</button>
        </div></td>
      </tr>
    `).join('');

    // Mobile Cards
    mobileContainer.innerHTML = results.map(r => `
      <div class="result-mobile-card">
        <div><strong>${escapeHtml(r.name)}</strong> - ${escapeHtml(r.test)}</div>
        <div>📞 ${escapeHtml(r.phone)}</div>
        <div>📧 ${escapeHtml(r.email)}</div>
        <div class="action-group">
          <button class="btn-mini btn-view" onclick="viewFile('${r.id}')">عرض</button>
          <button class="btn-mini btn-delete" onclick="deleteResult('${r.id}')">حذف</button>
          <button class="btn-mini btn-telegram" onclick="sendTelegramToPatient('${r.id}')">تليجرام</button>
        </div>
      </div>
    `).join('');
  }

  // ========================================
  // RENDER TELEGRAM NUMBERS
  // ========================================
  function renderTelegramNumbers() {
    const tbody = document.getElementById('telegramNumbersBody');
    if (telegramNumbers.length === 0) {
      tbody.innerHTML = '<tr><td colspan="3" style="text-align:center;">لا توجد أرقام</td></tr>';
      return;
    }
    tbody.innerHTML = telegramNumbers.map(num => `
      <tr id="tg-row-${num.phone}">
        <td>${escapeHtml(num.phone)}</td>
        <td>${num.createdAt || '—'}</td>
        <td><button class="btn-mini btn-delete" onclick="deleteTelegramNumber('${num.phone}')">حذف</button></td>
      </tr>
    `).join('');
  }

  // ========================================
  // RENDER EMAIL LOGS
  // ========================================
  function renderEmailLogs() {
    const tbody = document.getElementById('emailLogsBody');
    if (emailLogs.length === 0) {
      tbody.innerHTML = '<tr><td colspan="5" style="text-align:center;">لا توجد إيميلات مرسلة</td></tr>';
      return;
    }
    tbody.innerHTML = emailLogs.map(log => `
      <tr id="log-${log.id}">
        <td>${escapeHtml(log.to)}</td>
        <td>${escapeHtml(log.subject)}</td>
        <td>${log.date}</td>
        <td>${log.status === 'sent' ? '✅ مرسل' : '❌ فشل'}</td>
        <td><button class="btn-mini btn-delete" onclick="deleteEmailLog('${log.id}')"><i class="fas fa-trash"></i> حذف</button></td>
      </tr>
    `).join('');
  }

  // ========================================
  // DELETE RESULT
  // ========================================
  window.deleteResult = (id) => {
    const result = results.find(r => r.id == id);
    if (!result) return;
    if (confirm(`⚠️ حذف نتيجة ${result.name}؟`)) {
      results = results.filter(r => r.id != id);
      saveResults();
      showNotification(`✅ تم حذف ${result.name}`, 'success');
    }
  };

  // ========================================
  // VIEW FILE (SIMULATED)
  // ========================================
  window.viewFile = (id) => {
    const result = results.find(r => r.id == id);
    if (result && result.fileData) {
      // Create a blob and open in new tab
      const byteCharacters = atob(result.fileData.split(',')[1]);
      const byteNumbers = new Array(byteCharacters.length);
      for (let i = 0; i < byteCharacters.length; i++) {
        byteNumbers[i] = byteCharacters.charCodeAt(i);
      }
      const byteArray = new Uint8Array(byteNumbers);
      const blob = new Blob([byteArray], { type: result.fileType });
      const url = URL.createObjectURL(blob);
      window.open(url, '_blank');
      URL.revokeObjectURL(url);
    } else {
      showNotification('⚠️ لا يوجد ملف مرفق لهذه النتيجة', 'error');
    }
  };

  // ========================================
  // SEND EMAIL NOTIFICATION (SIMULATED)
  // ========================================
  window.sendEmailNotification = async (id) => {
    const result = results.find(r => r.id == id);
    if (!result) return;
    if (!confirm(`📧 إرسال إيميل للمريض ${result.name}؟`)) return;
    
    showNotification(`📧 جاري إرسال الإيميل إلى ${result.name}...`);
    
    setTimeout(() => {
      const emailLog = {
        id: Date.now() + Math.random(),
        to: result.email,
        subject: `نتيجة التحليل - ${result.test}`,
        date: new Date().toLocaleString(),
        status: 'sent'
      };
      emailLogs.unshift(emailLog);
      saveEmailLogs();
      showNotification(`✅ تم إرسال الإيميل إلى ${result.name}`, 'success');
    }, 800);
  };

  // ========================================
  // SEND TELEGRAM TO PATIENT (SIMULATED)
  // ========================================
  window.sendTelegramToPatient = async (id) => {
    const result = results.find(r => r.id == id);
    if (!result) return;
    if (!confirm(`📱 إرسال تليجرام للمريض ${result.name}؟`)) return;
    
    showNotification(`📱 جاري إرسال تليجرام إلى ${result.phone}...`);
    
    setTimeout(() => {
      showNotification(`✅ تم إرسال الإشعار إلى ${result.name} عبر التليجرام`, 'success');
    }, 800);
  };

  // ========================================
  // TELEGRAM FUNCTIONS
  // ========================================
  document.getElementById('sendTelegramBtn')?.addEventListener('click', () => {
    const phone = document.getElementById('telegramPhone')?.value.trim();
    const message = document.getElementById('telegramMessage')?.value.trim();
    const resultDiv = document.getElementById('telegramResult');
    
    if (!phone) { showNotification('⚠️ أدخل رقم الهاتف', 'error'); return; }
    if (!message) { showNotification('⚠️ أدخل نص الرسالة', 'error'); return; }
    
    resultDiv.innerHTML = '<span style="color:#0088cc;">⏳ جاري الإرسال...</span>';
    
    setTimeout(() => {
      resultDiv.innerHTML = `<span style="color:#10b981;">✅ تم إرسال الرسالة إلى ${phone}</span>`;
      showNotification(`✅ تم إرسال الرسالة إلى ${phone}`, 'success');
      document.getElementById('telegramPhone').value = '';
      document.getElementById('telegramMessage').value = '';
    }, 800);
  });

  document.getElementById('addTelegramNumberBtn')?.addEventListener('click', () => {
    const phone = document.getElementById('newTelegramNumber')?.value.trim();
    if (!phone) { showNotification('⚠️ أدخل رقم الهاتف', 'error'); return; }
    if (telegramNumbers.some(n => n.phone === phone)) {
      showNotification('⚠️ الرقم موجود بالفعل', 'error');
      return;
    }
    
    telegramNumbers.push({
      phone: phone,
      createdAt: new Date().toLocaleString()
    });
    saveTelegramNumbers();
    document.getElementById('newTelegramNumber').value = '';
    showNotification(`✅ تم إضافة ${phone}`, 'success');
  });

  window.deleteTelegramNumber = (phone) => {
    if (!confirm(`حذف ${phone}؟`)) return;
    telegramNumbers = telegramNumbers.filter(n => n.phone !== phone);
    saveTelegramNumbers();
    showNotification(`✅ تم حذف ${phone}`, 'success');
  };

  document.getElementById('refreshTelegramNumbers')?.addEventListener('click', () => {
    renderTelegramNumbers();
    showNotification('تم تحديث القائمة', 'success');
  });

  // ========================================
  // EMAIL FUNCTIONS
  // ========================================
  function addEmailLog(to, subject, status = 'sent') {
    const log = {
      id: Date.now() + Math.random(),
      to: to,
      subject: subject,
      date: new Date().toLocaleString(),
      status: status
    };
    emailLogs.unshift(log);
    saveEmailLogs();
  }

  document.getElementById('sendManualEmailBtn')?.addEventListener('click', () => {
    const name = document.getElementById('manualEmailName')?.value.trim();
    const to = document.getElementById('manualEmailAddress')?.value.trim();
    const subject = document.getElementById('manualEmailSubject')?.value.trim();
    const body = document.getElementById('manualEmailBody')?.value.trim();
    const resultDiv = document.getElementById('manualEmailResult');
    
    if (!name || !to || !subject || !body) {
      showNotification('⚠️ املأ جميع الحقول', 'error');
      return;
    }
    
    resultDiv.innerHTML = '<span style="color:#ea4335;">⏳ جاري الإرسال...</span>';
    
    setTimeout(() => {
      addEmailLog(to, subject, 'sent');
      resultDiv.innerHTML = '<span style="color:#10b981;">✅ تم الإرسال بنجاح</span>';
      showNotification(`✅ تم إرسال الإيميل إلى ${to}`, 'success');
      
      document.getElementById('manualEmailName').value = '';
      document.getElementById('manualEmailAddress').value = '';
      document.getElementById('manualEmailSubject').value = '';
      document.getElementById('manualEmailBody').value = '';
      
      setTimeout(() => {
        resultDiv.innerHTML = '';
      }, 3000);
    }, 800);
  });

  // Recipients Management
  function updateRecipientsDisplay() {
    const container = document.getElementById('recipientsList');
    const countSpan = document.getElementById('recipientCount');
    
    if (recipientsList.length === 0) {
      container.innerHTML = '<div style="text-align: center; color: var(--text-muted);">لا يوجد مستلمين، أضف مستلمين أولاً</div>';
      if (countSpan) countSpan.innerText = '0';
      return;
    }
    
    container.innerHTML = recipientsList.map((r, idx) => `
      <div class="recipient-item">
        <div><strong>${escapeHtml(r.name)}</strong> - ${escapeHtml(r.email)}</div>
        <button class="btn-mini" style="background:var(--danger-bg);color:white;padding:4px 14px;" onclick="removeRecipient(${idx})">حذف</button>
      </div>
    `).join('');
    if (countSpan) countSpan.innerText = recipientsList.length;
  }
  
  window.removeRecipient = function(idx) {
    recipientsList.splice(idx, 1);
    updateRecipientsDisplay();
    showNotification('تم حذف المستلم', 'success');
  };
  
  document.getElementById('addRecipientBtn')?.addEventListener('click', () => {
    const name = document.getElementById('bulkRecipientName')?.value.trim();
    const email = document.getElementById('bulkRecipientEmail')?.value.trim();
    
    if (!name) { showNotification('⚠️ أدخل اسم المستلم', 'error'); return; }
    if (!email) { showNotification('⚠️ أدخل البريد الإلكتروني', 'error'); return; }
    if (!/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) {
      showNotification('⚠️ البريد الإلكتروني غير صحيح', 'error');
      return;
    }
    
    recipientsList.push({ name, email });
    updateRecipientsDisplay();
    
    document.getElementById('bulkRecipientName').value = '';
    document.getElementById('bulkRecipientEmail').value = '';
    showNotification(`✅ تم إضافة ${name}`, 'success');
  });
  
  document.getElementById('clearRecipientsBtn')?.addEventListener('click', () => {
    if (recipientsList.length > 0 && confirm('هل تريد حذف جميع المستلمين؟')) {
      recipientsList = [];
      updateRecipientsDisplay();
      showNotification('✅ تم حذف جميع المستلمين', 'success');
    }
  });
  
  document.getElementById('sendBulkEmailBtn')?.addEventListener('click', () => {
    const subject = document.getElementById('bulkEmailSubject')?.value.trim();
    const body = document.getElementById('bulkEmailBody')?.value.trim();
    const resultDiv = document.getElementById('bulkEmailResult');
    
    if (recipientsList.length === 0) {
      showNotification('⚠️ أضف مستلمين أولاً', 'error');
      return;
    }
    if (!subject) { showNotification('⚠️ أدخل الموضوع', 'error'); return; }
    if (!body) { showNotification('⚠️ أدخل محتوى الرسالة', 'error'); return; }
    
    resultDiv.innerHTML = '<span style="color:#ea4335;">⏳ جاري الإرسال للجميع...</span>';
    
    setTimeout(() => {
      let sentCount = 0;
      recipientsList.forEach(recipient => {
        addEmailLog(recipient.email, subject, 'sent');
        sentCount++;
      });
      
      resultDiv.innerHTML = `<span style="color:#10b981;">✅ تم الإرسال إلى ${sentCount} من ${recipientsList.length} مستلم</span>`;
      showNotification(`✅ تم إرسال ${sentCount} إيميل`, 'success');
      
      document.getElementById('bulkEmailSubject').value = '';
      document.getElementById('bulkEmailBody').value = '';
      
      setTimeout(() => {
        resultDiv.innerHTML = '';
      }, 3000);
    }, 1000);
  });

  window.deleteEmailLog = (logId) => {
    if (!confirm('⚠️ هل تريد حذف هذا الإيميل من السجل؟')) return;
    emailLogs = emailLogs.filter(log => log.id != logId);
    saveEmailLogs();
    showNotification('✅ تم حذف الإيميل من السجل', 'success');
  };
  
  document.getElementById('refreshEmailLogs')?.addEventListener('click', () => {
    renderEmailLogs();
    showNotification('تم تحديث السجل', 'success');
  });

  // Templates
  const templates = {
    welcome: { subject: 'مرحباً بك في خدمتنا', body: 'نرحب بك في مركز التحاليل الطبية. يسعدنا خدمتك.' },
    reminder: { subject: 'تذكير بموعد التحليل', body: 'نود تذكيرك بموعد التحليل المحدد. يرجى الحضور في الموعد المحدد.' },
    thanks: { subject: 'شكراً لثقتك', body: 'نشكرك على ثقتك بنا. نحن في خدمتك دائماً.' },
    result_ready: { subject: 'نتيجة التحليل جاهزة', body: 'تم تجهيز نتيجة التحليل الخاصة بك. يمكنك الاطلاع عليها من خلال الرابط المرفق.' }
  };
  
  document.querySelectorAll('.template-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const type = btn.getAttribute('data-template');
      const t = templates[type];
      if (t) {
        document.getElementById('manualEmailSubject').value = t.subject;
        document.getElementById('manualEmailBody').value = t.body;
        showNotification(`تم تحميل قالب: ${t.subject}`, 'success');
      }
    });
  });

  // ========================================
  // UPLOAD RESULT
  // ========================================
  document.getElementById('uploadForm')?.addEventListener('submit', (e) => {
    e.preventDefault();
    
    const name = document.getElementById('patientName')?.value.trim();
    const test = document.getElementById('testType')?.value.trim();
    const phone = document.getElementById('patientPhone')?.value.trim();
    const email = document.getElementById('patientEmail')?.value.trim();
    const fileInput = document.getElementById('resultFile');
    const notes = document.getElementById('notes')?.value.trim();
    
    if (!name || !test || !phone || !email || !fileInput.files[0]) {
      showNotification('⚠️ يرجى ملء جميع الحقول واختيار ملف', 'error');
      return;
    }
    
    const reader = new FileReader();
    reader.onload = function(evt) {
      const newResult = {
        id: Date.now(),
        name: name,
        test: test,
        phone: phone,
        email: email,
        notes: notes,
        date: new Date().toLocaleString(),
        fileData: evt.target.result,
        fileName: fileInput.files[0].name,
        fileType: fileInput.files[0].type
      };
      
      results.unshift(newResult);
      saveResults();
      
      document.getElementById('uploadForm').reset();
      showNotification(`✅ تم رفع نتيجة ${name} بنجاح`, 'success');
    };
    
    reader.readAsDataURL(fileInput.files[0]);
  });

  // ========================================
  // THEME MANAGEMENT
  // ========================================
  const themeToggle = document.getElementById('themeToggle');
  const html = document.documentElement;
  let currentTheme = localStorage.getItem('theme') || 'light';
  
  function setTheme(theme) {
    if (theme === 'dark') {
      html.setAttribute('data-theme', 'dark');
      if (themeToggle) themeToggle.innerHTML = '<i class="fas fa-sun"></i><span>الوضع الفاتح</span>';
      localStorage.setItem('theme', 'dark');
    } else {
      html.removeAttribute('data-theme');
      if (themeToggle) themeToggle.innerHTML = '<i class="fas fa-moon"></i><span>الوضع المظلم</span>';
      localStorage.setItem('theme', 'light');
    }
    currentTheme = theme;
  }
  
  setTheme(currentTheme);
  
  if (themeToggle) {
    themeToggle.addEventListener('click', () => {
      const newTheme = currentTheme === 'light' ? 'dark' : 'light';
      setTheme(newTheme);
    });
  }

  // ========================================
  // SIDEBAR / DRAWER FUNCTIONALITY
  // ========================================
  const mobileMenuBtn = document.getElementById('mobileMenuBtn');
  const sidebarEl = document.getElementById('sidebar');
  const drawerOverlay = document.getElementById('drawerOverlay');

  function closeDrawer() {
    sidebarEl?.classList.remove('open');
    drawerOverlay?.classList.remove('open');
  }

  function openDrawer() {
    sidebarEl?.classList.add('open');
    drawerOverlay?.classList.add('open');
  }

  if (mobileMenuBtn) mobileMenuBtn.addEventListener('click', openDrawer);
  if (drawerOverlay) drawerOverlay.addEventListener('click', closeDrawer);

  // ========================================
  // SIDEBAR NAVIGATION (TABS)
  // ========================================
  const sidebarItems = document.querySelectorAll('.sidebar-item');
  const tabContents = document.querySelectorAll('.tab-content');

  function switchTab(tabId) {
    tabContents.forEach(content => content.classList.remove('active'));
    const activeTab = document.getElementById(tabId);
    if (activeTab) activeTab.classList.add('active');
    
    sidebarItems.forEach(item => {
      item.classList.remove('active');
      if (item.getAttribute('data-tab') === tabId) item.classList.add('active');
    });
    
    closeDrawer();
  }

  sidebarItems.forEach(item => {
    item.addEventListener('click', () => {
      const tabId = item.getAttribute('data-tab');
      if (tabId) switchTab(tabId);
    });
  });

  // ========================================
  // LOGOUT FUNCTIONALITY
  // ========================================
  function handleLogout() {
    if (confirm('هل أنت متأكد من الخروج؟')) {
      localStorage.clear();
      showNotification('تم تسجيل الخروج بنجاح', 'success');
      setTimeout(() => {
        location.reload();
      }, 1000);
    }
  }
  
  document.getElementById('logoutLink')?.addEventListener('click', handleLogout);
  document.getElementById('logoutBtn')?.addEventListener('click', handleLogout);

  // ========================================
  // HELPER FUNCTIONS
  // ========================================
  function showNotification(message, type = 'success') {
    const existing = document.querySelector('.toast-notify');
    if (existing) existing.remove();
    
    const toast = document.createElement('div');
    toast.className = `toast-notify toast-${type}`;
    toast.innerHTML = `${type === 'success' ? '✅' : '❌'} <span>${message}</span> <i class="fas fa-times-circle" style="margin-right: auto; cursor: pointer;" onclick="this.parentElement.remove()"></i>`;
    document.body.appendChild(toast);
    
    setTimeout(() => toast.remove(), 4000);
  }

  function escapeHtml(str) {
    if (!str) return '';
    return str.replace(/[&<>]/g, function(m) {
      if (m === '&') return '&amp;';
      if (m === '<') return '&lt;';
      if (m === '>') return '&gt;';
      return m;
    });
  }

  // ========================================
  // INITIALIZE
  // ========================================
  loadData();
</script>
</body>
</html>
