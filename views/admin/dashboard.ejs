<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
  <title>لوحة التحكم - معمل التحاليل</title>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  <style>
    /* ========================================
       CSS VARIABLES FOR THEMING
    ======================================== */
    :root {
      --bg-primary: #f0f4f9;
      --bg-card: #ffffff;
      --bg-sidebar: #ffffff;
      --bg-header: #ffffff;
      --bg-hover: #f1f5f9;
      --text-primary: #1e293b;
      --text-secondary: #64748b;
      --text-muted: #94a3b8;
      --border-color: #e2e8f0;
      --border-light: #eef2f6;
      --shadow-sm: 0 2px 8px rgba(0, 0, 0, 0.04);
      --shadow-md: 0 4px 12px rgba(0, 0, 0, 0.08);
      --gradient-start: #1e3c72;
      --gradient-end: #2a5298;
      --stat-icon-bg: #eef2ff;
      --table-header-bg: #f8fafc;
      --success-bg: #10b981;
      --danger-bg: #dc2626;
      --telegram-bg: #0088cc;
      --email-bg: #ea4335;
      --transition-default: all 0.2s ease;
    }

    [data-theme="dark"] {
      --bg-primary: #0f172a;
      --bg-card: #1e293b;
      --bg-sidebar: #1e293b;
      --bg-header: #1e293b;
      --bg-hover: #334155;
      --text-primary: #f1f5f9;
      --text-secondary: #cbd5e1;
      --text-muted: #94a3b8;
      --border-color: #334155;
      --border-light: #1e293b;
      --shadow-sm: 0 2px 8px rgba(0, 0, 0, 0.2);
      --shadow-md: 0 4px 12px rgba(0, 0, 0, 0.3);
      --gradient-start: #0f172a;
      --gradient-end: #1e3c72;
      --stat-icon-bg: #1e3a5f;
      --table-header-bg: #0f172a;
    }

    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    body {
      font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', 'Tajawal', sans-serif;
      background: var(--bg-primary);
      transition: background-color 0.3s ease;
    }

    /* ========================================
       NEW LAYOUT: CSS GRID + FLEXBOX
    ======================================== */
    .dashboard-container {
      display: grid;
      grid-template-columns: 280px 1fr;
      min-height: 100vh;
      transition: all 0.3s ease;
    }

    /* SIDEBAR - Fixed & Independent */
    .sidebar {
      background: var(--bg-sidebar);
      border-left: 1px solid var(--border-color);
      height: 100vh;
      position: sticky;
      top: 0;
      display: flex;
      flex-direction: column;
      justify-content: space-between;
      overflow-y: auto;
      box-shadow: var(--shadow-sm);
      z-index: 50;
    }

    .sidebar-header {
      padding: 28px 20px;
      border-bottom: 1px solid var(--border-color);
    }

    .sidebar-header h2 {
      font-size: 1.2rem;
      color: var(--text-primary);
      display: flex;
      align-items: center;
      gap: 10px;
    }

    .sidebar-header h2 i {
      color: var(--gradient-end);
    }

    .sidebar-nav {
      padding: 20px 0;
      flex: 1;
    }

    .sidebar-item {
      display: flex;
      align-items: center;
      gap: 12px;
      padding: 12px 20px;
      margin: 4px 12px;
      border-radius: 16px;
      color: var(--text-secondary);
      text-decoration: none;
      transition: var(--transition-default);
      cursor: pointer;
    }

    .sidebar-item:hover {
      background: var(--bg-hover);
      color: var(--text-primary);
    }

    .sidebar-item.active {
      background: linear-gradient(90deg, transparent, rgba(42, 82, 152, 0.1));
      color: var(--gradient-end);
      font-weight: 600;
    }

    .sidebar-item i {
      width: 24px;
      font-size: 1.1rem;
    }

    .sidebar-footer {
      padding: 20px;
      border-top: 1px solid var(--border-color);
      margin-top: auto;
    }

    .logout-sidebar {
      display: flex;
      align-items: center;
      gap: 12px;
      color: var(--danger-bg);
      text-decoration: none;
      padding: 12px;
      border-radius: 12px;
      transition: var(--transition-default);
    }

    .logout-sidebar:hover {
      background: rgba(220, 38, 38, 0.1);
    }

    /* MAIN CONTENT */
    .main-content {
      padding: 24px 32px;
      background: var(--bg-primary);
      overflow-x: hidden;
    }

    /* Header Bar */
    .header-bar {
      background: var(--bg-card);
      border-radius: 28px;
      padding: 16px 24px;
      margin-bottom: 32px;
      display: flex;
      flex-wrap: wrap;
      justify-content: space-between;
      align-items: center;
      gap: 20px;
      box-shadow: var(--shadow-sm);
    }

    .logo h1 {
      font-size: 1.3rem;
      color: var(--text-primary);
      display: flex;
      align-items: center;
      gap: 10px;
    }

    .header-actions {
      display: flex;
      align-items: center;
      gap: 20px;
    }

    .theme-toggle {
      background: var(--bg-primary);
      border: 1px solid var(--border-color);
      border-radius: 40px;
      padding: 8px 18px;
      cursor: pointer;
      display: flex;
      align-items: center;
      gap: 8px;
      color: var(--text-primary);
      font-size: 0.85rem;
      font-weight: 500;
      transition: var(--transition-default);
    }

    .theme-toggle:hover {
      transform: translateY(-2px);
      box-shadow: var(--shadow-sm);
    }

    .user-info {
      display: flex;
      align-items: center;
      gap: 15px;
    }

    .user-badge {
      background: var(--bg-hover);
      padding: 8px 18px;
      border-radius: 40px;
      font-size: 0.85rem;
      color: var(--text-primary);
    }

    .logout-link {
      color: var(--danger-bg);
      text-decoration: none;
      display: flex;
      align-items: center;
      gap: 6px;
    }

    /* Mobile Menu Button - Hidden on Desktop */
    .mobile-menu-btn {
      display: none;
      position: fixed;
      bottom: 20px;
      left: 20px;
      z-index: 100;
      background: var(--gradient-end);
      border: none;
      border-radius: 50%;
      width: 50px;
      height: 50px;
      color: white;
      font-size: 1.4rem;
      box-shadow: var(--shadow-md);
      cursor: pointer;
    }

    /* Stats Grid - Independent Cards */
    .stats-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
      gap: 24px;
      margin-bottom: 40px;
    }

    .stat-card {
      background: var(--bg-card);
      border-radius: 28px;
      padding: 24px;
      display: flex;
      align-items: center;
      gap: 20px;
      box-shadow: var(--shadow-sm);
      transition: var(--transition-default);
    }

    .stat-card:hover {
      transform: translateY(-4px);
      box-shadow: var(--shadow-md);
    }

    .stat-icon {
      width: 56px;
      height: 56px;
      background: var(--stat-icon-bg);
      border-radius: 24px;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 28px;
      color: var(--gradient-end);
    }

    .stat-info h3 {
      font-size: 2rem;
      font-weight: 700;
      color: var(--text-primary);
      line-height: 1.2;
    }

    .stat-info p {
      color: var(--text-secondary);
      font-size: 0.85rem;
    }

    /* Section Cards - Independent */
    .section-card {
      background: var(--bg-card);
      border-radius: 28px;
      padding: 28px;
      margin-bottom: 32px;
      box-shadow: var(--shadow-sm);
      transition: var(--transition-default);
    }

    .section-card:last-child {
      margin-bottom: 0;
    }

    .section-title {
      font-size: 1.25rem;
      font-weight: 700;
      color: var(--text-primary);
      display: flex;
      align-items: center;
      gap: 12px;
      margin-bottom: 24px;
      padding-bottom: 12px;
      border-bottom: 2px solid var(--border-light);
    }

    /* Form Layout */
    .form-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
      gap: 20px;
    }

    .input-group {
      margin-bottom: 8px;
    }

    .input-group label {
      display: block;
      font-size: 0.8rem;
      font-weight: 600;
      color: var(--text-secondary);
      margin-bottom: 8px;
    }

    .input-group input,
    .input-group select,
    .input-group textarea {
      width: 100%;
      padding: 12px 16px;
      background: var(--bg-primary);
      border: 1.5px solid var(--border-color);
      border-radius: 20px;
      font-size: 0.9rem;
      color: var(--text-primary);
      transition: var(--transition-default);
    }

    .input-group input:focus,
    .input-group textarea:focus {
      outline: none;
      border-color: var(--gradient-end);
      background: var(--bg-card);
    }

    .upload-btn {
      background: linear-gradient(135deg, var(--gradient-start), var(--gradient-end));
      color: white;
      border: none;
      padding: 14px 28px;
      border-radius: 40px;
      font-weight: 600;
      font-size: 0.9rem;
      display: inline-flex;
      align-items: center;
      gap: 10px;
      cursor: pointer;
      margin-top: 20px;
      transition: var(--transition-default);
    }

    .upload-btn:hover {
      transform: translateY(-2px);
      box-shadow: var(--shadow-md);
    }

    /* Results Table */
    .results-card {
      background: var(--bg-card);
      border-radius: 28px;
      padding: 0;
      overflow: hidden;
      margin-bottom: 32px;
    }
    
    .results-card .section-title {
      padding: 24px 28px 0 28px;
      margin-bottom: 0;
    }
    
    .table-wrapper {
      overflow-x: auto;
      padding: 0 0 24px 0;
    }

    .desktop-table {
      width: 100%;
      border-collapse: collapse;
      min-width: 800px;
    }

    .desktop-table th {
      text-align: right;
      padding: 16px 16px;
      color: var(--text-secondary);
      font-weight: 600;
      font-size: 0.85rem;
      border-bottom: 2px solid var(--border-light);
      background: var(--table-header-bg);
    }

    .desktop-table td {
      padding: 16px;
      color: var(--text-primary);
      font-size: 0.85rem;
      border-bottom: 1px solid var(--border-light);
    }

    .desktop-table tr:hover {
      background: var(--bg-hover);
    }

    /* Action Buttons */
    .action-group {
      display: flex;
      gap: 8px;
      flex-wrap: wrap;
    }

    .btn-mini {
      padding: 6px 12px;
      border-radius: 40px;
      border: none;
      font-weight: 600;
      font-size: 0.7rem;
      cursor: pointer;
      display: inline-flex;
      align-items: center;
      gap: 6px;
      transition: var(--transition-default);
    }

    .btn-view {
      background: var(--gradient-end);
      color: white;
      text-decoration: none;
    }

    .btn-delete {
      background: var(--danger-bg);
      color: white;
    }

    .btn-notify {
      background: var(--success-bg);
      color: white;
    }

    .btn-telegram {
      background: var(--telegram-bg);
      color: white;
    }

    .btn-email {
      background: var(--email-bg);
      color: white;
    }

    .btn-mini:hover {
      transform: translateY(-2px);
      filter: brightness(1.05);
    }

    /* Mobile Cards for Results */
    .mobile-cards {
      display: none;
      padding: 20px;
    }

    .result-mobile-card {
      background: var(--bg-primary);
      border-radius: 20px;
      padding: 18px;
      margin-bottom: 16px;
      border: 1px solid var(--border-light);
    }

    /* Telegram & Email Tables */
    .telegram-numbers-table,
    .email-logs-table {
      width: 100%;
      border-collapse: collapse;
      margin-top: 16px;
    }

    .telegram-numbers-table th,
    .telegram-numbers-table td,
    .email-logs-table th,
    .email-logs-table td {
      padding: 12px;
      text-align: right;
      border-bottom: 1px solid var(--border-light);
      color: var(--text-primary);
    }

    hr {
      margin: 28px 0;
      border-color: var(--border-light);
    }

    /* Toast Notification */
    .toast-notify {
      position: fixed;
      bottom: 30px;
      left: 30px;
      background: var(--text-primary);
      color: white;
      padding: 12px 20px;
      border-radius: 60px;
      display: flex;
      align-items: center;
      gap: 12px;
      z-index: 1000;
      box-shadow: var(--shadow-md);
      animation: slideUp 0.3s ease;
    }

    .toast-success {
      border-right: 4px solid var(--success-bg);
    }

    .toast-error {
      border-right: 4px solid var(--danger-bg);
    }

    @keyframes slideUp {
      from {
        opacity: 0;
        transform: translateY(20px);
      }
      to {
        opacity: 1;
        transform: translateY(0);
      }
    }

    .empty-state {
      text-align: center;
      padding: 60px 20px;
      color: var(--text-muted);
    }

    /* Tab Content Visibility */
    .tab-content {
      display: none;
    }

    .tab-content.active {
      display: block;
    }

    /* ========================================
       RESPONSIVE DESIGN
    ======================================== */
    @media (max-width: 1024px) {
      .main-content {
        padding: 20px;
      }
      
      .stats-grid {
        gap: 16px;
      }
    }

    @media (max-width: 768px) {
      .dashboard-container {
        grid-template-columns: 1fr;
      }
      
      .sidebar {
        position: fixed;
        top: 0;
        right: -100%;
        width: 280px;
        height: 100vh;
        transition: right 0.3s ease;
        z-index: 200;
        box-shadow: var(--shadow-md);
      }
      
      .sidebar.open {
        right: 0;
      }
      
      .mobile-menu-btn {
        display: flex;
        align-items: center;
        justify-content: center;
      }
      
      .main-content {
        margin-right: 0;
        padding: 16px;
      }
      
      .desktop-table {
        display: none;
      }
      
      .mobile-cards {
        display: block;
      }
      
      .stats-grid {
        grid-template-columns: 1fr;
        gap: 12px;
      }
      
      .stat-card {
        padding: 16px;
      }
      
      .section-card {
        padding: 20px;
      }
      
      .form-grid {
        grid-template-columns: 1fr;
        gap: 16px;
      }
      
      .header-bar {
        flex-direction: column;
        align-items: stretch;
        text-align: center;
      }
      
      .header-actions {
        justify-content: center;
      }
      
      .user-badge {
        display: none;
      }
    }
    
    @media (max-width: 480px) {
      .main-content {
        padding: 12px;
      }
      
      .section-title {
        font-size: 1.1rem;
      }
      
      .stat-info h3 {
        font-size: 1.6rem;
      }
    }
  </style>
</head>
<body>
<div class="dashboard-container">
  <!-- Mobile Menu Button -->
  <button class="mobile-menu-btn" id="mobileMenuBtn">
    <i class="fas fa-bars"></i>
  </button>

  <!-- Sidebar -->
  <aside class="sidebar" id="sidebar">
    <div>
      <div class="sidebar-header">
        <h2><i class="fas fa-microscope"></i> معمل التحاليل</h2>
      </div>
      <nav class="sidebar-nav">
        <div class="sidebar-item active" data-tab="tab-lab">
          <i class="fas fa-flask"></i>
          <span>رفع التحاليل</span>
        </div>
        <div class="sidebar-item" data-tab="tab-telegram">
          <i class="fab fa-telegram"></i>
          <span>التيليجرام</span>
        </div>
        <div class="sidebar-item" data-tab="tab-smtp">
          <i class="fas fa-envelope"></i>
          <span>SMTP / الإيميلات</span>
        </div>
      </nav>
    </div>
    <div class="sidebar-footer">
      <a href="/admin/logout" class="logout-sidebar">
        <i class="fas fa-sign-out-alt"></i>
        <span>خروج</span>
      </a>
      <div style="margin-top: 20px; padding-top: 15px; border-top: 1px solid var(--border-color);">
        <a href="/privacy" style="color: var(--text-muted); text-decoration: none; font-size: 0.75rem;">
          <i class="fas fa-shield-alt"></i> سياسة الخصوصية
        </a>
      </div>
    </div>
  </aside>

  <!-- Main Content -->
  <main class="main-content">
    <div class="header-bar">
      <div class="logo">
        <h1><i class="fas fa-microscope"></i> لوحة التحكم</h1>
      </div>
      <div class="header-actions">
        <button class="theme-toggle" id="themeToggle">
          <i class="fas fa-moon"></i>
          <span>الوضع المظلم</span>
        </button>
        <div class="user-info">
          <span class="user-badge"><i class="fas fa-user-md"></i> الدكتور جون</span>
          <a href="/admin/logout" class="logout-link"><i class="fas fa-sign-out-alt"></i> خروج</a>
        </div>
      </div>
    </div>

    <!-- Stats Cards Section -->
    <div class="stats-grid">
      <div class="stat-card">
        <div class="stat-icon"><i class="fas fa-file-alt"></i></div>
        <div class="stat-info">
          <h3 id="totalResultsCount"><%= results.length %></h3>
          <p>إجمالي النتائج</p>
        </div>
      </div>
      <div class="stat-card">
        <div class="stat-icon"><i class="fab fa-telegram"></i></div>
        <div class="stat-info">
          <h3 id="telegramCount"><%= telegramNumbers ? telegramNumbers.length : 0 %></h3>
          <p>أرقام تليجرام</p>
        </div>
      </div>
      <div class="stat-card">
        <div class="stat-icon"><i class="fas fa-envelope"></i></div>
        <div class="stat-info">
          <h3 id="emailCount">0</h3>
          <p>إيميلات مرسلة</p>
        </div>
      </div>
    </div>

    <!-- Tab Content: رفع التحاليل -->
    <div id="tab-lab" class="tab-content active">
      <!-- Upload Section -->
      <div class="section-card">
        <div class="section-title"><i class="fas fa-cloud-upload-alt"></i> رفع نتيجة تحليل جديدة</div>
        <form action="/admin/upload" method="POST" enctype="multipart/form-data" id="uploadForm">
          <div class="form-grid">
            <div class="input-group"><label><i class="fas fa-user"></i> اسم المريض</label><input type="text" name="name" placeholder="الاسم الكامل" required></div>
            <div class="input-group"><label><i class="fas fa-flask"></i> نوع التحليل</label><input type="text" name="test" placeholder="مثال: صورة دم" required></div>
            <div class="input-group"><label><i class="fas fa-phone"></i> رقم الهاتف</label><input type="tel" name="phone" placeholder="10 أو 11 رقم" pattern="[0-9]{10,11}" required></div>
            <div class="input-group"><label><i class="fas fa-envelope"></i> البريد الإلكتروني</label><input type="email" name="email" placeholder="patient@example.com" required></div>
            <div class="input-group"><label><i class="fas fa-file-pdf"></i> ملف النتيجة</label><input type="file" name="pdf" accept=".pdf,.jpg,.jpeg,.png,.doc,.docx" required></div>
            <div class="input-group"><label><i class="fas fa-sticky-note"></i> ملاحظات</label><textarea name="notes" rows="2" placeholder="أي ملاحظات خاصة..."></textarea></div>
          </div>
          <button type="submit" class="upload-btn"><i class="fas fa-cloud-upload-alt"></i> رفع النتيجة</button>
        </form>
      </div>

      <!-- Results Database Section -->
      <div class="results-card">
        <div class="section-title"><i class="fas fa-database"></i> قاعدة البيانات</div>
        <div class="table-wrapper">
          <% if (results.length > 0) { %>
            <table class="desktop-table">
              <thead>
                <tr><th>المريض</th><th>نوع التحليل</th><th>الهاتف</th><th>البريد</th><th>الملف</th><th>التاريخ</th><th>الإجراءات</th></tr>
              </thead>
              <tbody>
                <% results.forEach((r) => { %>
                  <tr id="row-<%= r.id %>">
                    <td><strong><%= r.name %></strong></td>
                    <td><%= r.test %></td>
                    <td><%= r.phone %></td>
                    <td><%= r.email %></td>
                    <td><a href="/view/<%= r.id %>" target="_blank" class="btn-mini btn-view"><i class="fas fa-eye"></i> عرض</a></td>
                    <td><%= r.date %></td>
                    <td><div class="action-group">
                      <button class="btn-mini btn-delete" onclick="deleteResult('<%= r.id %>', '<%= r.name %>')"><i class="fas fa-trash"></i> حذف</button>
                      <button class="btn-mini btn-notify" onclick="sendEmailNotification('<%= r.id %>', '<%= r.name %>', '<%= r.email %>')"><i class="fas fa-envelope"></i> إيميل</button>
                      <button class="btn-mini btn-telegram" onclick="sendTelegramToPatient('<%= r.id %>', '<%= r.name %>', '<%= r.phone %>')"><i class="fab fa-telegram"></i> تليجرام</button>
                    </div></td>
                  </tr>
                <% }) %>
              </tbody>
            </table>
            <div class="mobile-cards">
              <% results.forEach((r) => { %>
                <div class="result-mobile-card">
                  <div><strong><%= r.name %></strong> - <%= r.test %></div>
                  <div>📞 <%= r.phone %></div>
                  <div>📧 <%= r.email %></div>
                  <div class="action-group" style="margin-top: 12px;">
                    <a href="/view/<%= r.id %>" target="_blank" class="btn-mini btn-view">عرض</a>
                    <button class="btn-mini btn-delete" onclick="deleteResult('<%= r.id %>', '<%= r.name %>')">حذف</button>
                    <button class="btn-mini btn-telegram" onclick="sendTelegramToPatient('<%= r.id %>', '<%= r.name %>', '<%= r.phone %>')">تليجرام</button>
                  </div>
                </div>
              <% }) %>
            </div>
          <% } else { %>
            <div class="empty-state"><i class="fas fa-folder-open" style="font-size: 3rem; margin-bottom: 16px; display: block;"></i><p>لا توجد نتائج مسجلة</p></div>
          <% } %>
        </div>
      </div>
    </div>

    <!-- Tab Content: التيليجرام -->
    <div id="tab-telegram" class="tab-content">
      <div class="section-card">
        <div class="section-title"><i class="fab fa-telegram"></i> إرسال إشعارات عبر التيليجرام</div>
        <div style="margin-bottom: 28px;">
          <h4 style="margin-bottom: 16px;"><i class="fas fa-paper-plane"></i> إرسال رسالة لرقم معين</h4>
          <div class="form-grid">
            <div class="input-group"><label>رقم الهاتف</label><input type="tel" id="telegramPhone" placeholder="مثال: 01234567890"></div>
            <div class="input-group"><label>نص الرسالة</label><textarea id="telegramMessage" rows="3"></textarea></div>
          </div>
          <button id="sendTelegramBtn" class="upload-btn" style="background: #0088cc;"><i class="fab fa-telegram"></i> إرسال عبر تليجرام</button>
          <div id="telegramResult" style="margin-top: 16px;"></div>
        </div>
        <hr>
        <div>
          <h4 style="margin-bottom: 16px;"><i class="fas fa-list"></i> الأرقام المسجلة في البوت</h4>
          <div style="display: flex; gap: 12px; margin-bottom: 20px; flex-wrap: wrap;">
            <input type="tel" id="newTelegramNumber" placeholder="رقم جديد" style="padding: 12px; border-radius: 40px; border: 1px solid var(--border-color); flex:1; background: var(--bg-primary); color: var(--text-primary);">
            <button id="addTelegramNumberBtn" class="btn-mini" style="background:var(--gradient-end);color:white; padding: 8px 20px;">إضافة</button>
            <button id="refreshTelegramNumbers" class="btn-mini" style="background:var(--text-muted);color:white; padding: 8px 20px;">تحديث</button>
          </div>
          <div class="table-wrapper">
            <table class="telegram-numbers-table">
              <thead><tr><th>الرقم</th><th>التاريخ</th><th></th></tr></thead>
              <tbody id="telegramNumbersBody">
                <% if (telegramNumbers && telegramNumbers.length) { %>
                  <% telegramNumbers.forEach(num => { %>
                    <tr id="tg-row-<%= num.phone %>"><td><%= num.phone %></td><td><%= num.createdAt || '—' %></td><td><button class="btn-mini btn-delete" onclick="deleteTelegramNumber('<%= num.phone %>')">حذف</button><\/td></tr>
                  <% }) %>
                <% } else { %>
                  <tr><td colspan="3" style="text-align:center;">لا توجد أرقام<\/td></tr>
                <% } %>
              </tbody>
            </table>
          </div>
        </div>
      </div>
    </div>

    <!-- Tab Content: SMTP / الإيميلات -->
    <div id="tab-smtp" class="tab-content">
      <div class="section-card">
        <div class="section-title"><i class="fas fa-paper-plane"></i> إرسال إيميل يدوي</div>
        <div class="form-grid">
          <div class="input-group"><label><i class="fas fa-user"></i> اسم المستلم</label><input type="text" id="manualEmailName" placeholder="الاسم"></div>
          <div class="input-group"><label><i class="fas fa-envelope"></i> البريد الإلكتروني</label><input type="email" id="manualEmailAddress" placeholder="example@domain.com"></div>
          <div class="input-group"><label><i class="fas fa-tag"></i> الموضوع</label><input type="text" id="manualEmailSubject" placeholder="موضوع الرسالة"></div>
          <div class="input-group" style="grid-column: span 2;"><label><i class="fas fa-comment"></i> محتوى الرسالة</label><textarea id="manualEmailBody" rows="5" placeholder="اكتب محتوى الإيميل هنا..."></textarea></div>
        </div>
        <button id="sendManualEmailBtn" class="upload-btn" style="background: #ea4335;"><i class="fas fa-envelope"></i> إرسال الإيميل</button>
        <div id="manualEmailResult" style="margin-top: 16px;"></div>
      </div>

      <div class="section-card">
        <div class="section-title"><i class="fas fa-users"></i> إرسال إيميل جماعي لقائمة مخصصة</div>
        <div style="margin-bottom: 24px;">
          <h4 style="margin-bottom: 16px;"><i class="fas fa-plus-circle"></i> إضافة مستلمين</h4>
          <div class="form-grid">
            <div class="input-group"><label>اسم المستلم</label><input type="text" id="bulkRecipientName" placeholder="الاسم"></div>
            <div class="input-group"><label>البريد الإلكتروني</label><input type="email" id="bulkRecipientEmail" placeholder="email@example.com"></div>
          </div>
          <button id="addRecipientBtn" class="btn-mini" style="background:var(--gradient-end);color:white; margin-top: 12px; padding: 10px 20px;"><i class="fas fa-plus"></i> إضافة للمستلمين</button>
        </div>
        <div style="margin-bottom: 24px;">
          <h4><i class="fas fa-list"></i> قائمة المستلمين (<span id="recipientCount">0</span>)</h4>
          <div id="recipientsList" style="background: var(--bg-primary); border-radius: 20px; padding: 16px; max-height: 250px; overflow-y: auto; margin-top: 12px;">
            <div style="text-align: center; color: var(--text-muted);">لا يوجد مستلمين، أضف مستلمين أولاً</div>
          </div>
          <button id="clearRecipientsBtn" class="btn-mini" style="background:var(--danger-bg);color:white; margin-top: 16px; padding: 8px 20px;"><i class="fas fa-trash"></i> حذف الكل</button>
        </div>
        <hr>
        <div>
          <h4 style="margin-bottom: 16px;"><i class="fas fa-envelope-open-text"></i> بيانات الإيميل</h4>
          <div class="input-group"><label><i class="fas fa-tag"></i> الموضوع</label><input type="text" id="bulkEmailSubject" placeholder="موضوع الرسالة"></div>
          <div class="input-group"><label><i class="fas fa-comment"></i> محتوى الرسالة</label><textarea id="bulkEmailBody" rows="5" placeholder="محتوى الإيميل لجميع المستلمين..."></textarea></div>
          <button id="sendBulkEmailBtn" class="upload-btn" style="background: #ea4335;"><i class="fas fa-paper-plane"></i> إرسال للجميع</button>
          <div id="bulkEmailResult" style="margin-top: 16px;"></div>
        </div>
      </div>

      <div class="section-card">
        <div class="section-title"><i class="fas fa-clipboard-list"></i> قوالب سريعة</div>
        <div style="display: flex; flex-wrap: wrap; gap: 12px;">
          <button class="btn-mini" style="background:var(--gradient-end);color:white; padding: 8px 16px;" onclick="loadTemplate('welcome')">ترحيب</button>
          <button class="btn-mini" style="background:var(--gradient-end);color:white; padding: 8px 16px;" onclick="loadTemplate('reminder')">تذكير</button>
          <button class="btn-mini" style="background:var(--gradient-end);color:white; padding: 8px 16px;" onclick="loadTemplate('thanks')">شكر</button>
          <button class="btn-mini" style="background:var(--gradient-end);color:white; padding: 8px 16px;" onclick="loadTemplate('result_ready')">نتيجة جاهزة</button>
        </div>
      </div>

      <div class="section-card">
        <div class="section-title"><i class="fas fa-history"></i> سجل الإيميلات المرسلة</div>
        <button id="refreshEmailLogs" class="btn-mini" style="background:var(--text-muted);color:white; margin-bottom: 20px; padding: 8px 20px;">تحديث</button>
        <div class="table-wrapper">
          <table class="email-logs-table">
            <thead>
              <tr><th>إلى</th><th>الموضوع</th><th>التاريخ</th><th>الحالة</th><th>الإجراءات</th></tr>
            </thead>
            <tbody id="emailLogsBody">
              <tr><td colspan="5" style="text-align:center;">جاري التحميل...<\/td></tr>
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </main>
</div>

<!-- Include WhatsApp Button -->
<%- include('../partials/whatsapp-button.ejs') %>

<script>
  // ========================================
  // THEME MANAGEMENT
  // ========================================
  (function() {
    const themeToggle = document.getElementById('themeToggle');
    const html = document.documentElement;
    
    let currentTheme = localStorage.getItem('theme') || 'light';
    
    function setTheme(theme) {
      if (theme === 'dark') {
        html.setAttribute('data-theme', 'dark');
        if (themeToggle) {
          themeToggle.innerHTML = '<i class="fas fa-sun"></i><span>الوضع الفاتح</span>';
        }
        localStorage.setItem('theme', 'dark');
      } else {
        html.removeAttribute('data-theme');
        if (themeToggle) {
          themeToggle.innerHTML = '<i class="fas fa-moon"></i><span>الوضع المظلم</span>';
        }
        localStorage.setItem('theme', 'light');
      }
      currentTheme = theme;
    }
    
    setTheme(currentTheme);
    
    if (themeToggle) {
      themeToggle.addEventListener('click', () => {
        const newTheme = currentTheme === 'light' ? 'dark' : 'light';
        setTheme(newTheme);
      });
    }
  })();

  // ========================================
  // SIDEBAR / DRAWER FUNCTIONALITY
  // ========================================
  const mobileMenuBtn = document.getElementById('mobileMenuBtn');
  const sidebar = document.getElementById('sidebar');

  function closeDrawer() {
    sidebar?.classList.remove('open');
  }

  function openDrawer() {
    sidebar?.classList.add('open');
  }

  if (mobileMenuBtn) {
    mobileMenuBtn.addEventListener('click', openDrawer);
  }

  // Close sidebar when clicking outside on mobile
  document.addEventListener('click', (e) => {
    if (window.innerWidth <= 768) {
      if (sidebar && sidebar.classList.contains('open') && !sidebar.contains(e.target) && e.target !== mobileMenuBtn) {
        closeDrawer();
      }
    }
  });

  // ========================================
  // SIDEBAR NAVIGATION (TABS)
  // ========================================
  const sidebarItems = document.querySelectorAll('.sidebar-item');
  const tabContents = document.querySelectorAll('.tab-content');

  function switchTab(tabId) {
    tabContents.forEach(content => {
      content.classList.remove('active');
    });
    const activeTab = document.getElementById(tabId);
    if (activeTab) activeTab.classList.add('active');
    
    sidebarItems.forEach(item => {
      item.classList.remove('active');
      if (item.getAttribute('data-tab') === tabId) {
        item.classList.add('active');
      }
    });
    
    closeDrawer();
  }

  sidebarItems.forEach(item => {
    item.addEventListener('click', () => {
      const tabId = item.getAttribute('data-tab');
      if (tabId) switchTab(tabId);
    });
  });

  // ========================================
  // HELPER FUNCTIONS
  // ========================================
  function showNotification(message, type = 'success') {
    const existing = document.querySelector('.toast-notify');
    if(existing) existing.remove();
    const toast = document.createElement('div');
    toast.className = `toast-notify toast-${type}`;
    toast.innerHTML = `${type === 'success' ? '✅' : '❌'} <span>${message}</span> <i class="fas fa-times-circle" style="margin-right: auto; cursor: pointer;" onclick="this.parentElement.remove()"></i>`;
    document.body.appendChild(toast);
    setTimeout(() => toast.remove(), 4000);
  }

  function escapeHtml(str) {
    if (!str) return '';
    return str.replace(/[&<>]/g, function(m) {
      if (m === '&') return '&amp;';
      if (m === '<') return '&lt;';
      if (m === '>') return '&gt;';
      return m;
    });
  }

  // ========================================
  // DELETE RESULT
  // ========================================
  async function deleteResult(id, patientName) {
    if (!confirm(`⚠️ حذف نتيجة ${patientName}؟`)) return;
    try {
      const res = await fetch('/admin/delete', { 
        method: 'POST', 
        credentials: 'include',
        headers: { 'Content-Type': 'application/x-www-form-urlencoded' }, 
        body: `file=${id}` 
      });
      if (res.ok) { showNotification(`✅ حذف ${patientName}`); document.getElementById(`row-${id}`)?.remove(); }
      else throw new Error();
    } catch(e) { showNotification('❌ فشل الحذف', 'error'); }
  }

  // ========================================
  // SEND EMAIL NOTIFICATION
  // ========================================
  async function sendEmailNotification(id, patientName, email) {
    if (!confirm(`📧 إرسال إيميل للمريض ${patientName}؟`)) return;
    showNotification(`📧 جاري إرسال الإيميل إلى ${patientName}...`);
    try {
      const res = await fetch('/api/send-email', { 
        method: 'POST', 
        credentials: 'include',
        headers: { 'Content-Type': 'application/json' }, 
        body: JSON.stringify({ to: email, name: patientName, resultId: id }) 
      });
      const data = await res.json();
      if (res.ok) showNotification(`✅ تم إرسال الإيميل إلى ${patientName}`);
      else showNotification(`❌ فشل: ${data.error}`, 'error');
    } catch(e) { showNotification('❌ خطأ', 'error'); }
  }

  // ========================================
  // SEND TELEGRAM TO PATIENT
  // ========================================
  async function sendTelegramToPatient(id, patientName, phone) {
    if (!confirm(`📱 إرسال تليجرام للمريض ${patientName}؟`)) return;
    const btn = event?.target; const original = btn?.innerHTML;
    if(btn) { btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i>'; btn.disabled = true; }
    try {
      const res = await fetch('/api/notify-patient', { 
        method: 'POST', 
        credentials: 'include',
        headers: { 'Content-Type': 'application/json' }, 
        body: JSON.stringify({ resultId: id }) 
      });
      const data = await res.json();
      if (res.ok && data.ok) showNotification(`✅ تم الإرسال لـ ${data.delivered} جهاز`);
      else showNotification(`❌ ${data.error || 'فشل'}`, 'error');
    } catch(e) { showNotification('❌ خطأ', 'error'); }
    if(btn) { btn.innerHTML = original; btn.disabled = false; }
  }

  // ========================================
  // TELEGRAM FUNCTIONS
  // ========================================
  document.getElementById('sendTelegramBtn')?.addEventListener('click', async () => {
    const phone = document.getElementById('telegramPhone')?.value.trim();
    const message = document.getElementById('telegramMessage')?.value.trim();
    const resultDiv = document.getElementById('telegramResult');
    if (!phone || !message) { showNotification('⚠️ املأ الحقول', 'error'); return; }
    resultDiv.innerHTML = '<span style="color:#0088cc;">⏳ جاري...</span>';
    try {
      const res = await fetch('/api/send-telegram', { 
        method: 'POST', 
        credentials: 'include',
        headers: { 'Content-Type': 'application/json' }, 
        body: JSON.stringify({ phone, message }) 
      });
      const data = await res.json();
      if (res.ok && data.ok) { resultDiv.innerHTML = `<span style="color:#10b981;">✅ تم: وصل لـ ${data.delivered} جهاز</span>`; showNotification(`✅ تم الإرسال لـ ${data.delivered}`); }
      else { resultDiv.innerHTML = `<span style="color:#dc2626;">❌ ${data.error}</span>`; showNotification(data.error, 'error'); }
    } catch(e) { resultDiv.innerHTML = '<span style="color:#dc2626;">❌ خطأ</span>'; showNotification('خطأ', 'error'); }
  });

  document.getElementById('addTelegramNumberBtn')?.addEventListener('click', async () => {
    const phone = document.getElementById('newTelegramNumber')?.value.trim();
    if (!phone) { showNotification('⚠️ أدخل رقم', 'error'); return; }
    try {
      const res = await fetch('/api/numbers', { 
        method: 'POST', 
        credentials: 'include',
        headers: { 'Content-Type': 'application/json' }, 
        body: JSON.stringify({ phone }) 
      });
      if (res.ok) { showNotification(`✅ تم إضافة ${phone}`); document.getElementById('newTelegramNumber').value = ''; loadTelegramNumbers(); }
      else showNotification('فشل', 'error');
    } catch(e) { showNotification('خطأ', 'error'); }
  });

  window.deleteTelegramNumber = async (phone) => {
    if (!confirm(`حذف ${phone}؟`)) return;
    try {
      const res = await fetch(`/api/numbers/${encodeURIComponent(phone)}`, { 
        method: 'DELETE',
        credentials: 'include'
      });
      if (res.ok) { showNotification(`✅ حذف ${phone}`); document.getElementById(`tg-row-${phone}`)?.remove(); }
      else showNotification('فشل', 'error');
    } catch(e) { showNotification('خطأ', 'error'); }
  };

  async function loadTelegramNumbers() {
    try {
      const res = await fetch('/api/numbers', { credentials: 'include' }); 
      const data = await res.json();
      const items = data.items || []; const tbody = document.getElementById('telegramNumbersBody');
      if(tbody) tbody.innerHTML = items.length ? items.map(i => `<tr id="tg-row-${i.phone}"><td>${i.phone}<\/td><td>${i.createdAt || '—'}<\/td><td><button class="btn-mini btn-delete" onclick="deleteTelegramNumber('${i.phone}')">حذف</button><\/td></tr>`).join('') : '<tr><td colspan="3" style="text-align:center;">لا توجد أرقام<\/td><\/tr>';
      document.getElementById('telegramCount').innerText = items.length;
    } catch(e) { console.error(e); }
  }
  document.getElementById('refreshTelegramNumbers')?.addEventListener('click', loadTelegramNumbers);

  // ========================================
  // SMTP FUNCTIONS
  // ========================================
  let recipientsList = [];
  
  function updateRecipientsDisplay() {
    const container = document.getElementById('recipientsList');
    const countSpan = document.getElementById('recipientCount');
    if (!container) return;
    
    if (recipientsList.length === 0) {
      container.innerHTML = '<div style="text-align: center; color: var(--text-muted);">لا يوجد مستلمين، أضف مستلمين أولاً</div>';
      if (countSpan) countSpan.innerText = '0';
      return;
    }
    
    container.innerHTML = recipientsList.map((r, idx) => `
      <div style="display: flex; justify-content: space-between; align-items: center; padding: 12px; border-bottom: 1px solid var(--border-color);">
        <div><strong>${escapeHtml(r.name)}</strong> - ${escapeHtml(r.email)}</div>
        <button class="btn-mini" style="background:var(--danger-bg);color:white;padding:4px 12px;" onclick="removeRecipient(${idx})">حذف</button>
      </div>
    `).join('');
    if (countSpan) countSpan.innerText = recipientsList.length;
  }
  
  window.removeRecipient = function(idx) {
    recipientsList.splice(idx, 1);
    updateRecipientsDisplay();
  };
  
  document.getElementById('addRecipientBtn')?.addEventListener('click', () => {
    const name = document.getElementById('bulkRecipientName')?.value.trim();
    const email = document.getElementById('bulkRecipientEmail')?.value.trim();
    
    if (!name) { showNotification('⚠️ أدخل اسم المستلم', 'error'); return; }
    if (!email) { showNotification('⚠️ أدخل البريد الإلكتروني', 'error'); return; }
    if (!/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) { showNotification('⚠️ البريد الإلكتروني غير صحيح', 'error'); return; }
    
    recipientsList.push({ name, email });
    updateRecipientsDisplay();
    
    document.getElementById('bulkRecipientName').value = '';
    document.getElementById('bulkRecipientEmail').value = '';
    showNotification(`✅ تم إضافة ${name}`, 'success');
  });
  
  document.getElementById('clearRecipientsBtn')?.addEventListener('click', () => {
    if (recipientsList.length > 0 && confirm('هل تريد حذف جميع المستلمين؟')) {
      recipientsList = [];
      updateRecipientsDisplay();
      showNotification('✅ تم حذف جميع المستلمين', 'success');
    }
  });
  
  document.getElementById('sendManualEmailBtn')?.addEventListener('click', async () => {
    const name = document.getElementById('manualEmailName')?.value.trim();
    const to = document.getElementById('manualEmailAddress')?.value.trim();
    const subject = document.getElementById('manualEmailSubject')?.value.trim();
    const body = document.getElementById('manualEmailBody')?.value.trim();
    const resultDiv = document.getElementById('manualEmailResult');
    
    if (!name || !to || !subject || !body) { showNotification('⚠️ املأ جميع الحقول', 'error'); return; }
    resultDiv.innerHTML = '<span style="color:#ea4335;">⏳ جاري الإرسال...</span>';
    
    try {
      const res = await fetch('/api/send-email-manual', { 
        method: 'POST', 
        credentials: 'include',
        headers: { 'Content-Type': 'application/json' }, 
        body: JSON.stringify({ to, name, subject, body }) 
      });
      const data = await res.json();
      if (res.ok) { 
        resultDiv.innerHTML = '<span style="color:#10b981;">✅ تم الإرسال بنجاح</span>'; 
        showNotification('✅ تم إرسال الإيميل');
        document.getElementById('manualEmailName').value = '';
        document.getElementById('manualEmailAddress').value = '';
        document.getElementById('manualEmailSubject').value = '';
        document.getElementById('manualEmailBody').value = '';
        loadEmailLogs();
      } else { 
        resultDiv.innerHTML = `<span style="color:#dc2626;">❌ ${data.error}</span>`; 
        showNotification(data.error, 'error');
      }
    } catch(e) { 
      resultDiv.innerHTML = '<span style="color:#dc2626;">❌ خطأ في الاتصال</span>'; 
      showNotification('خطأ في الاتصال', 'error');
    }
  });

  document.getElementById('sendBulkEmailBtn')?.addEventListener('click', async () => {
    const subject = document.getElementById('bulkEmailSubject')?.value.trim();
    const body = document.getElementById('bulkEmailBody')?.value.trim();
    const resultDiv = document.getElementById('bulkEmailResult');
    
    if (recipientsList.length === 0) { showNotification('⚠️ أضف مستلمين أولاً', 'error'); return; }
    if (!subject) { showNotification('⚠️ أدخل الموضوع', 'error'); return; }
    if (!body) { showNotification('⚠️ أدخل محتوى الرسالة', 'error'); return; }
    
    resultDiv.innerHTML = '<span style="color:#ea4335;">⏳ جاري الإرسال للجميع...</span>';
    
    try {
      const res = await fetch('/api/send-bulk-email', { 
        method: 'POST', 
        credentials: 'include',
        headers: { 'Content-Type': 'application/json' }, 
        body: JSON.stringify({ recipients: recipientsList, subject, body }) 
      });
      
      if (res.status === 401) {
        resultDiv.innerHTML = '<span style="color:#dc2626;">❌ انتهت الجلسة، يرجى إعادة تحميل الصفحة</span>';
        showNotification('❌ انتهت الجلسة، يرجى إعادة تحميل الصفحة', 'error');
        return;
      }
      
      const data = await res.json();
      if (res.ok) { 
        resultDiv.innerHTML = `<span style="color:#10b981;">✅ تم الإرسال إلى ${data.sent} من ${data.total} مستلم</span>`; 
        showNotification(`✅ تم إرسال ${data.sent} إيميل`);
        document.getElementById('bulkEmailSubject').value = '';
        document.getElementById('bulkEmailBody').value = '';
        loadEmailLogs();
      } else { 
        resultDiv.innerHTML = `<span style="color:#dc2626;">❌ ${data.error}</span>`; 
        showNotification(data.error, 'error');
      }
    } catch(e) { 
      resultDiv.innerHTML = '<span style="color:#dc2626;">❌ خطأ</span>'; 
      showNotification('خطأ', 'error');
    }
  });

  // ========================================
  // DELETE EMAIL LOG - FIXED VERSION
  // ========================================
  window.deleteEmailLog = async (logId) => {
    // التحقق من وجود معرف صالح
    if (!logId || logId === 'undefined' || logId === 'null') {
      showNotification('❌ معرف الإيميل غير صالح', 'error');
      return;
    }
    
    if (!confirm('⚠️ هل تريد حذف هذا الإيميل من السجل؟')) return;
    
    try {
      const res = await fetch(`/api/email-logs/${logId}`, { 
        method: 'DELETE',
        credentials: 'include',
        headers: {
          'Content-Type': 'application/json'
        }
      });
      
      const data = await res.json();
      
      if (res.ok) {
        showNotification('✅ تم حذف الإيميل من السجل', 'success');
        loadEmailLogs(); // إعادة تحميل السجل
      } else {
        showNotification(`❌ فشل الحذف: ${data.error || 'خطأ غير معروف'}`, 'error');
      }
    } catch(e) {
      console.error('Delete email log error:', e);
      showNotification('❌ خطأ في الاتصال', 'error');
    }
  };

  // ========================================
  // LOAD EMAIL LOGS - FIXED VERSION
  // ========================================
  async function loadEmailLogs() {
    try {
      const res = await fetch('/api/email-logs', { credentials: 'include' });
      const data = await res.json();
      const logs = data.logs || [];
      const tbody = document.getElementById('emailLogsBody');
      if(tbody) {
        if(logs.length > 0) {
          tbody.innerHTML = logs.map(log => {
            // تأكد من وجود log.id
            const logId = log.id || '';
            return `
              <tr>
                <td>${escapeHtml(log.to || '')}</td>
                <td>${escapeHtml(log.subject || '')}</td>
                <td>${log.date ? new Date(log.date).toLocaleString() : '—'}</td>
                <td>${log.status === 'sent' ? '✅ مرسل' : '❌ فشل'}</td>
                <td>
                  <button class="btn-mini btn-delete" onclick="deleteEmailLog('${logId}')">
                    <i class="fas fa-trash"></i> حذف
                  </button>
                </td>
              </tr>
            `;
          }).join('');
        } else {
          tbody.innerHTML = '<tr><td colspan="5" style="text-align:center;">لا توجد إيميلات مرسلة بعد<\/td><\/tr>';
        }
        document.getElementById('emailCount').innerText = logs.length;
      }
    } catch(e) { 
      console.error('Load email logs error:', e);
      const tbody = document.getElementById('emailLogsBody');
      if(tbody) tbody.innerHTML = '<tr><td colspan="5" style="text-align:center;">❌ خطأ في تحميل السجل<\/td><\/tr>';
    }
  }
  
  document.getElementById('refreshEmailLogs')?.addEventListener('click', loadEmailLogs);

  const templates = {
    welcome: { subject: 'مرحباً بك في خدمتنا', body: 'نرحب بك في مركز التحاليل الطبية. يسعدنا خدمتك.' },
    reminder: { subject: 'تذكير بموعد التحليل', body: 'نود تذكيرك بموعد التحليل المحدد. يرجى الحضور في الموعد المحدد.' },
    thanks: { subject: 'شكراً لثقتك', body: 'نشكرك على ثقتك بنا. نحن في خدمتك دائماً.' },
    result_ready: { subject: 'نتيجة التحليل جاهزة', body: 'تم تجهيز نتيجة التحليل الخاصة بك. يمكنك الاطلاع عليها من خلال الرابط المرفق.' }
  };
  
  window.loadTemplate = (type) => {
    const t = templates[type];
    if(t) {
      document.getElementById('manualEmailSubject').value = t.subject;
      document.getElementById('manualEmailBody').value = t.body;
      showNotification(`تم تحميل قالب: ${t.subject}`, 'success');
    }
  };

  // ========================================
  // HEARTBEAT FOR SESSION
  // ========================================
  setInterval(async () => {
    try {
      await fetch('/api/check-session', { credentials: 'include' });
    } catch(e) { console.log('Heartbeat error:', e); }
  }, 60000);

  // ========================================
  // INITIAL LOAD
  // ========================================
  document.addEventListener('DOMContentLoaded', () => {
    loadTelegramNumbers();
    loadEmailLogs();
    const successMsg = localStorage.getItem('uploadSuccess');
    if(successMsg) { showNotification(successMsg, 'success'); localStorage.removeItem('uploadSuccess'); }
    const urlError = new URLSearchParams(window.location.search).get('error');
    if(urlError) { showNotification(`❌ ${decodeURIComponent(urlError)}`, 'error'); window.history.replaceState({}, document.title, window.location.pathname); }
  });
</script>
</body>
</html>
