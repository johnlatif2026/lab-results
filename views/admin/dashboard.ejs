<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
  <title>لوحة التحكم - معمل التحاليل</title>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    body {
      font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', 'Tajawal', sans-serif;
      background: #f0f4f9;
      padding: 20px;
    }

    .dashboard {
      max-width: 1400px;
      margin: 0 auto;
    }

    /* الهيدر */
    .header-bar {
      background: white;
      border-radius: 28px;
      padding: 16px 24px;
      margin-bottom: 24px;
      display: flex;
      flex-wrap: wrap;
      justify-content: space-between;
      align-items: center;
      gap: 15px;
      box-shadow: 0 2px 8px rgba(0, 0, 0, 0.04);
    }

    .logo h1 {
      font-size: 1.3rem;
      color: #1e293b;
      display: flex;
      align-items: center;
      gap: 10px;
    }

    .logo i {
      color: #2a5298;
    }

    .user-info {
      display: flex;
      align-items: center;
      gap: 15px;
    }

    .user-badge {
      background: #f1f5f9;
      padding: 8px 18px;
      border-radius: 40px;
      font-size: 0.85rem;
      color: #334155;
    }

    .logout-link {
      color: #dc2626;
      text-decoration: none;
      font-size: 0.85rem;
      display: flex;
      align-items: center;
      gap: 6px;
    }

    /* كروت الإحصائيات */
    .stats-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
      gap: 16px;
      margin-bottom: 30px;
    }

    .stat-card {
      background: white;
      border-radius: 24px;
      padding: 20px;
      display: flex;
      align-items: center;
      gap: 16px;
      box-shadow: 0 2px 8px rgba(0, 0, 0, 0.04);
    }

    .stat-icon {
      width: 50px;
      height: 50px;
      background: #eef2ff;
      border-radius: 20px;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 24px;
      color: #2a5298;
    }

    .stat-info h3 {
      font-size: 1.8rem;
      font-weight: 700;
      color: #0f172a;
    }

    .stat-info p {
      color: #64748b;
      font-size: 0.8rem;
    }

    /* كارت الرفع */
    .upload-card {
      background: white;
      border-radius: 28px;
      padding: 24px;
      margin-bottom: 30px;
      box-shadow: 0 2px 8px rgba(0, 0, 0, 0.04);
    }

    .section-title {
      font-size: 1.2rem;
      font-weight: 700;
      color: #1e293b;
      display: flex;
      align-items: center;
      gap: 10px;
      margin-bottom: 20px;
      padding-bottom: 12px;
      border-bottom: 2px solid #eef2f6;
    }

    .form-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
      gap: 16px;
    }

    .input-group {
      margin-bottom: 8px;
    }

    .input-group label {
      display: block;
      font-size: 0.8rem;
      font-weight: 600;
      color: #334155;
      margin-bottom: 6px;
    }

    .input-group input,
    .input-group select,
    .input-group textarea {
      width: 100%;
      padding: 12px 14px;
      background: #f8fafc;
      border: 1.5px solid #e2e8f0;
      border-radius: 20px;
      font-size: 0.85rem;
      transition: all 0.2s;
    }

    .input-group input:focus,
    .input-group textarea:focus {
      outline: none;
      border-color: #2a5298;
      background: white;
    }

    .upload-btn {
      background: linear-gradient(135deg, #1e3c72, #2a5298);
      color: white;
      border: none;
      padding: 14px 24px;
      border-radius: 40px;
      font-weight: 600;
      font-size: 0.9rem;
      display: inline-flex;
      align-items: center;
      gap: 10px;
      cursor: pointer;
      margin-top: 16px;
      transition: all 0.2s;
    }

    .upload-btn:hover {
      transform: translateY(-2px);
      box-shadow: 0 4px 12px rgba(42, 82, 152, 0.25);
    }

    /* جدول النتائج - يتحول لكروت في الموبايل */
    .results-card {
      background: white;
      border-radius: 28px;
      padding: 20px;
      overflow-x: auto;
    }

    /* في الشاشات الكبيرة جدول */
    .desktop-table {
      width: 100%;
      border-collapse: collapse;
      min-width: 600px;
    }

    .desktop-table th {
      text-align: right;
      padding: 14px 12px;
      color: #475569;
      font-weight: 600;
      font-size: 0.8rem;
      border-bottom: 2px solid #eef2f6;
    }

    .desktop-table td {
      padding: 14px 12px;
      color: #1e293b;
      font-size: 0.85rem;
      border-bottom: 1px solid #f1f5f9;
    }

    /* في الموبايل - كروت */
    .mobile-cards {
      display: none;
    }

    .result-mobile-card {
      background: #f8fafc;
      border-radius: 20px;
      padding: 16px;
      margin-bottom: 12px;
    }

    .mobile-row {
      display: flex;
      justify-content: space-between;
      margin-bottom: 10px;
      flex-wrap: wrap;
      gap: 8px;
    }

    .mobile-label {
      font-weight: 600;
      color: #475569;
      font-size: 0.75rem;
    }

    .mobile-value {
      color: #0f172a;
      font-size: 0.85rem;
    }

    .action-group {
      display: flex;
      gap: 10px;
      margin-top: 12px;
      flex-wrap: wrap;
    }

    .btn-mini {
      padding: 8px 16px;
      border-radius: 40px;
      border: none;
      font-weight: 600;
      font-size: 0.75rem;
      cursor: pointer;
      display: inline-flex;
      align-items: center;
      gap: 6px;
      transition: all 0.2s;
    }

    .btn-view {
      background: #1e3c72;
      color: white;
      text-decoration: none;
    }

    .btn-delete {
      background: #dc2626;
      color: white;
    }

    .btn-notify {
      background: #10b981;
      color: white;
    }

    .btn-mini:hover {
      transform: translateY(-1px);
      filter: brightness(1.05);
    }

    /* حالة فارغة */
    .empty-state {
      text-align: center;
      padding: 50px 20px;
      color: #94a3b8;
    }

    /* التصميم المتجاوب */
    @media (max-width: 768px) {
      .desktop-table {
        display: none;
      }
      .mobile-cards {
        display: block;
      }
      .stats-grid {
        grid-template-columns: 1fr 1fr;
      }
    }

    @media (max-width: 550px) {
      body {
        padding: 12px;
      }
      .stats-grid {
        grid-template-columns: 1fr;
      }
      .header-bar {
        flex-direction: column;
        text-align: center;
      }
      .form-grid {
        grid-template-columns: 1fr;
      }
    }

    /* توست notifications */
    .toast-notify {
      position: fixed;
      bottom: 20px;
      left: 20px;
      right: 20px;
      background: #1e293b;
      color: white;
      padding: 12px 18px;
      border-radius: 60px;
      display: flex;
      align-items: center;
      gap: 10px;
      z-index: 1000;
      max-width: 400px;
      margin: 0 auto;
      animation: slideUp 0.3s ease;
    }

    .toast-success {
      border-right: 4px solid #10b981;
    }

    .toast-error {
      border-right: 4px solid #dc2626;
    }

    @keyframes slideUp {
      from {
        opacity: 0;
        transform: translateY(20px);
      }
      to {
        opacity: 1;
        transform: translateY(0);
      }
    }
  </style>
</head>
<body>
<div class="dashboard">
  <div class="header-bar">
    <div class="logo">
      <h1><i class="fas fa-microscope"></i> لوحة التحكم</h1>
    </div>
    <div class="user-info">
      <span class="user-badge"><i class="fas fa-user-md"></i> الدكتور جون</span>
      <a href="/admin/logout" class="logout-link"><i class="fas fa-sign-out-alt"></i> خروج</a>
    </div>
  </div>

  <!-- الإحصائيات -->
  <div class="stats-grid">
    <div class="stat-card">
      <div class="stat-icon"><i class="fas fa-file-alt"></i></div>
      <div class="stat-info">
        <h3 id="totalResultsCount"><%= results.length %></h3>
        <p>إجمالي النتائج</p>
      </div>
    </div>
    <div class="stat-card">
      <div class="stat-icon"><i class="fas fa-check-circle"></i></div>
      <div class="stat-info">
        <h3 id="sentCount">0</h3>
        <p>تم الإشعار بها</p>
      </div>
    </div>
    <div class="stat-card">
      <div class="stat-icon"><i class="fas fa-clock"></i></div>
      <div class="stat-info">
        <h3 id="pendingCount">0</h3>
        <p>في انتظار الإشعار</p>
      </div>
    </div>
  </div>

  <!-- رفع نتيجة جديدة -->
  <div class="upload-card">
    <div class="section-title">
      <i class="fas fa-cloud-upload-alt"></i> رفع نتيجة تحليل جديدة
    </div>
    <form action="/admin/upload" method="POST" enctype="multipart/form-data" id="uploadForm">
      <div class="form-grid">
        <div class="input-group">
          <label><i class="fas fa-user"></i> اسم المريض</label>
          <input type="text" id="name" name="name" placeholder="الاسم الكامل" required>
        </div>
        <div class="input-group">
          <label><i class="fas fa-flask"></i> نوع التحليل</label>
          <input type="text" id="test" name="test" placeholder="مثال: صورة دم، وظائف كبد" required>
        </div>
        <div class="input-group">
          <label><i class="fas fa-phone"></i> رقم الهاتف</label>
          <input type="tel" id="phone" name="phone" placeholder="10 أو 11 رقم" pattern="[0-9]{10,11}" required>
        </div>
        <div class="input-group">
          <label><i class="fas fa-envelope"></i> البريد الإلكتروني</label>
          <input type="email" id="email" name="email" placeholder="patient@example.com" required>
        </div>
        <div class="input-group">
          <label><i class="fas fa-file-pdf"></i> ملف النتيجة</label>
          <input type="file" id="pdf" name="pdf" accept=".pdf,.jpg,.jpeg,.png,.doc,.docx" required>
        </div>
        <div class="input-group">
          <label><i class="fas fa-sticky-note"></i> ملاحظات (اختياري)</label>
          <textarea id="notes" name="notes" rows="2" placeholder="أي ملاحظات خاصة..."></textarea>
        </div>
      </div>
      <button type="submit" class="upload-btn" id="uploadButton">
        <i class="fas fa-cloud-upload-alt"></i> رفع النتيجة
      </button>
    </form>
  </div>

  <!-- عرض النتائج -->
  <div class="results-card">
    <div class="section-title">
      <i class="fas fa-database"></i> قاعدة البيانات
    </div>

    <% if (results.length > 0) { %>
      <!-- جدول للشاشات الكبيرة -->
      <table class="desktop-table">
        <thead>
          <tr><th>المريض</th><th>نوع التحليل</th><th>الهاتف</th><th>البريد</th><th>الملف</th><th>التاريخ</th><th>الإجراءات</th></tr>
        </thead>
        <tbody>
          <% results.forEach((r) => { %>
            <tr id="row-<%= r.id %>">
              <td><strong><%= r.name %></strong><br><small style="color:#64748b;"><%= r.test %></small></td>
              <td><%= r.test %></td>
              <td><%= r.phone %></td>
              <td><%= r.email %></td>
              <td><a href="/view/<%= r.id %>" target="_blank" class="btn-mini btn-view" style="padding:4px 12px;"><i class="fas fa-eye"></i> عرض</a></td>
              <td><%= r.date %></td>
              <td>
                <div class="action-group" style="gap:6px;">
                  <button class="btn-mini btn-delete" onclick="deleteResult('<%= r.id %>', '<%= r.name %>')"><i class="fas fa-trash"></i> حذف</button>
                  <button class="btn-mini btn-notify" onclick="sendNotification('<%= r.id %>', '<%= r.name %>')"><i class="fas fa-bell"></i> إشعار</button>
                </div>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>

      <!-- كروت للموبايل -->
      <div class="mobile-cards">
        <% results.forEach((r) => { %>
          <div class="result-mobile-card" id="mobile-row-<%= r.id %>">
            <div class="mobile-row">
              <span class="mobile-label">المريض:</span>
              <span class="mobile-value"><strong><%= r.name %></strong></span>
            </div>
            <div class="mobile-row">
              <span class="mobile-label">نوع التحليل:</span>
              <span class="mobile-value"><%= r.test %></span>
            </div>
            <div class="mobile-row">
              <span class="mobile-label">الهاتف:</span>
              <span class="mobile-value"><%= r.phone %></span>
            </div>
            <div class="mobile-row">
              <span class="mobile-label">البريد:</span>
              <span class="mobile-value"><%= r.email %></span>
            </div>
            <div class="mobile-row">
              <span class="mobile-label">التاريخ:</span>
              <span class="mobile-value"><%= r.date %></span>
            </div>
            <div class="action-group">
              <a href="/view/<%= r.id %>" target="_blank" class="btn-mini btn-view"><i class="fas fa-eye"></i> عرض الملف</a>
              <button class="btn-mini btn-delete" onclick="deleteResult('<%= r.id %>', '<%= r.name %>')"><i class="fas fa-trash"></i> حذف</button>
              <button class="btn-mini btn-notify" onclick="sendNotification('<%= r.id %>', '<%= r.name %>')"><i class="fas fa-bell"></i> إشعار</button>
            </div>
          </div>
        <% }) %>
      </div>
    <% } else { %>
      <div class="empty-state">
        <i class="fas fa-folder-open" style="font-size: 3rem; margin-bottom: 12px;"></i>
        <p>لا توجد نتائج مسجلة حتى الآن</p>
        <p style="font-size: 0.8rem;">استخدم النموذج أعلاه لإضافة أول نتيجة</p>
      </div>
    <% } %>
  </div>
</div>

<script>
  function showNotification(message, type = 'success') {
    const existing = document.querySelector('.toast-notify');
    if(existing) existing.remove();
    
    const toast = document.createElement('div');
    toast.className = `toast-notify toast-${type}`;
    const icon = type === 'success' ? '<i class="fas fa-check-circle"></i>' : '<i class="fas fa-exclamation-triangle"></i>';
    toast.innerHTML = `${icon} <span>${message}</span> <i class="fas fa-times-circle" style="margin-right: auto; cursor: pointer;" onclick="this.parentElement.remove()"></i>`;
    document.body.appendChild(toast);
    setTimeout(() => toast.remove(), 4000);
  }

  async function deleteResult(id, patientName) {
    if (!confirm(`⚠️ حذف نتيجة\n\nهل أنت متأكد من حذف نتيجة: ${patientName}؟`)) return;
    
    const row = document.getElementById(`row-${id}`);
    const mobileRow = document.getElementById(`mobile-row-${id}`);
    
    try {
      const response = await fetch('/admin/delete', {
        method: 'POST',
        headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
        body: `file=${encodeURIComponent(id)}`
      });
      
      if (response.ok) {
        showNotification(`✅ تم حذف نتيجة ${patientName}`, 'success');
        if (row) row.remove();
        if (mobileRow) mobileRow.remove();
        updateStatsAfterDelete();
        
        // تحديث العدد الكلي
        const remaining = document.querySelectorAll('.desktop-table tbody tr, .result-mobile-card').length;
        if (remaining === 0) location.reload();
      } else {
        throw new Error('فشل الحذف');
      }
    } catch(error) {
      showNotification('❌ حدث خطأ أثناء الحذف', 'error');
    }
  }

  async function sendNotification(id, patientName) {
    if (!confirm(`📨 إرسال إشعار\n\nهل تريد إرسال إشعار للمريض: ${patientName}؟`)) return;
    
    const btn = event?.target?.closest?.('.btn-notify');
    const originalHTML = btn ? btn.innerHTML : 'إشعار';
    if (btn) {
      btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i>';
      btn.disabled = true;
    }
    
    try {
      const response = await fetch('/admin/notify', {
        method: 'POST',
        headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
        body: `file=${encodeURIComponent(id)}`
      });
      
      if (response.ok) {
        showNotification(`📨 تم إرسال الإشعار إلى ${patientName}`, 'success');
      } else {
        throw new Error('فشل الإرسال');
      }
    } catch(err) {
      showNotification('⚠️ فشل إرسال الإشعار', 'error');
    } finally {
      if (btn) {
        btn.innerHTML = originalHTML;
        btn.disabled = false;
      }
    }
  }

  function updateStatsAfterDelete() {
    const totalElem = document.querySelector('#totalResultsCount');
    if (totalElem) {
      let current = parseInt(totalElem.innerText) || 0;
      if (current > 0) totalElem.innerText = current - 1;
    }
    updateStats();
  }

  function updateStats() {
    const rows = document.querySelectorAll('.desktop-table tbody tr, .result-mobile-card').length;
    const sent = Math.floor(rows * 0.7);
    const pending = rows - sent;
    
    const sentSpan = document.getElementById('sentCount');
    const pendingSpan = document.getElementById('pendingCount');
    if (sentSpan) sentSpan.innerText = sent;
    if (pendingSpan) pendingSpan.innerText = pending;
  }

  document.addEventListener('DOMContentLoaded', function() {
    updateStats();
    
    const form = document.getElementById('uploadForm');
    if (form) {
      form.addEventListener('submit', function(e) {
        const phone = document.getElementById('phone').value;
        if (!/^[0-9]{10,11}$/.test(phone.replace(/\D/g, ''))) {
          e.preventDefault();
          showNotification('⚠️ رقم الهاتف يجب أن يكون 10 أو 11 رقم', 'error');
          return false;
        }
        const btn = document.getElementById('uploadButton');
        btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> جاري الرفع...';
        btn.disabled = true;
        return true;
      });
    }
  });
</script>
</body>
</html>
